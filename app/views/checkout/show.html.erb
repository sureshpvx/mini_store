<div class="max-w-7xl mx-auto px-6 py-16">

  <!-- HEADER -->
  <div class="mb-14">

    <p class="text-xs uppercase tracking-[0.45em] text-gray-500 mb-4">
      Checkout
    </p>

    <h1 class="text-5xl text-white font-semibold">
      Complete Your Order
    </h1>

    <p class="text-gray-500 mt-5 text-lg">
      Select a shipping address and review your order.
    </p>

  </div>

  <%= form_with url: orders_path, method: :post do |form| %>

    <div class="grid grid-cols-1 lg:grid-cols-[1.3fr_0.7fr] gap-10">

      <!-- LEFT -->
      <div>

        <!-- ADDRESS SECTION -->
        <div class="border border-white/10
                    bg-[#070707]
                    rounded-[32px]
                    p-8">

          <div class="flex items-center justify-between gap-6 mb-8">

            <div>

              <p class="text-xs uppercase tracking-[0.35em] text-gray-500 mb-3">
                Shipping
              </p>

              <h2 class="text-3xl text-white font-light">
                Select Address
              </h2>

            </div>

            <%= link_to "Add New",
                        new_address_path(return_to: checkout_path),
                        class: "inline-flex items-center justify-center
                               h-12 px-6
                               rounded-full
                               border border-white/15
                               uppercase tracking-[0.3em]
                               text-xs text-white
                               hover:bg-white hover:text-black
                               transition-all duration-500" %>

          </div>

          <% if @addresses.any? %>

            <div class="space-y-5">

              <% @addresses.each_with_index do |address, index| %>

                <label class="block cursor-pointer">

                  <div class="border border-white/10
                              rounded-3xl
                              p-6
                              hover:border-white/30
                              transition-all duration-300">

                    <!-- TOP -->
                    <div class="flex items-start justify-between gap-6">

                      <div>

                        <h3 class="text-xl text-white font-medium">
                          <%= address.full_name %>
                        </h3>

                        <p class="text-gray-500 mt-2">
                          <%= address.phone_number %>
                        </p>

                      </div>

                      <!-- WORKING RADIO -->
                      <%= form.radio_button :address_id,
                                            address.id,
                                            checked: index == 0,
                                            class: "w-5 h-5 accent-white cursor-pointer" %>

                    </div>

                    <!-- ADDRESS -->
                    <div class="mt-6 space-y-2 text-gray-300">

                      <p>
                        <%= address.address_line_1 %>
                      </p>

                      <% if address.address_line_2.present? %>

                        <p>
                          <%= address.address_line_2 %>
                        </p>

                      <% end %>

                      <p>
                        <%= address.city %>,
                        <%= address.state %>
                      </p>

                      <p>
                        <%= address.postal_code %>
                      </p>

                      <p>
                        <%= address.country %>
                      </p>

                    </div>

                  </div>

                </label>

              <% end %>

            </div>

          <% else %>

            <!-- EMPTY ADDRESS STATE -->
            <div class="border border-dashed border-white/10
                        rounded-3xl
                        p-12
                        text-center">

              <p class="text-gray-500 mb-6">
                No saved addresses found.
              </p>

              <%= link_to "Add Address",
                          new_address_path(return_to: checkout_path),
                          class: "inline-flex items-center justify-center
                                 h-14 px-8
                                 rounded-full
                                 bg-white text-black
                                 uppercase tracking-[0.35em]
                                 text-sm
                                 hover:opacity-90
                                 transition-all duration-500" %>

            </div>

          <% end %>

        </div>

      </div>

      <!-- RIGHT -->
      <div>

        <div class="border border-white/10
                    bg-[#070707]
                    rounded-[32px]
                    p-8
                    sticky top-10">

          <p class="text-xs uppercase tracking-[0.35em] text-gray-500 mb-4">
            Order Summary
          </p>

          <h2 class="text-3xl text-white font-light mb-8">
            Your Cart
          </h2>

          <div class="space-y-6">

            <% @cart.cart_items.each do |item| %>

              <div class="flex items-center justify-between gap-5">

                <!-- LEFT -->
                <div class="flex items-center gap-4">

                  <div class="w-16 h-20 rounded-2xl overflow-hidden bg-black">

                    <% if item.product.images.attached? %>

                      <%= image_tag item.product.images.first,
                                    class: "w-full h-full object-cover" %>

                    <% end %>

                  </div>

                  <div>

                    <h3 class="text-white uppercase tracking-wide text-sm">
                      <%= item.product.name %>
                    </h3>

                    <p class="text-gray-500 mt-2 text-sm">
                      Qty:
                      <span class="text-gray-300">
                        <%= item.quantity %>
                      </span>
                    </p>

                  </div>

                </div>

                <!-- RIGHT -->
                <div>

                  <p class="text-white">
                    ₹ <%= item.total_price.to_f.round(2) %>
                  </p>

                </div>

              </div>

            <% end %>

          </div>

          <!-- TOTAL -->
          <div class="border-t border-white/10 mt-10 pt-8">

            <div class="flex justify-between items-center mb-5">

              <span class="text-gray-400">
                Subtotal
              </span>

              <span class="text-white">
                ₹ <%= @cart.total_price.to_f.round(2) %>
              </span>

            </div>

            <div class="flex justify-between items-center mb-8">

              <span class="text-gray-400">
                Shipping
              </span>

              <span class="text-white">
                Free
              </span>

            </div>

            <div class="flex justify-between items-center">

              <span class="text-xl uppercase tracking-[0.3em] text-white">
                Total
              </span>

              <span class="text-3xl text-white font-light">
                ₹ <%= @cart.total_price.to_f.round(2) %>
              </span>

            </div>

          </div>

          <!-- PLACE ORDER -->
          <div class="mt-10">

            <%= form.submit "Place Order",
                            class: "w-full h-16
                                   rounded-full
                                   bg-white text-black
                                   uppercase tracking-[0.35em]
                                   text-sm
                                   hover:opacity-90
                                   transition-all duration-500
                                   cursor-pointer" %>

          </div>

        </div>

      </div>

    </div>

  <% end %>

</div>