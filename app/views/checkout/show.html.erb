<div data-controller="checkout modal">

  <div class="max-w-[1440px] mx-auto px-4 sm:px-10 py-16 sm:py-24">

    <!-- GLOBAL ADDRESS MODAL -->
    <%= render "shared/modal",
               title: "Add Address",
               modal_id: "address-modal" do %>

      <%= render "addresses/form",
                 address: Address.new %>

    <% end %>

    <!-- OTP MODAL -->
    <%= render "shared/modal",
               title: "Secure Checkout",
               modal_id: "otp-modal" do %>

      <%= render "otp_auth/form" %>

    <% end %>

    <!-- HIDDEN TRIGGER for OTP modal -->
    <button type="button"
            id="otp-modal-trigger"
            data-checkout-target="otpTrigger"
            data-modal-id="otp-modal"
            data-action="click->modal#open"
            class="hidden">
      Open OTP
    </button>

    <!-- HEADER -->
    <div class="mb-14">

      <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-3">
        Checkout
      </p>

      <h1 class="text-2xl sm:text-3xl font-light uppercase tracking-[0.1em] text-black">
        Complete Your Order
      </h1>

      <p class="text-gray-400 mt-4 text-sm leading-relaxed font-light max-w-md">
        Select a shipping address and review your order.
      </p>

    </div>

    <!-- CHECKOUT FORM -->
    <%= form_with url: orders_path,
                  method: :post,
                  data: { turbo: false, checkout_target: "form", action: "submit->checkout#submitOrder" },
                  html: { id: "checkout-form" } do |form| %>

      <div class="grid grid-cols-1 lg:grid-cols-[1.3fr_0.7fr] gap-6 lg:gap-10">

        <!-- LEFT -->
        <div>

          <!-- ADDRESS SECTION -->
          <div class="border border-black/[0.06] bg-white p-6 sm:p-8">

            <div class="flex items-center justify-between gap-6 mb-8">

              <div>

                <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-3">
                  Shipping
                </p>

                <h2 class="text-xl sm:text-2xl font-light uppercase tracking-[0.1em] text-black">
                  Select Address
                </h2>

              </div>

              <!-- OPEN MODAL BUTTON -->
              <button
                type="button"
                data-modal-id="address-modal"
                data-action="click->modal#open"
                class="inline-flex items-center justify-center h-12 px-6 border border-black/30 uppercase tracking-[0.2em] text-[11px] text-black hover:bg-black hover:text-white transition-all duration-300">
                Add New
              </button>

            </div>

            <!-- VISIBLE ERROR MESSAGE -->
            <div data-checkout-target="error" id="address-error" class="hidden mb-6 text-[11px] uppercase tracking-[0.2em] text-red-500 text-center border border-red-200 bg-red-50 px-4 py-3">
              Please select a shipping address
            </div>

            <div class="space-y-4">

              <% if @addresses.present? %>

                <% @addresses.compact.each_with_index do |address, index| %>

                  <% next if address.full_name.blank? %>

                  <label
                    data-checkout-target="addressCard"
                    data-action="click->checkout#toggleAddress"
                    class="relative block cursor-pointer border border-black/[0.06] p-6 hover:border-black/20 transition-all duration-300 <%= 'border-black/30 bg-gray-50/50' if index == 0 && false %>">

                    <%= radio_button_tag :address_id,
                                         address.id,
                                         false,
                                         id: "address_#{address.id}",
                                         data: {
                                           action: "change->checkout#addressChanged"
                                         },
                                         class: "absolute top-6 right-6 w-5 h-5 accent-black cursor-pointer" %>

                    <div class="pr-12">

                      <h3 class="text-lg font-light text-black mb-1 tracking-wide">
                        <%= address.full_name %>
                      </h3>

                      <p class="text-gray-400 text-sm mb-4 font-light">
                        <%= address.phone_number %>
                      </p>

                      <div class="space-y-1 text-gray-500 text-sm leading-relaxed font-light">

                        <p><%= address.address_line_1 %></p>

                        <% if address.address_line_2.present? %>
                          <p><%= address.address_line_2 %></p>
                        <% end %>

                        <p>
                          <%= address.city %>,
                          <%= address.state %>
                        </p>

                        <p><%= address.postal_code %></p>

                        <p><%= address.country %></p>

                      </div>

                    </div>

                  </label>

                <% end %>

              <% else %>

                <div class="border border-dashed border-black/[0.06] p-16 text-center">

                  <p class="text-gray-400 mb-8 font-light text-sm">
                    No saved addresses found.
                  </p>

                  <button
                    type="button"
                    data-modal-id="address-modal"
                    data-action="click->modal#open"
                    class="px-8 h-12 bg-black text-white uppercase tracking-[0.2em] text-[11px] hover:bg-gray-800 transition">
                    Add Address
                  </button>

                </div>

              <% end %>

            </div>

          </div>

        </div>

        <!-- RIGHT -->
        <div>

          <div class="border border-black/[0.06] bg-white p-6 sm:p-8 sticky top-24">

            <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-3">
              Order Summary
            </p>

            <h2 class="text-xl sm:text-2xl font-light uppercase tracking-[0.1em] text-black mb-8">
              Your Cart
            </h2>

            <div class="space-y-6">

              <% @cart.cart_items.each do |item| %>

                <div class="flex items-center justify-between gap-5">

                  <div class="flex items-center gap-4">

                    <div class="w-16 h-20 overflow-hidden bg-gray-50 flex-shrink-0">

                      <% if item.product.images.attached? %>

                        <%= image_tag item.product.images.first,
                                      class: "w-full h-full object-cover" %>

                      <% end %>

                    </div>

                    <div>

                      <h3 class="text-black uppercase tracking-[0.15em] text-[11px] font-medium">
                        <%= item.product.name %>
                      </h3>

                      <p class="text-gray-400 mt-1 text-[11px] tracking-wide">
                        Qty:
                        <span class="text-black">
                          <%= item.quantity %>
                        </span>
                      </p>

                    </div>

                  </div>

                  <div>

                    <p class="text-black font-light text-sm">
                      ₹ <%= item.total_price.to_f.round(2) %>
                    </p>

                  </div>

                </div>

              <% end %>

            </div>

            <!-- TOTAL -->
            <div class="border-t border-black/[0.06] mt-8 pt-6 space-y-3">

              <div class="flex justify-between items-center">

                <span class="text-[11px] uppercase tracking-[0.2em] text-gray-400">
                  Subtotal
                </span>

                <span class="text-black font-light">
                  ₹ <%= @cart.total_price.to_f.round(2) %>
                </span>

              </div>

              <div class="flex justify-between items-center">

                <span class="text-[11px] uppercase tracking-[0.2em] text-gray-400">
                  Shipping
                </span>

                <span class="text-black font-light">
                  Free
                </span>

              </div>

              <div class="flex justify-between items-center pt-2">

                <span class="text-sm uppercase tracking-[0.2em] text-black font-light">
                  Total
                </span>

                <span class="text-2xl text-black font-light">
                  ₹ <%= @cart.total_price.to_f.round(2) %>
                </span>

              </div>

            </div>

            <!-- PLACE ORDER -->
            <div class="mt-8 space-y-3">

              <% if user_signed_in? %>

                <%= form.submit "Place Order",
                                class: "w-full h-14 bg-black text-white uppercase tracking-[0.2em] text-[11px] hover:bg-gray-800 transition-all duration-300 cursor-pointer" %>

              <% else %>

                <button
                  id="place-order-button"
                  type="button"
                  data-action="click->checkout#placeOrderAsGuest"
                  class="w-full h-14 bg-black text-white uppercase tracking-[0.2em] text-[11px] hover:bg-gray-800 transition-all duration-300">
                  Place Order
                </button>

              <% end %>

            </div>

          </div>

        </div>

      </div>

    <% end %>

  </div>

</div>

<% if params[:auto_submit].present? && session[:auto_order_address_id].present? %>

  <script>
      document.addEventListener("DOMContentLoaded", () => {
          const checkoutForm = document.getElementById("checkout-form");
          if (!checkoutForm) return;

          let hiddenInput = document.createElement("input");
          hiddenInput.type = "hidden";
          hiddenInput.name = "address_id";
          hiddenInput.value = "<%= session[:auto_order_address_id] %>";
          checkoutForm.appendChild(hiddenInput);
          checkoutForm.submit();
      });
  </script>

<% end %>