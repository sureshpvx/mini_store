<div data-controller="modal">

  <div class="max-w-7xl mx-auto px-6 py-16">

    <!-- GLOBAL ADDRESS MODAL -->
    <%= render "shared/modal",
               title: "Add Address",
               modal_id: "address-modal" do %>

      <%= render "addresses/form",
                 address: Address.new %>

    <% end %>

    <!-- OTP MODAL -->
    <%= render "shared/modal",
               title: "Secure Checkout",
               modal_id: "otp-modal" do %>

      <%= render "otp_auth/form" %>

    <% end %>

    <!-- HEADER -->
    <div class="mb-14">

      <p class="text-xs uppercase tracking-[0.45em] text-gray-500 mb-4">
        Checkout
      </p>

      <h1 class="text-5xl text-white font-semibold">
        Complete Your Order
      </h1>

      <p class="text-gray-500 mt-5 text-lg">
        Select a shipping address and review your order.
      </p>

    </div>

    <!-- CHECKOUT FORM -->
    <%= form_with url: orders_path,
                  method: :post,
                  data: { turbo: false },
                  html: { id: "checkout-form" } do |form| %>

      <div class="grid grid-cols-1 lg:grid-cols-[1.3fr_0.7fr] gap-10">

        <!-- LEFT -->
        <div>

          <!-- ADDRESS SECTION -->
          <div class="border border-white/10
                      bg-[#070707]
                      rounded-[32px]
                      p-8">

            <div class="flex items-center justify-between gap-6 mb-8">

              <div>

                <p class="text-xs uppercase tracking-[0.35em] text-gray-500 mb-3">
                  Shipping
                </p>

                <h2 class="text-3xl text-white font-light">
                  Select Address
                </h2>

              </div>

              <!-- OPEN MODAL BUTTON -->
              <button
                type="button"
                data-modal-id="address-modal"
                data-action="click->modal#open"
                class="
                  inline-flex items-center justify-center
                  h-12 px-6
                  rounded-full
                  border border-white/15
                  uppercase tracking-[0.3em]
                  text-xs text-white
                  hover:bg-white hover:text-black
                  transition-all duration-500
                ">
                Add New
              </button>

            </div>

            <div class="space-y-6">

              <% if @addresses.present? %>

                <% @addresses.compact.each do |address| %>

                  <% next if address.full_name.blank? %>

                  <label
                    class="
                      relative block cursor-pointer
                      border border-white/10
                      rounded-[32px]
                      p-8
                      hover:border-white/20
                      transition-all duration-300
                    ">

                    <%= radio_button_tag :address_id,
                                         address.id,
                                         false,
                                         data: {
                                           address_id: address.id
                                         },class: "
                                           absolute top-8 right-8
                                           w-5 h-5
                                         " %>


                    <div class="pr-16">

                      <h3 class="text-3xl font-light text-white mb-3">
                        <%= address.full_name %>
                      </h3>

                      <p class="text-gray-500 text-lg mb-8">
                        <%= address.phone_number %>
                      </p>

                      <div class="space-y-3 text-gray-300 text-xl leading-relaxed">

                        <p><%= address.address_line_1 %></p>

                        <% if address.address_line_2.present? %>
                          <p><%= address.address_line_2 %></p>
                        <% end %>

                        <p>
                          <%= address.city %>,
                          <%= address.state %>
                        </p>

                        <p><%= address.postal_code %></p>

                        <p><%= address.country %></p>

                      </div>

                    </div>

                  </label>

                <% end %>

              <% else %>

                <div
                  class="
                    border border-dashed border-white/10
                    rounded-[32px]
                    p-16
                    text-center
                  ">

                  <p class="text-gray-500 mb-8">
                    No saved addresses found.
                  </p>

                  <button
                    type="button"
                    data-modal-id="address-modal"
                    data-action="click->modal#open"
                    class="
                      px-10 h-14 rounded-full
                      bg-white text-black
                      uppercase tracking-[0.3em]
                      text-sm
                    ">
                    Add Address
                  </button>

                </div>

              <% end %>

            </div>

          </div>

        </div>

        <!-- RIGHT -->
        <div>

          <div class="border border-white/10
                      bg-[#070707]
                      rounded-[32px]
                      p-8
                      sticky top-10">

            <p class="text-xs uppercase tracking-[0.35em] text-gray-500 mb-4">
              Order Summary
            </p>

            <h2 class="text-3xl text-white font-light mb-8">
              Your Cart
            </h2>

            <div class="space-y-6">

              <% @cart.cart_items.each do |item| %>

                <div class="flex items-center justify-between gap-5">

                  <div class="flex items-center gap-4">

                    <div class="w-16 h-20 rounded-2xl overflow-hidden bg-black">

                      <% if item.product.images.attached? %>

                        <%= image_tag item.product.images.first,
                                      class: "w-full h-full object-cover" %>

                      <% end %>

                    </div>

                    <div>

                      <h3 class="text-white uppercase tracking-wide text-sm">
                        <%= item.product.name %>
                      </h3>

                      <p class="text-gray-500 mt-2 text-sm">
                        Qty:
                        <span class="text-gray-300">
                          <%= item.quantity %>
                        </span>
                      </p>

                    </div>

                  </div>

                  <div>

                    <p class="text-white">
                      ₹ <%= item.total_price.to_f.round(2) %>
                    </p>

                  </div>

                </div>

              <% end %>

            </div>

            <!-- TOTAL -->
            <div class="border-t border-white/10 mt-10 pt-8">

              <div class="flex justify-between items-center mb-5">

                <span class="text-gray-400">
                  Subtotal
                </span>

                <span class="text-white">
                  ₹ <%= @cart.total_price.to_f.round(2) %>
                </span>

              </div>

              <div class="flex justify-between items-center mb-8">

                <span class="text-gray-400">
                  Shipping
                </span>

                <span class="text-white">
                  Free
                </span>

              </div>

              <div class="flex justify-between items-center">

                <span class="text-xl uppercase tracking-[0.3em] text-white">
                  Total
                </span>

                <span class="text-3xl text-white font-light">
                  ₹ <%= @cart.total_price.to_f.round(2) %>
                </span>

              </div>

            </div>

            <!-- PLACE ORDER -->
            <div class="mt-10">

              <% if user_signed_in? %>

                <%= form.submit "Place Order",
                                class: "
                                  w-full
                                  h-16
                                  rounded-full
                                  bg-white
                                  text-black
                                  uppercase
                                  tracking-[0.35em]
                                  text-sm
                                  hover:opacity-90
                                  transition-all duration-500
                                  cursor-pointer
                                " %>

              <% else %>

                <button
                  id="place-order-button"
                  type="button"
                  data-modal-id="otp-modal"
                  data-action="click->modal#open"
                  class="
    w-full
    h-16
    rounded-full
    bg-white
    text-black
    uppercase
    tracking-[0.35em]
    text-sm
    hover:opacity-90
    transition-all duration-500
  ">

                  Place Order

                </button>

              <% end %>

            </div>

          </div>

        </div>

      </div>

    <% end %>

  </div>

</div>

<% if params[:auto_submit].present? %>

  <script>
      document.addEventListener("DOMContentLoaded", () => {

          const checkoutForm =
              document.getElementById("checkout-form")

          if (!checkoutForm) return

          let hiddenInput =
              document.createElement("input")

          hiddenInput.type = "hidden"
          hiddenInput.name = "address_id"

          hiddenInput.value =
              "<%= session[:auto_order_address_id] %>"

          checkoutForm.appendChild(hiddenInput)

          checkoutForm.submit()

      })
  </script>

<% end %>
<script>
    document.addEventListener("DOMContentLoaded", () => {

        const placeOrderButton =
            document.getElementById("place-order-button")

        if (!placeOrderButton) return

        placeOrderButton.addEventListener("click", async (e) => {

            const selectedAddress =
                document.querySelector("input[name='address_id']:checked")

            if (!selectedAddress) {

                e.preventDefault()

                alert("Please select a shipping address")

                return
            }

            await fetch("/store-checkout-address", {

                method: "POST",

                headers: {
                    "Content-Type": "application/json",
                    "X-CSRF-Token":
                    document.querySelector(
                        'meta[name="csrf-token"]'
                    ).content
                },

                body: JSON.stringify({
                    address_id: selectedAddress.value
                })

            })

        })

    })
</script>