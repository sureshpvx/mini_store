<!-- app/views/addresses/edit.html.erb -->
<div class="min-h-screen bg-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">

    <!-- Header -->
    <div class="mb-10 sm:mb-14">
      <p class="text-xs uppercase tracking-[0.45em] text-gray-400 mb-4">
        Address
      </p>
      <h1 class="text-3xl sm:text-4xl text-black font-light tracking-[0.05em]">
        Edit Address
      </h1>
      <p class="text-gray-400 mt-4 text-sm font-light">
        Update your shipping information.
      </p>
    </div>

    <!-- Form Card -->
    <div class="border border-black/[0.06] bg-white p-6 sm:p-10">
      <%= render "form", address: @address %>
    </div>

  </div>
</div>