<div class="max-w-6xl mx-auto px-6 py-16">

  <!-- HEADER -->
  <div class="flex flex-col lg:flex-row
              lg:items-center
              lg:justify-between
              gap-8
              mb-14">

    <div>

      <p class="text-xs uppercase tracking-[0.45em] text-gray-500 mb-4">
        Account
      </p>

      <h1 class="text-5xl text-white font-semibold">
        Saved Addresses
      </h1>

      <p class="text-gray-500 mt-5 text-lg">
        Manage your shipping destinations.
      </p>

    </div>

    <%= link_to "Add Address",
                new_address_path,
                class: "inline-flex items-center justify-center
                       h-14 px-8
                       rounded-full
                       bg-white text-black
                       uppercase tracking-[0.35em]
                       text-sm
                       hover:opacity-90
                       transition-all duration-500" %>

  </div>

  <% if @addresses.any? %>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

      <% @addresses.each do |address| %>

        <div class="border border-white/10
                    bg-[#070707]
                    rounded-[32px]
                    p-8
                    min-h-[380px]
                    flex flex-col justify-between">

          <!-- TOP -->
          <div>

            <div class="flex items-start justify-between gap-6">

              <div>

                <h2 class="text-2xl text-white font-medium">
                  <%= address.full_name %>
                </h2>

                <p class="text-gray-500 mt-2">
                  <%= address.phone_number %>
                </p>

              </div>

            </div>

            <!-- ADDRESS -->
            <div class="mt-8 space-y-3">

              <p class="text-white text-lg">
                <%= address.address_line_1 %>
              </p>

              <% if address.address_line_2.present? %>

                <p class="text-gray-400">
                  <%= address.address_line_2 %>
                </p>

              <% end %>

              <p class="text-gray-400">
                <%= address.city %>,
                <%= address.state %>
              </p>

              <p class="text-gray-500 text-sm uppercase tracking-wide">
                <%= address.postal_code %>
              </p>

              <p class="text-gray-500">
                <%= address.country %>
              </p>

            </div>

          </div>

          <!-- ACTIONS -->
          <!-- ACTIONS -->
          <div class="mt-10 flex flex-col sm:flex-row gap-4">

            <%= link_to "Edit",
                        edit_address_path(address),
                        class: "flex-1 h-12
                     border border-white/15
                     rounded-full
                     flex items-center justify-center
                     uppercase tracking-[0.3em]
                     text-xs text-white
                     hover:bg-white hover:text-black
                     transition-all duration-500" %>

            <%= button_to "Delete",
                          address_path(address),
                          method: :delete,
                          data: {
                            turbo_confirm: "Delete this address?"
                          },
                          form_class: "flex-1",
                          class: "w-full h-12
                       border border-red-500/20
                       text-red-400
                       rounded-full
                       uppercase tracking-[0.3em]
                       text-xs
                       hover:bg-red-500
                       hover:text-white
                       transition-all duration-500" %>

          </div>

        </div>

      <% end %>

    </div>

  <% else %>

    <!-- EMPTY STATE -->
    <div class="border border-white/10
                bg-[#070707]
                rounded-[32px]
                p-16
                text-center">

      <p class="text-xs uppercase tracking-[0.45em] text-gray-500 mb-6">
        No Addresses Saved
      </p>

      <h2 class="text-4xl text-white font-light mb-5">
        Add your first shipping address.
      </h2>

      <p class="text-gray-500 max-w-xl mx-auto leading-relaxed">
        Save addresses for faster and smoother checkout experiences.
      </p>

      <div class="mt-10">

        <%= link_to "Add Address",
                    new_address_path,
                    class: "inline-flex items-center justify-center
                           h-16 px-10
                           rounded-full
                           bg-white text-black
                           uppercase tracking-[0.35em]
                           text-sm
                           hover:opacity-90
                           transition-all duration-500" %>

      </div>

    </div>

  <% end %>

</div>