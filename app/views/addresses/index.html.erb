<!-- app/views/addresses/index.html.erb -->
<div class="min-h-screen bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12 sm:mb-14">

      <div>
        <p class="text-xs uppercase tracking-[0.45em] text-gray-400 mb-4">
          Account
        </p>
        <h1 class="text-3xl sm:text-4xl text-black font-light tracking-[0.05em]">
          Saved Addresses
        </h1>
        <p class="text-gray-400 mt-4 text-sm font-light">
          Manage your shipping destinations.
        </p>
      </div>

      <%= link_to new_address_path,
                  class: "inline-flex items-center justify-center h-12 sm:h-14 px-8 border border-black text-black uppercase tracking-[0.2em] text-[11px] hover:bg-black hover:text-white transition-all duration-300 shrink-0" do %>
        Add Address
      <% end %>

    </div>

    <% if @addresses.any? %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <% @addresses.each do |address| %>

          <div class="border border-black/[0.06] bg-white p-6 sm:p-8 flex flex-col justify-between">

            <!-- Content -->
            <div>

              <h2 class="text-lg text-black font-medium tracking-wide">
                <%= address.full_name %>
              </h2>

              <p class="text-gray-400 text-sm mt-1">
                <%= address.phone_number %>
              </p>

              <div class="mt-6 space-y-1.5">

                <p class="text-black text-sm">
                  <%= address.address_line_1 %>
                </p>

                <% if address.address_line_2.present? %>
                  <p class="text-gray-500 text-sm">
                    <%= address.address_line_2 %>
                  </p>
                <% end %>

                <p class="text-gray-500 text-sm">
                  <%= address.city %>, <%= address.state %>
                </p>

                <p class="text-gray-400 text-xs uppercase tracking-wide">
                  <%= address.postal_code %>
                </p>

                <p class="text-gray-400 text-sm">
                  <%= address.country %>
                </p>

              </div>

            </div>

            <!-- Actions -->
            <div class="mt-8 flex flex-col sm:flex-row gap-3">

              <%= link_to "Edit",
                          edit_address_path(address),
                          class: "flex-1 h-12 border border-black/[0.15] flex items-center justify-center uppercase tracking-[0.2em] text-[10px] text-black hover:bg-black hover:text-white transition-all duration-300" %>

              <%= button_to "Delete",
                            address_path(address),
                            method: :delete,
                            data: { turbo_confirm: "Delete this address?" },
                            form_class: "flex-1",
                            class: "w-full h-12 border border-red-200 text-red-500 uppercase tracking-[0.2em] text-[10px] hover:bg-red-500 hover:text-white hover:border-red-500 transition-all duration-300" %>

            </div>

          </div>

        <% end %>

      </div>

    <% else %>

      <!-- Empty State -->
      <div class="border border-black/[0.06] bg-white p-16 text-center">

        <p class="text-xs uppercase tracking-[0.45em] text-gray-400 mb-6">
          No Addresses Saved
        </p>

        <h2 class="text-2xl sm:text-3xl text-black font-light tracking-[0.05em] mb-4">
          Add your first shipping address.
        </h2>

        <p class="text-gray-400 text-sm max-w-md mx-auto font-light">
          Save addresses for a faster and smoother checkout experience.
        </p>

        <div class="mt-10">
          <%= link_to new_address_path,
                      class: "inline-flex items-center justify-center h-14 px-10 bg-black text-white uppercase tracking-[0.2em] text-[11px] hover:bg-gray-800 transition-all duration-300" do %>
            Add Address
          <% end %>
        </div>

      </div>

    <% end %>

  </div>
</div>