<%= form_with model: address,
              local: true do |f| %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

    <%= f.text_field :full_name,
                     placeholder: "Full Name",
                     class: "h-14 rounded-2xl bg-black border border-white/10 px-5 text-white" %>

    <%= f.text_field :phone_number,
                     placeholder: "Phone Number",
                     class: "h-14 rounded-2xl bg-black border border-white/10 px-5 text-white" %>

    <%= f.text_field :address_line_1,
                     placeholder: "Address Line 1",
                     class: "h-14 rounded-2xl bg-black border border-white/10 px-5 text-white md:col-span-2" %>

    <%= f.text_field :address_line_2,
                     placeholder: "Address Line 2",
                     class: "h-14 rounded-2xl bg-black border border-white/10 px-5 text-white md:col-span-2" %>

    <%= f.text_field :city,
                     placeholder: "City",
                     class: "h-14 rounded-2xl bg-black border border-white/10 px-5 text-white" %>

    <%= f.text_field :state,
                     placeholder: "State",
                     class: "h-14 rounded-2xl bg-black border border-white/10 px-5 text-white" %>

    <%= f.text_field :postal_code,
                     placeholder: "Postal Code",
                     class: "h-14 rounded-2xl bg-black border border-white/10 px-5 text-white" %>

    <%= f.text_field :country,
                     placeholder: "Country",
                     value: "India",
                     class: "h-14 rounded-2xl bg-black border border-white/10 px-5 text-white" %>

  </div>

  <%= f.submit "Save Address",
               class: "
                 mt-8
                 w-full
                 h-14
                 rounded-full
                 bg-white
                 text-black
                 uppercase
                 tracking-[0.3em]
                 text-sm
                 hover:opacity-90
                 transition-all
               " %>

<% end %>