<%# app/views/pages/shipping.html.erb %>
<section class="pt-32 pb-24 px-4 sm:px-8 bg-white min-h-screen">
  <div class="max-w-3xl mx-auto">
    <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-4">Information</p>
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-light uppercase tracking-[0.2em] text-black mb-16">
      Shipping & Delivery
    </h1>

    <div class="space-y-0">
      <div class="border-t border-black/[0.03] py-10">
        <h2 class="text-sm uppercase tracking-[0.2em] text-black mb-3">Domestic Shipping</h2>
        <p class="text-gray-600 text-sm leading-relaxed">
          We ship across India via Delhivery, Blue Dart, and DTDC. Orders are processed within 1–2 business days.
          Estimated delivery is 3–7 business days depending on your pin code.
        </p>
      </div>

      <div class="border-t border-black/[0.03] py-10">
        <h2 class="text-sm uppercase tracking-[0.2em] text-black mb-3">Shipping Rates</h2>
        <p class="text-gray-600 text-sm leading-relaxed">
          Free standard shipping on all orders above ₹2,500. Orders below this threshold incur a flat shipping fee of ₹150.
        </p>
      </div>

      <div class="border-t border-black/[0.03] py-10">
        <h2 class="text-sm uppercase tracking-[0.2em] text-black mb-3">Order Tracking</h2>
        <p class="text-gray-600 text-sm leading-relaxed">
          Once dispatched, you will receive an email and SMS with your tracking number and a link to monitor progress in real time.
        </p>
      </div>

      <div class="border-t border-black/[0.03] py-10">
        <h2 class="text-sm uppercase tracking-[0.2em] text-black mb-3">Lost or Damaged Packages</h2>
        <p class="text-gray-600 text-sm leading-relaxed">
          In the rare event of loss or damage in transit, contact us within 48 hours of delivery. We will initiate a replacement or refund immediately.
        </p>
      </div>
    </div>
  </div>
</section>