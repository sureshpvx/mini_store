<%# app/views/pages/size_guide.html.erb %>
<section class="pt-32 pb-24 px-4 sm:px-8 bg-white min-h-screen">
  <div class="max-w-4xl mx-auto">
    <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-4">Information</p>
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-light uppercase tracking-[0.2em] text-black mb-16">
      Size Guide
    </h1>

    <div class="space-y-12">
      <!-- Tops -->
      <div>
        <h2 class="text-xs uppercase tracking-[0.2em] text-black mb-6">Tops & Outerwear</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
            <tr class="border-t border-b border-black/10 text-[10px] uppercase tracking-[0.2em] text-gray-400">
              <th class="py-4 pr-6 font-normal">Size</th>
              <th class="py-4 pr-6 font-normal">Chest (in)</th>
              <th class="py-4 pr-6 font-normal">Shoulder (in)</th>
              <th class="py-4 pr-6 font-normal">Length (in)</th>
            </tr>
            </thead>
            <tbody class="text-gray-600">
            <tr class="border-b border-black/[0.03]"><td class="py-4 pr-6 text-black">S</td><td class="py-4 pr-6">38–40</td><td class="py-4 pr-6">17.5</td><td class="py-4 pr-6">27</td></tr>
            <tr class="border-b border-black/[0.03]"><td class="py-4 pr-6 text-black">M</td><td class="py-4 pr-6">40–42</td><td class="py-4 pr-6">18.0</td><td class="py-4 pr-6">28</td></tr>
            <tr class="border-b border-black/[0.03]"><td class="py-4 pr-6 text-black">L</td><td class="py-4 pr-6">42–44</td><td class="py-4 pr-6">18.5</td><td class="py-4 pr-6">29</td></tr>
            <tr class="border-b border-black/[0.03]"><td class="py-4 pr-6 text-black">XL</td><td class="py-4 pr-6">44–46</td><td class="py-4 pr-6">19.0</td><td class="py-4 pr-6">30</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Bottoms -->
      <div>
        <h2 class="text-xs uppercase tracking-[0.2em] text-black mb-6">Bottoms</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
            <tr class="border-t border-b border-black/10 text-[10px] uppercase tracking-[0.2em] text-gray-400">
              <th class="py-4 pr-6 font-normal">Size</th>
              <th class="py-4 pr-6 font-normal">Waist (in)</th>
              <th class="py-4 pr-6 font-normal">Hip (in)</th>
              <th class="py-4 pr-6 font-normal">Inseam (in)</th>
            </tr>
            </thead>
            <tbody class="text-gray-600">
            <tr class="border-b border-black/[0.03]"><td class="py-4 pr-6 text-black">30</td><td class="py-4 pr-6">30</td><td class="py-4 pr-6">36</td><td class="py-4 pr-6">30</td></tr>
            <tr class="border-b border-black/[0.03]"><td class="py-4 pr-6 text-black">32</td><td class="py-4 pr-6">32</td><td class="py-4 pr-6">38</td><td class="py-4 pr-6">30</td></tr>
            <tr class="border-b border-black/[0.03]"><td class="py-4 pr-6 text-black">34</td><td class="py-4 pr-6">34</td><td class="py-4 pr-6">40</td><td class="py-4 pr-6">30</td></tr>
            <tr class="border-b border-black/[0.03]"><td class="py-4 pr-6 text-black">36</td><td class="py-4 pr-6">36</td><td class="py-4 pr-6">42</td><td class="py-4 pr-6">30</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <p class="text-gray-400 text-[10px] uppercase tracking-widest">
        All measurements are garment dimensions. For a relaxed fit, size up.
      </p>
    </div>
  </div>
</section>