<%# app/views/pages/contact.html.erb %>
<section class="pt-24 pb-20 sm:pt-32 sm:pb-24 px-4 sm:px-8 bg-white min-h-screen">
  <div class="max-w-[1440px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-24">

    <!-- Info -->
    <div>
      <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-4">Get in Touch</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-light uppercase tracking-[0.2em] text-black mb-10">
        Contact
      </h1>

      <div class="space-y-8 text-sm text-gray-600">
        <div>
          <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-1">Email</p>
          <p class="text-black">support@hypee.com</p>
        </div>
        <div>
          <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-1">Phone</p>
          <p class="text-black">+91 98765 43210</p>
        </div>
        <div>
          <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-1">Hours</p>
          <p class="text-black">Mon – Sat, 10:00 – 19:00 IST</p>
        </div>
        <div>
          <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-1">Headquarters</p>
          <p class="text-black leading-relaxed">
            Hypee Studio<br>
            42, MG Road, Bangalore<br>
            Karnataka, India 560001
          </p>
        </div>
      </div>
    </div>

    <!-- Form -->
    <div class="bg-gray-50 p-8 sm:p-12 border border-black/[0.03]">
      <% if flash[:notice] %>
        <div class="mb-6 border border-black/10 bg-white px-4 py-3 text-xs uppercase tracking-widest text-black">
          <%= flash[:notice] %>
        </div>
      <% elsif flash[:alert] %>
        <div class="mb-6 border border-red-200 bg-red-50 px-4 py-3 text-xs uppercase tracking-widest text-red-600">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with model: ContactMessage.new,
                    url: contact_messages_path,
                    method: :post,
                    html: {
                      novalidate: true,
                      class: "space-y-6",
                      data: { controller: "form-validation", action: "submit->form-validation#validateAll" }
                    } do |f| %>

        <div data-field-wrapper>
          <%= f.label :name, "Name", class: "block text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-2" %>
          <%= validated_field f, :name,
                              class: "w-full bg-white border border-black/10 px-4 py-3 text-sm text-black placeholder-gray-300 focus:outline-none focus:border-black/30 transition" %>
        </div>

        <div data-field-wrapper>
          <%= f.label :email, "Email", class: "block text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-2" %>
          <%= validated_field f, :email,
                              as: :email_field,
                              data: { validate_type: "email" },
                              class: "w-full bg-white border border-black/10 px-4 py-3 text-sm text-black placeholder-gray-300 focus:outline-none focus:border-black/30 transition" %>
        </div>

        <div data-field-wrapper>
          <%= f.label :message, "Message", class: "block text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-2" %>
          <%= validated_field f, :message,
                              as: :text_area,
                              rows: 5,
                              class: "w-full bg-white border border-black/10 px-4 py-3 text-sm text-black placeholder-gray-300 focus:outline-none focus:border-black/30 transition resize-none" %>
        </div>

        <%= f.submit "Send Message",
                     class: "w-full bg-black text-white px-8 py-4 text-xs uppercase tracking-[0.2em] hover:bg-gray-800 transition cursor-pointer" %>
      <% end %>
    </div>

  </div>
</section>