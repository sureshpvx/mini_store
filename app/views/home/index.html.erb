<%# app/views/home/index.html.erb %>

<!-- ================= HERO SECTION ================= -->
<section
  class="relative min-h-screen w-full bg-black overflow-hidden"
  data-controller="hero-video"
  data-action="mouseenter->hero-video#play mouseleave->hero-video#pause">

  <!-- Video — no poster, just black background shows until loaded -->
  <video
    data-hero-video-target="video"
    class="absolute inset-0 w-full h-full object-cover transition-opacity duration-700 ease-out"
    style="opacity: 0.35"
    muted
    loop
    playsinline>
    <source src="<%= asset_path('save.mp4') %>" type="video/mp4">
  </video>

  <!-- Gradient -->
  <div class="absolute inset-0 bg-gradient-to-t from-black via-black/80 to-black/30 md:bg-gradient-to-r md:from-black md:via-black/70 md:to-transparent"></div>

  <!-- Content -->
  <div class="relative z-10 flex items-end md:items-center h-full min-h-screen">
    <div class="w-full max-w-7xl mx-auto px-6 sm:px-10 pb-24 md:pb-0 pt-32 md:pt-0">
      <div class="max-w-md md:max-w-xl text-left">

        <p class="text-[10px] uppercase tracking-[0.4em] text-gray-500 mb-6">
          SS / 26 Collection
        </p>

        <h1 class="text-5xl sm:text-6xl lg:text-[7.5rem] font-black uppercase leading-[0.85] mb-8 tracking-tight">
          DEFINE<br>YOUR<br>EDGE
        </h1>

        <p class="text-gray-400 mb-10 text-sm leading-relaxed max-w-sm">
          Uncompromising aesthetics for the modern minimalist.
          Structured silhouettes, premium materials, quiet dominance.
        </p>

        <%= link_to products_path(filter: "all"),
                    class: "inline-flex items-center gap-4 border border-white/20 bg-transparent px-8 py-4 uppercase tracking-[0.25em] text-[11px] text-white hover:bg-white hover:text-black transition-all duration-300" do %>
          Explore Collection
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        <% end %>

      </div>
    </div>
  </div>

</section>

<!-- ================= CATEGORIES ================= -->
<section class="py-16 sm:py-24 px-4 sm:px-10 bg-[#0a0a0a]">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-white/5">

    <% categories = [
      { name: "Men", image: "men.jpg", filter: "men" },
      { name: "Women", image: "women.jpg", filter: "women" },
      { name: "Accessories", image: "acc.jpg", filter: "accessories" }
    ] %>

    <% categories.each do |cat| %>
      <%= link_to products_path(filter: cat[:filter]),
                  class: "relative group overflow-hidden bg-black h-[280px] sm:h-[380px] md:h-[600px] block" do %>

        <%= image_tag cat[:image], loading: "lazy",
                      class: "absolute inset-0 w-full h-full object-cover grayscale opacity-60 group-hover:opacity-90 group-hover:scale-105 transition-all duration-700 ease-out" %>

        <div class="absolute inset-0 bg-black/50 group-hover:bg-black/30 transition duration-500"></div>

        <div class="absolute inset-0 flex items-center justify-center">
          <div class="text-center">
            <h2 class="text-2xl sm:text-3xl uppercase font-bold tracking-[0.2em] text-white mb-2">
              <%= cat[:name] %>
            </h2>
            <span class="inline-block w-8 h-px bg-white/40 group-hover:w-16 group-hover:bg-white transition-all duration-500"></span>
          </div>
        </div>

      <% end %>
    <% end %>

  </div>
</section>

<!-- ================= NEW ARRIVALS ================= -->
<section class="py-16 sm:py-24 px-4 sm:px-10 bg-[#0a0a0a] border-t border-white/[0.03]">

  <div class="max-w-7xl mx-auto">

    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4 mb-12 sm:mb-16">
      <div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-600 mb-3">Latest Drop</p>
        <h2 class="text-3xl sm:text-5xl font-medium uppercase tracking-tight text-white">
          New Arrivals
        </h2>
      </div>

      <%= link_to products_path(filter: "new"), class: "group flex items-center gap-2 text-gray-500 hover:text-white text-[10px] uppercase tracking-[0.3em] transition" do %>
        View All
        <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
      <% @new_arrivals.each do |product| %>
        <%= link_to product_path(product), class: "group flex flex-col" do %>

          <div class="relative aspect-[3/4] bg-[#080808] overflow-hidden mb-4 sm:mb-5 flex items-center justify-center border border-white/[0.04]">
            <% if product.images.attached? %>
              <%= image_tag product.images.first, loading: "lazy",
                            class: "w-full h-full object-contain p-6 sm:p-10 group-hover:scale-105 transition-transform duration-700 ease-out" %>
            <% else %>
              <div class="text-gray-700 uppercase text-[8px] tracking-widest">No Image</div>
            <% end %>
          </div>

          <div class="flex flex-col gap-1.5">
            <div class="flex justify-between items-baseline gap-2">
              <h3 class="uppercase text-[10px] sm:text-[11px] tracking-[0.15em] font-medium text-white group-hover:text-gray-400 transition truncate">
                <%= product.name %>
              </h3>
              <span class="text-[10px] sm:text-[11px] text-gray-400 font-light whitespace-nowrap">
                <%= number_to_currency(product.price, unit: "₹", precision: 0) %>
              </span>
            </div>
            <% if product.description.present? %>
              <p class="hidden sm:block text-[10px] text-gray-600 tracking-wide font-light leading-relaxed">
                <%= product.description.truncate(30) %>
              </p>
            <% end %>
          </div>

        <% end %>
      <% end %>
    </div>

  </div>

</section>

<!-- ================= EDITORIAL BANNER ================= -->
<section class="relative h-[500px] md:h-[600px] flex items-center border-t border-white/[0.03] overflow-hidden">

  <div class="absolute inset-0 w-full md:w-3/5 ml-auto">
    <%= image_tag "girl.jpg", loading: "lazy",
                  class: "w-full h-full object-cover object-[60%_center] md:object-center grayscale opacity-70" %>
  </div>

  <div class="absolute inset-0 bg-gradient-to-t from-black via-black/80 to-transparent md:bg-gradient-to-r md:from-black md:via-black/90 md:to-transparent"></div>

  <div class="relative z-10 px-6 sm:px-10 max-w-xl md:max-w-2xl">
    <p class="text-[10px] uppercase tracking-[0.3em] text-gray-500 mb-4">Editorial</p>
    <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold uppercase mb-6 leading-[0.95] tracking-tight">
      Crafted<br>For The Bold
    </h2>
    <p class="text-gray-400 mb-8 text-sm sm:text-base leading-relaxed max-w-md">
      Reject the superfluous. Embrace the essential. Our latest collection is an exercise in restraint and precision.
    </p>
    <%= link_to "#",
                class: "inline-flex items-center gap-3 bg-white text-black px-7 py-3.5 uppercase text-[11px] tracking-[0.2em] font-medium hover:bg-gray-200 transition duration-300" do %>
      Read the Journal
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
    <% end %>
  </div>

</section>