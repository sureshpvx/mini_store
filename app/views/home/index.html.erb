<section class="relative bg-white border-b border-black/[0.03]">

  <!-- ================= IMMERSIVE HERO (all screen sizes) ================= -->
  <div class="relative min-h-[85vh] lg:min-h-screen overflow-hidden bg-neutral-900">

    <!-- Main background: boyincords.jpg — FACE VISIBLE ON DESKTOP -->
    <%= image_tag "boyincords.jpg",
                  class: "absolute inset-0 w-full h-full object-cover object-top lg:object-[50%_10%]",
                  alt: "" %>

    <!-- Gradient for text readability -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>

    <!-- Floating polaroid: girlinhoodie.jpg -->
    <div class="absolute top-20 right-3 lg:top-24 lg:right-12 w-24 lg:w-40 bg-white p-1.5 lg:p-3 shadow-[0_12px_40px_rgba(0,0,0,0.25)] rotate-3 z-20">
      <%= image_tag "girlinhoodie.jpg",
                    class: "w-full aspect-[3/4] object-cover",
                    alt: "" %>
      <div class="pt-1 pb-0.5 lg:pt-2 lg:pb-1 text-center">
        <span class="text-[7px] lg:text-[9px] uppercase tracking-[0.2em] text-gray-400">SS / 26</span>
      </div>
    </div>

    <!-- Live indicator tag -->
    <div class="absolute top-20 left-3 lg:top-24 lg:left-12 z-10">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/20 px-2 py-1.5 lg:px-4 lg:py-2">
        <div class="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></div>
        <span class="text-[9px] lg:text-[11px] uppercase tracking-[0.3em] text-white">New Arrivals</span>
      </div>
    </div>

    <!-- Text & CTA overlaid at bottom -->
    <div class="absolute bottom-0 left-0 right-0 p-6 pb-24 lg:p-12 lg:pb-16 z-10">
      <p class="text-[10px] lg:text-xs uppercase tracking-[0.5em] text-white/50 mb-3">
        SS / 26 Collection
      </p>

      <h1 class="text-[3.2rem] lg:text-[6rem] xl:text-[7rem] font-black uppercase leading-[0.85] tracking-[-0.04em] text-white mb-5 lg:mb-8">
        DEFINE<br>YOUR<br>EDGE
      </h1>

      <p class="text-white/70 text-sm lg:text-base leading-relaxed mb-8 lg:mb-10 max-w-[280px] lg:max-w-md font-light">
        Structured silhouettes, premium materials, quiet dominance.
      </p>

      <%= link_to products_path,
                  class: "group flex items-center justify-center gap-3
                           bg-white text-black
                           px-8 py-4
                           uppercase text-[11px]
                           tracking-[0.28em]
                           font-medium
                           w-full
                           hover:bg-gray-100
                           transition duration-300" do %>
        <span>Shop Collection</span>
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300"
             fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      <% end %>

      <!-- Micro stats -->
      <div class="flex items-center justify-center lg:justify-start gap-6 mt-6">
        <span class="text-[9px] uppercase tracking-[0.2em] text-white/40">30+ Items</span>
        <div class="w-px h-3 bg-white/20"></div>
        <span class="text-[9px] uppercase tracking-[0.2em] text-white/40">Premium</span>
      </div>
    </div>
  </div>

  <!-- ================= BOTTOM INFO (desktop only) ================= -->
  <div class="hidden lg:flex items-center justify-center gap-20 py-8 border-t border-black/[0.03]">

    <div>
      <p class="text-[9px] uppercase tracking-[0.3em] text-gray-400 mb-3">New Arrivals</p>
      <p class="text-3xl font-light tracking-tight text-black">30+</p>
    </div>

    <div class="w-px h-10 bg-black/[0.08]"></div>

    <div>
      <p class="text-[9px] uppercase tracking-[0.3em] text-gray-400 mb-3">Premium Quality</p>
      <p class="text-3xl font-light tracking-tight text-black">100%</p>
    </div>

    <div class="w-px h-10 bg-black/[0.08]"></div>

    <div>
      <p class="text-[9px] uppercase tracking-[0.3em] text-gray-400 mb-3">Timeless Design</p>
      <p class="text-3xl font-light tracking-tight text-black">SS / 26</p>
    </div>

  </div>

</section>

<!-- ================= CATEGORIES ================= -->
<section class="py-12 sm:py-16 md:py-24 px-4 sm:px-10 bg-white">
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-6 max-w-[1440px] mx-auto">

    <% categories = [
      { name: "Men", image: "men.jpg", filter: "men" },
      { name: "Women", image: "women.jpg", filter: "women" },
      { name: "Accessories", image: "acc.jpg", filter: "accessories" }
    ] %>

    <% categories.each do |cat| %>
      <%= link_to products_path(filter: cat[:filter]),
                  class: "relative group overflow-hidden bg-gray-50 h-[220px] sm:h-[400px] md:h-[500px] lg:h-[600px] block" do %>

        <%= image_tag cat[:image], loading: "lazy",
                      class: "absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" %>

        <div class="absolute inset-0 bg-gradient-to-t from-white/70 via-white/10 to-transparent"></div>

        <div class="absolute bottom-0 left-0 right-0 flex justify-center pb-6 sm:pb-12">
          <div class="text-center">
            <h2 class="text-xs sm:text-sm uppercase tracking-[0.35em] font-light text-black mb-3">
              <%= cat[:name] %>
            </h2>
            <span class="inline-block w-4 h-px bg-black/20 group-hover:w-10 group-hover:bg-black/40 transition-all duration-500"></span>
          </div>
        </div>

      <% end %>
    <% end %>

  </div>
</section>

<!-- ================= NEW ARRIVALS ================= -->
<section class="py-12 sm:py-16 md:py-24 px-4 sm:px-10 bg-white border-t border-black/[0.03]">

  <div class="max-w-[1440px] mx-auto">

    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4 mb-10 sm:mb-16">
      <div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-3">Latest Drop</p>
        <h2 class="text-2xl sm:text-3xl font-light uppercase tracking-[0.2em] text-black">
          New Arrivals
        </h2>
      </div>

      <%= link_to products_path(filter: "new"), class: "group flex items-center gap-2 text-gray-400 hover:text-black text-[10px] uppercase tracking-[0.3em] transition" do %>
        View All
        <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6">
      <% @new_arrivals.each do |product| %>
        <%= link_to product_path(product), class: "group flex flex-col" do %>

          <div class="relative aspect-[3/4] bg-gray-50 overflow-hidden mb-3 sm:mb-5 flex items-center justify-center">
            <% if product.images.attached? %>
              <%= image_tag product.images.first, loading: "lazy",
                            class: "w-full h-full object-contain p-3 sm:p-8 group-hover:scale-105 transition-transform duration-700 ease-out" %>
            <% else %>
              <div class="text-gray-300 uppercase text-[8px] tracking-widest">No Image</div>
            <% end %>
          </div>

          <div class="flex flex-col gap-1">
            <div class="flex justify-between items-baseline gap-2">
              <h3 class="uppercase text-[9px] sm:text-[11px] tracking-[0.2em] font-light text-black group-hover:text-gray-500 transition truncate">
                <%= product.name %>
              </h3>
              <span class="text-[9px] sm:text-[11px] text-gray-400 font-light whitespace-nowrap">
                <%= number_to_currency(product.price, unit: "₹", precision: 0) %>
              </span>
            </div>
          </div>

        <% end %>
      <% end %>
    </div>

  </div>

</section>

<!-- ================= EDITORIAL BANNER ================= -->
<section class="relative h-[400px] sm:h-[500px] md:h-[600px] flex items-center border-t border-black/[0.03] overflow-hidden bg-white">

  <div class="absolute inset-0 w-full md:w-3/5 ml-auto">
    <%= image_tag "girl.jpg", loading: "lazy",
                  class: "w-full h-full object-cover object-[60%_center] md:object-center" %>
  </div>

  <div class="absolute inset-0 bg-gradient-to-t from-white via-white/60 to-transparent md:bg-gradient-to-r md:from-white md:via-white/80 md:to-transparent"></div>

  <div class="relative z-10 px-5 sm:px-10 max-w-xl md:max-w-2xl">
    <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-4">Editorial</p>
    <h2 class="text-2xl sm:text-3xl lg:text-5xl font-light uppercase mb-4 sm:mb-6 leading-[1.1] tracking-[0.1em] text-black">
      Crafted<br>For The Bold
    </h2>
    <p class="text-gray-500 mb-6 sm:mb-8 text-sm leading-relaxed max-w-md font-light">
      Reject the superfluous. Embrace the essential. Our latest collection is an exercise in restraint and precision.
    </p>
    <%= link_to journal_path,
                class: "inline-flex items-center gap-3 border border-black/30 bg-transparent px-6 sm:px-7 py-3 sm:py-3.5 uppercase text-[11px] tracking-[0.2em] font-light text-black hover:bg-black hover:text-white transition duration-300" do %>
      Read the Journal
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
    <% end %>
  </div>

</section>