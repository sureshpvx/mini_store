<div class="min-h-screen bg-white text-black">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-10 pt-24 pb-28 sm:pt-16 sm:pb-24">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-10 items-start">

      <%# ========== UNIFIED MEDIA GALLERY ========== %>
      <div class="space-y-3" data-controller="product-gallery">

        <% all_media = [] %>
        <% @product.images.each do |img| %>
          <% optimized = img.variant(resize_to_limit: [900, 1200]) %>

          <% all_media << {
            type: :image,
            src: url_for(optimized),
            alt: @product.name
          } %>
        <% end %>
        <% if @product.video.attached? %>
          <% all_media << { type: :video, src: url_for(@product.video), content_type: @product.video.content_type, alt: "#{@product.name} video" } %>
        <% end %>

        <% if all_media.any? %>

          <div class="relative aspect-[3/4] sm:aspect-[4/5] overflow-hidden bg-gray-50 group select-none" data-product-gallery-target="viewport">

            <div class="flex h-full transition-transform duration-500 ease-out will-change-transform" data-product-gallery-target="track">
              <% all_media.each_with_index do |media, i| %>
                <div class="w-full h-full flex-shrink-0 relative" data-slide-index="<%= i %>">

                  <% if media[:type] == :image %>
                    <%= image_tag media[:src],
                                  class: "w-full h-full object-cover",
                                  alt: media[:alt],
                                  loading: i == 0 ? "eager" : "lazy",
                                  draggable: "false" %>
                  <% else %>
                    <video class="w-full h-full object-cover cursor-pointer"
                           muted loop playsinline preload="metadata"
                           data-product-gallery-target="video"
                           onclick="this.paused ? this.play() : this.pause(); this.muted = !this.muted;">
                      <source src="<%= media[:src] %>" type="<%= media[:content_type] %>">
                    </video>

                    <div class="absolute inset-0 flex items-center justify-center pointer-events-none transition-opacity duration-300" data-video-overlay>
                      <div class="w-12 h-12 border border-black/20 flex items-center justify-center backdrop-blur-sm bg-white/50">
                        <svg class="w-4 h-4 text-black ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                      </div>
                    </div>
                  <% end %>

                </div>
              <% end %>
            </div>

            <% if all_media.size > 1 %>
              <button type="button"
                      class="absolute left-0 top-0 bottom-0 w-16 sm:w-20 flex items-center justify-start pl-4 sm:pl-6 opacity-0 group-hover:opacity-100 transition-opacity duration-300 focus:opacity-100 outline-none z-10"
                      aria-label="Previous"
                      data-action="click->product-gallery#prev">
                <svg class="w-6 h-6 text-black/40 hover:text-black transition" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
              </button>

              <button type="button"
                      class="absolute right-0 top-0 bottom-0 w-16 sm:w-20 flex items-center justify-end pr-4 sm:pr-6 opacity-0 group-hover:opacity-100 transition-opacity duration-300 focus:opacity-100 outline-none z-10"
                      aria-label="Next"
                      data-action="click->product-gallery#next">
                <svg class="w-6 h-6 text-black/40 hover:text-black transition" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
              </button>
            <% end %>

            <% if all_media.size > 1 %>
              <div class="absolute top-4 right-4 text-[10px] uppercase tracking-[0.2em] text-black/50 bg-white/80 backdrop-blur-sm border border-black/10 px-2.5 py-1 z-10">
                <span data-product-gallery-target="current">1</span> / <%= all_media.size %>
              </div>
            <% end %>

            <% if all_media.any? { |m| m[:type] == :video } %>
              <div class="absolute top-4 left-4 text-[9px] uppercase tracking-[0.2em] text-black/60 bg-white/80 backdrop-blur-sm border border-black/10 px-2.5 py-1 z-10 hidden" data-product-gallery-target="videoBadge">
                Video
              </div>
            <% end %>

          </div>

          <% if all_media.size > 1 %>
            <div class="flex gap-2 overflow-x-auto pb-1 scrollbar-hide select-none" data-product-gallery-target="thumbs">
              <% all_media.each_with_index do |media, i| %>
                <button type="button"
                        class="flex-shrink-0 w-14 h-14 sm:w-16 sm:h-16 border transition-colors relative outline-none <%= i == 0 ? 'border-black/40' : 'border-black/10 hover:border-black/30' %>"
                        data-action="click->product-gallery#goTo"
                        data-index="<%= i %>"
                        aria-label="View <%= media[:type] %> <%= i + 1 %>">

                  <% if media[:type] == :image %>
                    <%= image_tag media[:src], class: "w-full h-full object-cover", alt: "", draggable: "false" %>
                  <% else %>
                    <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                      <svg class="w-5 h-5 text-black/40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                    </div>
                  <% end %>

                  <div class="absolute bottom-0 left-0 right-0 h-[2px] bg-black transition-opacity <%= i == 0 ? 'opacity-100' : 'opacity-0' %>" data-thumb-indicator></div>
                </button>
              <% end %>
            </div>
          <% end %>

        <% else %>
          <div class="aspect-[3/4] sm:aspect-[4/5] bg-gray-50 flex items-center justify-center border border-black/[0.04]">
            <span class="text-[10px] uppercase tracking-[0.3em] text-gray-400">No Image</span>
          </div>
        <% end %>

      </div>

      <%# ========== PRODUCT INFO ========== %>
      <div class="lg:pt-2 space-y-6">

        <%# Category + Stock %>
        <div class="flex items-center justify-between">
          <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400">
            <%= @product.category&.name || "Hypee" %>
          </p>
          <% stock = @product.stock.to_i %>
          <% if stock <= 5 && stock > 0 %>
            <span class="text-[9px] uppercase tracking-[0.15em] text-orange-500">Only <%= stock %> left</span>
          <% elsif stock == 0 %>
            <span class="text-[9px] uppercase tracking-[0.15em] text-red-500">Sold Out</span>
          <% else %>
            <span class="text-[9px] uppercase tracking-[0.15em] text-emerald-600">In stock</span>
          <% end %>
        </div>

        <%# Name + Price %>
        <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 sm:gap-4">
          <h1 class="text-2xl sm:text-3xl lg:text-4xl font-light uppercase tracking-[0.1em] leading-none text-black">
            <%= @product.name %>
          </h1>
          <span class="text-xl sm:text-2xl font-light tracking-wide text-black">
            <%= number_to_currency(@product.price, unit: "₹", precision: 0) %>
          </span>
        </div>

        <p class="text-[10px] text-gray-400 tracking-wide">(Inclusive of All Taxes)</p>
        <p class="text-[10px] text-gray-400 tracking-wide">
          <%= @product.views_count %> <%= @product.views_count == 1 ? 'view' : 'views' %>
        </p>

        <%# Description — always open %>
        <% if @product.description.present? %>
          <div class="border-b border-black/[0.06] pb-4">
            <p class="text-[11px] uppercase tracking-[0.2em] text-gray-400 mb-3">Description</p>
            <p class="text-xs text-gray-500 leading-relaxed font-light">
              <%= @product.description %>
            </p>
          </div>
        <% end %>

        <%# Delivery & Return accordion %>
        <div class="space-y-0" data-controller="accordion">
          <div class="border-b border-black/[0.06]" data-accordion-item>
            <button type="button" class="w-full flex items-center justify-between py-3 text-left group" data-action="click->accordion#toggle">
              <span class="text-[11px] uppercase tracking-[0.2em] text-gray-400 group-hover:text-black transition">Delivery & Return</span>
              <svg class="w-3 h-3 text-gray-400 transition-transform duration-300" data-accordion-icon fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="hidden pb-4" data-accordion-panel>
              <div class="space-y-2 text-xs text-gray-500 leading-relaxed font-light">
                <p>Free standard delivery on orders above ₹5000. Estimated delivery 3–5 business days.</p>
                <p>Returns accepted within 7 days of delivery. Product must be unused with original tags attached.</p>
              </div>
            </div>
          </div>
        </div>

        <%# ========== FORM: Quantity + Buy Now + Add to Cart ========== %>
        <% if stock > 0 %>
          <%= form_with url: add_item_cart_path(product_id: @product.id),
                        method: :post,
                        data: { turbo: true },
                        class: "space-y-4" do |f| %>

            <div class="flex flex-col sm:flex-row items-stretch gap-3">
              <div class="flex items-stretch gap-3">
                <%# Stepper %>
                <div class="flex items-center border border-black/20" data-controller="quantity">
                  <button type="button"
                          class="w-10 h-12 flex items-center justify-center text-gray-400 hover:text-black transition select-none"
                          data-action="click->quantity#decrement">−</button>
                  <input type="number"
                         name="quantity"
                         value="1"
                         min="1"
                         max="<%= stock %>"
                         class="w-10 h-12 bg-transparent text-center text-sm text-black outline-none border-x border-black/10"
                         data-quantity-target="input"
                         readonly>
                  <button type="button"
                          class="w-10 h-12 flex items-center justify-center text-gray-400 hover:text-black transition select-none"
                          data-action="click->quantity#increment">+</button>
                </div>
              </div>

              <div class="flex flex-1 gap-3">
                <%# Buy Now — solid black, primary %>
                <%= button_tag "Buy Now",
                               type: :submit,
                               formaction: buy_now_cart_path(product_id: @product.id),
                               class: "flex-1 h-12 bg-black text-white uppercase tracking-[0.2em] text-[11px] font-medium hover:bg-gray-800 transition active:scale-[0.98]" %>

                <%# Add to Cart — outline, secondary %>
                <%= button_tag "Add to Cart",
                               type: :submit,
                               class: "flex-1 h-12 border border-black/30 text-black uppercase tracking-[0.2em] text-[11px] font-medium hover:bg-black hover:text-white transition active:scale-[0.98]" %>
              </div>
            </div>

          <% end %>
        <% else %>
          <button disabled class="w-full h-12 border border-black/10 text-gray-400 uppercase tracking-[0.25em] text-[11px] cursor-not-allowed">
            Sold Out
          </button>
        <% end %>

        <p class="text-[9px] uppercase tracking-[0.15em] text-gray-400 text-center">
          Free shipping over ₹5000
        </p>

        <%# Meta footer %>
        <div class="space-y-1 pt-1">
          <p class="text-[10px] text-gray-400">Country of Origin: India</p>
          <p class="text-[10px] text-gray-400 leading-relaxed">
            Marketed and distributed by:<br>
            Hypee Lifestyle Private Limited
          </p>
        </div>

      </div>
    </div>

  </div>
</div>