<%# app/views/products/index.html.erb %>

<div class="max-w-[1440px] mx-auto px-4 sm:px-10 pt-24 pb-28 sm:pt-16 sm:pb-24 bg-white">

  <!-- HEADER: Centered -->
  <div class="mb-12 sm:mb-20 text-center">

    <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-3">
      Collection
    </p>

    <h1 class="text-2xl sm:text-3xl font-light uppercase tracking-[0.1em] text-black">
      <%= params[:filter]&.titleize || "All Products" %>
    </h1>

    <div class="flex flex-col sm:flex-row justify-center items-center gap-5 mt-5">

      <p class="text-gray-400 text-[11px] uppercase tracking-[0.2em] leading-relaxed max-w-md font-light">
        Curated pieces for modern minimal style. Engineered for the contemporary silhouette.
      </p>

    </div>

    <span class="block mt-4 text-[10px] text-gray-400 uppercase tracking-[0.25em] font-light">
      Showing
      <span class="text-black">
        <%= @product_count %>
      </span>
      items
    </span>

  </div>

  <% if @products.any? %>

    <!-- 2 cols on mobile, 3 on desktop -->
    <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-6">

      <% @products.each do |product| %>

        <%= link_to product_path(product),
                    class: "group flex flex-col" do %>

          <!-- PRODUCT IMAGE -->
          <div class="relative aspect-[3/4] bg-gray-50 overflow-hidden mb-4 sm:mb-5 flex items-center justify-center border border-black/[0.04]">

            <% if product.images.attached? %>

              <%= image_tag(
                    cloudinary_url(
                      product.images.first.key,
                      width: 500,
                      height: 600,
                      crop: :limit,
                      quality: "auto",
                      fetch_format: "auto"
                    ),
                    loading: "lazy",
                    decoding: "async",
                    width: 500,
                    height: 600,
                    class: "w-full h-full object-contain p-4 sm:p-10 group-hover:scale-105 transition-transform duration-700 ease-out"
                  ) %>

            <% else %>

              <div class="text-gray-400 uppercase text-[10px] tracking-[0.3em]">
                No Image
              </div>

            <% end %>

          </div>

          <!-- PRODUCT INFO -->
          <div class="flex flex-col gap-1.5">

            <div class="flex justify-between items-baseline gap-2">

              <h3 class="uppercase text-[10px] sm:text-[11px] tracking-[0.15em] font-medium text-black group-hover:text-gray-600 transition truncate">
                <%= product.name %>
              </h3>

              <span class="text-[10px] sm:text-[11px] text-gray-500 font-light whitespace-nowrap">
                <%= number_to_currency(product.price, unit: "₹", precision: 0) %>
              </span>

            </div>

            <% if product.description.present? %>

              <p class="hidden sm:block text-[10px] text-gray-500 tracking-wide font-light leading-relaxed">
                <%= product.description.truncate(30) %>
              </p>

            <% end %>

          </div>

        <% end %>

      <% end %>

    </div>

    <!-- PAGINATION -->
    <% if @pagy&.pages.to_i > 1 %>
      <div class="mt-16 flex items-center justify-center gap-2">
        <% if @pagy.prev %>
          <%= link_to pagy_url_for(@pagy, @pagy.prev), class: "w-11 h-11 flex items-center justify-center border border-black/[0.06] text-gray-400 hover:text-black hover:border-black/20 transition-all duration-300" do %>←<% end %>
        <% end %>
        <% @pagy.series.each do |item| %>
          <% if item.is_a?(Integer) %>
            <%= link_to item, pagy_url_for(@pagy, item), class: "w-11 h-11 flex items-center justify-center border border-black/[0.06] text-gray-400 hover:text-black hover:border-black/20 text-[11px] tracking-[0.2em] transition-all duration-300" %>
          <% elsif item.is_a?(String) %>
            <div class="w-11 h-11 flex items-center justify-center bg-black text-white text-[11px] tracking-[0.2em] font-medium"><%= item %></div>
          <% elsif item == :gap %>
            <div class="w-11 text-center text-gray-400">...</div>
          <% end %>
        <% end %>
        <% if @pagy.next %>
          <%= link_to pagy_url_for(@pagy, @pagy.next), class: "w-11 h-11 flex items-center justify-center border border-black/[0.06] text-gray-400 hover:text-black hover:border-black/20 transition-all duration-300" do %>→<% end %>
        <% end %>
      </div>
    <% end %>

  <% else %>

    <div class="flex flex-col items-center justify-center py-32 border border-dashed border-black/[0.06]">

      <p class="text-gray-400 text-xs uppercase tracking-[0.35em] mb-6 font-light">
        The archive is currently empty
      </p>

      <%= link_to "Return to Shop",
                  root_path,
                  class: "text-[11px] text-black border border-black/30 px-8 py-3 uppercase tracking-[0.2em] transition-all duration-300 hover:bg-black hover:text-white" %>

    </div>

  <% end %>

</div>