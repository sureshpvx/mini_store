<!-- app/views/orders/index.html.erb -->

<div class="min-h-screen bg-white pb-16 md:pb-0">

  <!-- HEADER -->
  <div class="max-w-[1440px] mx-auto px-4 sm:px-10 pt-24 pb-16">

    <p class="text-[10px] uppercase tracking-[0.4em] text-gray-400 mb-4">Account</p>

    <h1 class="text-3xl sm:text-4xl font-light uppercase tracking-[0.15em] text-black mb-4">
      My Orders
    </h1>

    <p class="text-gray-400 text-sm font-light leading-relaxed max-w-md">
      Track your purchases and revisit previous orders.
    </p>

  </div>

  <!-- ORDERS LIST -->
  <div class="max-w-[1440px] mx-auto px-4 sm:px-10 pb-24">

    <% if @orders.any? %>

      <div class="space-y-6">

        <% @orders.each do |order| %>

          <div class="border border-black/[0.06]">

            <!-- TOP META -->
            <div class="border-b border-black/[0.06] px-6 sm:px-8 py-6 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">

              <div class="flex flex-wrap gap-8 sm:gap-10">

                <div>
                  <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-2">Order</p>
                  <p class="text-black font-light text-sm tracking-wide">#HYPEE-<%= order.id.to_s.rjust(4, "0") %></p>
                </div>

                <div>
                  <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-2">Placed</p>
                  <p class="text-gray-500 font-light text-sm"><%= order.created_at.strftime("%d %b %Y") %></p>
                </div>

                <div>
                  <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-2">Items</p>
                  <p class="text-gray-500 font-light text-sm"><%= order.order_items.sum(:quantity) %></p>
                </div>

                <div class="flex gap-8 sm:gap-10">

                  <div>
                    <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-2">Delivery</p>
                    <p class="text-black font-light text-sm capitalize"><%= order.status.humanize %></p>
                  </div>

                  <div>
                    <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-2">Payment</p>
                    <p class="text-black font-light text-sm capitalize"><%= order.payment_status.humanize %></p>
                  </div>

                </div>

              </div>

              <div class="text-left lg:text-right">
                <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-2">Total</p>
                <p class="text-2xl text-black font-light">₹<%= order.total_price.to_f.round(2) %></p>
              </div>

            </div>

            <!-- PRODUCTS -->
            <div class="p-6 sm:p-8">

              <div class="space-y-5">

                <% order.order_items.limit(3).each do |item| %>

                  <div class="flex items-center justify-between gap-5">

                    <div class="flex items-center gap-5">

                      <div class="w-16 h-20 bg-gray-50 flex-shrink-0 overflow-hidden">

                        <% if item.product.images.attached? %>

                          <%= image_tag item.product.images.first,
                                        class: "w-full h-full object-cover" %>

                        <% end %>

                      </div>

                      <div>

                        <h3 class="text-black uppercase tracking-[0.15em] text-[11px] font-medium">
                          <%= item.product.name %>
                        </h3>

                        <p class="text-gray-400 text-[11px] font-light mt-2">
                          Qty <span class="text-black ml-1"><%= item.quantity %></span>
                        </p>

                      </div>

                    </div>

                    <div>

                      <p class="text-black font-light text-sm">₹<%= item.total_price.to_f.round(2) %></p>

                    </div>

                  </div>

                <% end %>

              </div>

              <!-- MORE ITEMS -->
              <% if order.order_items.count > 3 %>

                <div class="mt-6 pt-4 border-t border-black/[0.06]">

                  <p class="text-gray-400 text-[11px] uppercase tracking-[0.2em]">
                    + <%= order.order_items.count - 3 %> more items
                  </p>

                </div>

              <% end %>

              <!-- ACTION -->
              <div class="mt-8">

                <%= link_to order_path(order),
                            class: "inline-flex items-center justify-center h-12 px-8 border border-black/20 uppercase tracking-[0.25em] text-[11px] text-black hover:bg-black hover:text-white transition-all duration-300" do %>

                  View Full Order

                <% end %>

              </div>

            </div>

          </div>

        <% end %>

      </div>

    <% else %>

      <!-- EMPTY STATE -->
      <div class="border border-black/[0.06] p-16 sm:p-24 text-center">

        <p class="text-[10px] uppercase tracking-[0.4em] text-gray-400 mb-6">No Orders Yet</p>

        <h2 class="text-2xl sm:text-3xl text-black font-light uppercase tracking-[0.1em] mb-5">
          Your collection journey starts here.
        </h2>

        <p class="text-gray-400 text-sm font-light max-w-xl mx-auto leading-relaxed">
          Explore premium fashion pieces and place your first order.
        </p>

        <div class="mt-10">

          <%= link_to products_path,
                      class: "inline-flex items-center justify-center h-14 px-10 bg-black text-white uppercase tracking-[0.25em] text-[11px] hover:bg-gray-800 transition-all duration-300" do %>

            Explore Collection

          <% end %>

        </div>

      </div>

    <% end %>

  </div>

</div>