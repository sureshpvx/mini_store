<div class="max-w-6xl mx-auto px-6 py-16">

  <!-- HEADER -->
  <div class="mb-14">

    <p class="text-xs uppercase tracking-[0.45em] text-gray-500 mb-4">
      Account
    </p>

    <h1 class="text-5xl font-semibold text-white">
      My Orders
    </h1>

    <p class="text-gray-500 mt-5 text-lg">
      Track your purchases and revisit previous orders.
    </p>

  </div>

  <% if @orders.any? %>

    <div class="space-y-8">

      <% @orders.each do |order| %>

        <div class="border border-white/10
                    bg-[#070707]
                    rounded-[32px]
                    overflow-hidden">

          <!-- TOP -->
          <div class="border-b border-white/10
                      px-8 py-6
                      flex flex-col lg:flex-row
                      lg:items-center
                      lg:justify-between
                      gap-6">

            <!-- LEFT -->
            <div class="flex flex-wrap gap-8">

              <div>
                <p class="text-xs uppercase tracking-[0.35em] text-gray-500 mb-2">
                  Order
                </p>

                <p class="text-white text-lg font-medium">
                  #HYPEE-<%= order.id.to_s.rjust(4, "0") %>
                </p>
              </div>

              <div>
                <p class="text-xs uppercase tracking-[0.35em] text-gray-500 mb-2">
                  Placed
                </p>

                <p class="text-gray-300">
                  <%= order.created_at.strftime("%d %b %Y") %>
                </p>
              </div>

              <div>
                <p class="text-xs uppercase tracking-[0.35em] text-gray-500 mb-2">
                  Items
                </p>

                <p class="text-gray-300">
                  <%= order.order_items.sum(:quantity) %>
                </p>
              </div>

              <div class="flex gap-8">

                <!-- DELIVERY STATUS -->
                <div>

                  <p class="text-xs uppercase tracking-[0.35em] text-gray-500 mb-2">
                    Delivery
                  </p>

                  <p class="
      capitalize
      font-medium

      <%=
                    case order.status
                    when 'pending'
                      'text-yellow-400'
                    when 'processing'
                      'text-blue-400'
                    when 'shipped'
                      'text-purple-400'
                    when 'delivered'
                      'text-green-400'
                    when 'cancelled'
                      'text-red-400'
                    end
                  %>
    ">
                    <%= order.status.humanize %>
                  </p>

                </div>

                <!-- PAYMENT STATUS -->
                <div>

                  <p class="text-xs uppercase tracking-[0.35em] text-gray-500 mb-2">
                    Payment
                  </p>

                  <p class="
      capitalize
      font-medium

      <%=
                    case order.payment_status
                    when 'paid'
                      'text-green-400'
                    when 'unpaid'
                      'text-yellow-400'
                    when 'failed'
                      'text-red-400'
                    when 'refunded'
                      'text-gray-400'
                    end
                  %>
    ">
                    <%= order.payment_status.humanize %>
                  </p>

                </div>

              </div>

            </div>

            <!-- RIGHT -->
            <div class="text-left lg:text-right">

              <p class="text-xs uppercase tracking-[0.35em] text-gray-500 mb-2">
                Total
              </p>

              <p class="text-3xl text-white font-light">
                ₹ <%= order.total_price.to_f.round(2) %>
              </p>

            </div>

          </div>

          <!-- PRODUCTS -->
          <div class="p-8">

            <div class="space-y-5">

              <% order.order_items.limit(3).each do |item| %>

                <div class="flex items-center justify-between gap-5">

                  <!-- LEFT -->
                  <div class="flex items-center gap-5">

                    <!-- IMAGE -->
                    <div class="w-20 h-24 rounded-2xl overflow-hidden bg-black">

                      <% if item.product.images.attached? %>

                        <%= image_tag item.product.images.first,
                                      class: "w-full h-full object-cover" %>

                      <% end %>

                    </div>

                    <!-- INFO -->
                    <div>

                      <h3 class="text-white uppercase tracking-wide">
                        <%= item.product.name %>
                      </h3>

                      <p class="text-gray-500 mt-2 text-sm">
                        Quantity:
                        <span class="text-gray-300">
                          <%= item.quantity %>
                        </span>
                      </p>

                    </div>

                  </div>

                  <!-- RIGHT -->
                  <div>

                    <p class="text-white text-lg">
                      ₹ <%= item.total_price.to_f.round(2) %>
                    </p>

                  </div>

                </div>

              <% end %>

            </div>

            <!-- MORE ITEMS -->
            <% if order.order_items.count > 3 %>

              <div class="mt-6">

                <p class="text-gray-500 text-sm">
                  + <%= order.order_items.count - 3 %> more items
                </p>

              </div>

            <% end %>

            <!-- ACTION -->
            <div class="mt-8">

              <%= link_to "View Full Order",
                          order_path(order),
                          class: "inline-flex items-center justify-center
                                 h-14 px-8
                                 border border-white/15
                                 rounded-full
                                 uppercase tracking-[0.35em]
                                 text-xs text-white
                                 hover:bg-white hover:text-black
                                 transition-all duration-500" %>

            </div>

          </div>

        </div>

      <% end %>

    </div>

  <% else %>

    <!-- EMPTY STATE -->
    <div class="border border-white/10
                rounded-[32px]
                p-16
                text-center
                bg-[#070707]">

      <p class="text-xs uppercase tracking-[0.45em] text-gray-500 mb-6">
        No Orders Yet
      </p>

      <h2 class="text-4xl text-white font-light mb-5">
        Your collection journey starts here.
      </h2>

      <p class="text-gray-500 max-w-xl mx-auto leading-relaxed">
        Explore premium fashion pieces and place your first order.
      </p>

      <div class="mt-10">

        <%= link_to "Explore Collection",
                    products_path,
                    class: "inline-flex items-center justify-center
                           h-16 px-10
                           rounded-full
                           bg-white text-black
                           uppercase tracking-[0.35em]
                           text-sm
                           hover:opacity-90
                           transition-all duration-500" %>

      </div>

    </div>

  <% end %>

</div>