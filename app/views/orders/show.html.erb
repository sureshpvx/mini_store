<div class="max-w-[1440px] mx-auto px-4 sm:px-10 pt-24 pb-28 sm:pt-16 sm:pb-24 bg-white">

  <!-- HEADER -->
  <div class="mb-14 text-center">

    <div class="flex items-center justify-center gap-4 mb-4">

      <div class="w-10 h-10 border border-black/[0.06] bg-gray-50 flex items-center justify-center">

        <span class="text-black text-lg font-light">
          ✓
        </span>

      </div>

    </div>

    <h1 class="text-2xl sm:text-3xl font-light uppercase tracking-[0.1em] text-black">
      Order Confirmed
    </h1>

    <p class="text-gray-400 mt-3 text-sm font-light">
      Your order has been placed successfully.
    </p>

    <div class="flex flex-wrap justify-center gap-3 mt-8">

      <!-- ORDER ID -->
      <div class="border border-black/[0.06] bg-white px-5 py-3">

        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-2">
          Order ID
        </p>

        <p class="text-black font-light text-sm">
          #HYPEE-<%= @order.id.to_s.rjust(4, "0") %>
        </p>

      </div>

      <!-- STATUS -->
      <div class="border border-black/[0.06] bg-white px-5 py-3">

        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-2">
          Status
        </p>

        <p class="text-orange-500 font-light text-sm capitalize">
          <%= @order.status %>
        </p>

      </div>

      <!-- PAYMENT -->
      <div class="border border-black/[0.06] bg-white px-5 py-3">

        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-2">
          Payment
        </p>

        <p class="text-red-500 font-light text-sm capitalize">
          <%= @order.payment_status %>
        </p>

      </div>

    </div>

  </div>

  <!-- GRID -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- LEFT -->
    <div class="lg:col-span-2 space-y-6">

      <!-- SHIPPING -->
      <div class="border border-black/[0.06] bg-white p-6 sm:p-8">

        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-6">
          Shipping Details
        </p>

        <div class="space-y-4">

          <h2 class="text-lg sm:text-xl text-black font-light tracking-wide">
            <%= @order.shipping_full_name %>
          </h2>

          <p class="text-gray-400 text-sm font-light">
            <%= @order.shipping_phone_number %>
          </p>

          <div class="space-y-1 text-gray-500 text-sm leading-relaxed font-light">

            <p>
              <%= @order.shipping_address_line_1 %>
            </p>

            <% if @order.shipping_address_line_2.present? %>

              <p>
                <%= @order.shipping_address_line_2 %>
              </p>

            <% end %>

            <p>
              <%= @order.shipping_city %>,
              <%= @order.shipping_state %>
            </p>

            <p>
              <%= @order.shipping_postal_code %>
            </p>

            <p>
              <%= @order.shipping_country %>
            </p>

          </div>

        </div>

      </div>

      <!-- ORDER ITEMS -->
      <% @order.order_items.each do |item| %>

        <div class="border border-black/[0.06] bg-white p-6 flex flex-col md:flex-row gap-6 items-start md:items-center justify-between">

          <!-- LEFT -->
          <div class="flex gap-5 items-start">

            <!-- IMAGE -->
            <div class="w-24 h-28 overflow-hidden bg-gray-50 flex-shrink-0">

              <% if item.product.images.attached? %>

                <%= image_tag item.product.images.first,
                              class: "w-full h-full object-cover" %>

              <% end %>

            </div>

            <!-- INFO -->
            <div>

              <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-2">
                Product
              </p>

              <h2 class="text-base sm:text-lg text-black font-light uppercase tracking-[0.15em]">
                <%= item.product.name %>
              </h2>

              <div class="mt-4 space-y-1">

                <p class="text-gray-400 text-sm font-light">
                  Quantity:
                  <span class="text-black">
                    <%= item.quantity %>
                  </span>
                </p>

                <p class="text-gray-400 text-sm font-light">
                  Unit Price:
                  <span class="text-black">
                    ₹ <%= item.price.to_f.round(2) %>
                  </span>
                </p>

              </div>

            </div>

          </div>

          <!-- RIGHT -->
          <div class="text-right">

            <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-2">
              Subtotal
            </p>

            <p class="text-2xl text-black font-light">
              ₹ <%= item.total_price.to_f.round(2) %>
            </p>

          </div>

        </div>

      <% end %>

    </div>

    <!-- RIGHT SUMMARY -->
    <div>

      <div class="border border-black/[0.06] bg-white p-6 sm:p-8 sticky top-24">

        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-6">
          Order Summary
        </p>

        <div class="space-y-4">

          <div class="flex justify-between text-gray-400 text-sm">

            <span class="font-light">
              Subtotal
            </span>

            <span class="text-black font-light">
              ₹ <%= @order.total_price.to_f.round(2) %>
            </span>

          </div>

          <div class="flex justify-between text-gray-400 text-sm">

            <span class="font-light">
              Shipping
            </span>

            <span class="text-black font-light">
              Free
            </span>

          </div>

          <div class="border-t border-black/[0.06] pt-4 flex justify-between items-center">

            <span class="text-sm uppercase tracking-[0.2em] text-black font-light">
              Total
            </span>

            <span class="text-3xl text-black font-light">
              ₹ <%= @order.total_price.to_f.round(2) %>
            </span>

          </div>

        </div>

        <!-- ACTIONS -->
        <div class="mt-8 space-y-3">

          <%= link_to "View Orders",
                      orders_path,
                      class: "w-full h-14 border border-black/30 flex items-center justify-center uppercase tracking-[0.2em] text-[11px] text-black hover:bg-black hover:text-white transition-all duration-300" %>

          <%= link_to "Continue Shopping",
                      products_path,
                      class: "w-full h-14 bg-black text-white flex items-center justify-center uppercase tracking-[0.2em] text-[11px] hover:bg-gray-800 transition-all duration-300" %>

        </div>

      </div>

    </div>

  </div>

</div>