<div
  data-cart-target="drawer"
  id="cart-drawer"
  class="fixed inset-0 z-50 hidden">

  <!-- OVERLAY -->
  <div
    data-action="click->cart#close"
    class="absolute inset-0 bg-black/80 backdrop-blur-md transition-opacity duration-300">
  </div>

  <!-- DRAWER -->
  <div
    class="absolute right-0 top-0 h-full w-full md:w-[500px]
           bg-[#050505]/95 backdrop-blur-xl
           border-l border-white/10
           shadow-[0_0_60px_rgba(0,0,0,0.8)]
           flex flex-col">

    <!-- HEADER -->
    <div
      class="sticky top-0 z-20
             bg-[#050505]/95 backdrop-blur-xl
             border-b border-white/10
             px-8 py-7">

      <div class="flex items-start justify-between">

        <div>
          <h2 class="text-[15px] uppercase tracking-[0.45em] text-white">
            Cart
          </h2>

          <p class="text-sm text-gray-500 mt-3">
            Your selected pieces
          </p>
        </div>

        <button
          data-action="click->cart#close"
          class="w-11 h-11
                 border border-white/10
                 flex items-center justify-center
                 text-gray-400 hover:text-white
                 hover:border-white/30
                 transition duration-300
                 rounded-full">

          ✕

        </button>

      </div>

    </div>

    <!-- BODY -->
    <div
      class="flex-1 overflow-y-auto px-6 md:px-8 py-8 space-y-6
             [&::-webkit-scrollbar]:w-1
             [&::-webkit-scrollbar-track]:bg-transparent
             [&::-webkit-scrollbar-thumb]:bg-white/10">

      <% if current_cart.cart_items.any? %>

        <% current_cart.cart_items.each do |item| %>

          <div
            class="group relative overflow-hidden
                   border border-white/10
                   bg-gradient-to-b from-[#111111] to-[#090909]
                   hover:border-white/20
                   transition-all duration-500
                   rounded-2xl
                   p-5 flex gap-5">

            <!-- GLOW -->
            <div
              class="absolute inset-0 opacity-0
                     group-hover:opacity-100
                     transition duration-700
                     bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.05),transparent_60%)]">
            </div>

            <!-- IMAGE -->
            <div
              class="relative w-[115px] h-[150px]
                     overflow-hidden rounded-xl
                     bg-black flex-shrink-0">

              <% if item.product.images.attached? %>

                <%= image_tag item.product.images.first,
                              class: "w-full h-full object-cover
                            group-hover:scale-110
                            transition duration-700 ease-out" %>

              <% else %>

                <div
                  class="w-full h-full flex items-center justify-center
                         text-gray-700 text-xs bg-[#0F0F0F]">
                  NO IMAGE
                </div>

              <% end %>

              <!-- IMAGE OVERLAY -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-60">
              </div>

            </div>

            <!-- INFO -->
            <div class="relative flex-1 flex flex-col justify-between min-w-0">

              <div>

                <!-- CATEGORY -->
                <p
                  class="text-[10px]
                         uppercase tracking-[0.35em]
                         text-gray-600 mb-3">

                  <%= item.product.category&.name %>

                </p>

                <!-- PRODUCT NAME -->
                <h3
                  class="text-[15px]
                         leading-relaxed
                         tracking-[0.08em]
                         text-white uppercase">

                  <%= item.product.name %>

                </h3>

              </div>

              <!-- BOTTOM -->
              <div class="mt-7">

                <!-- PRICE -->
                <div class="flex items-end justify-between">

                  <p class="text-xl text-white font-light tracking-wide">
                    ₹ <%= item.total_price.to_f.round(2) %>
                  </p>

                  <button
                    class="text-[10px]
                           uppercase tracking-[0.3em]
                           text-gray-600 hover:text-white
                           transition">

                    Remove

                  </button>

                </div>

                <!-- QUANTITY -->
                <div
                  class="mt-5 inline-flex items-center
                         rounded-full
                         border border-white/10
                         bg-black/80 overflow-hidden">

                  <button
                    class="w-11 h-11 flex items-center justify-center
                           text-gray-500 hover:text-white
                           hover:bg-white/5 transition text-lg">

                    −

                  </button>

                  <div
                    class="w-12 h-11 flex items-center justify-center
                           text-sm text-white
                           border-x border-white/10">

                    <%= item.quantity %>

                  </div>

                  <button
                    class="w-11 h-11 flex items-center justify-center
                           text-gray-500 hover:text-white
                           hover:bg-white/5 transition text-lg">

                    +

                  </button>

                </div>

              </div>

            </div>

          </div>

        <% end %>

      <% else %>

        <!-- EMPTY STATE -->
        <div
          class="h-full flex flex-col
                 items-center justify-center
                 text-center px-10 py-20">

          <div
            class="w-24 h-24 rounded-full
                   border border-white/10
                   flex items-center justify-center
                   mb-8">

            <svg xmlns="http://www.w3.org/2000/svg"
                 class="w-10 h-10 text-gray-700"
                 fill="none"
                 viewBox="0 0 24 24"
                 stroke="currentColor"
                 stroke-width="1.5">

              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.5 6h11M10 21a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z" />

            </svg>

          </div>

          <h3
            class="text-lg uppercase
                   tracking-[0.3em]
                   text-white">

            Your cart is empty

          </h3>

          <p
            class="text-sm text-gray-500
                   mt-4 leading-relaxed">

            Curate your wardrobe with premium essentials.

          </p>

          <%= link_to "Explore Collection",
                      products_path,
                      class: "mt-8 border border-white
                              px-8 py-4
                              text-xs uppercase tracking-[0.3em]
                              hover:bg-white hover:text-black
                              transition-all duration-300 rounded-full" %>

        </div>

      <% end %>

    </div>

    <!-- FOOTER -->
    <div
      class="border-t border-white/10
             bg-[#050505]/95 backdrop-blur-xl
             p-8 space-y-6">

      <!-- TOTALS -->
      <div class="space-y-4">

        <div class="flex items-center justify-between">

          <p
            class="text-xs uppercase
                   tracking-[0.3em]
                   text-gray-500">

            Subtotal

          </p>

          <p class="text-white text-2xl font-light tracking-wide">
            ₹ <%= current_cart.total_price.to_f.round(2) %>
          </p>

        </div>

        <div class="flex items-center justify-between">

          <p
            class="text-xs uppercase
                   tracking-[0.3em]
                   text-gray-500">

            Shipping

          </p>

          <p class="text-gray-400 text-sm">
            Calculated at next step
          </p>

        </div>

      </div>

      <!-- CHECKOUT -->
      <button
        class="w-full h-16
               border border-white
               uppercase tracking-[0.45em]
               text-sm
               rounded-full
               hover:bg-white hover:text-black
               hover:shadow-[0_0_30px_rgba(255,255,255,0.15)]
               transition-all duration-500">

        Checkout

      </button>

      <!-- FOOT NOTE -->
      <p
        class="text-center text-[10px]
               uppercase tracking-[0.25em]
               text-gray-700 pt-1">

        Complimentary shipping on premium orders

      </p>

    </div>

  </div>

</div>