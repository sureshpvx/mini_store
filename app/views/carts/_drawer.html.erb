<div
  data-cart-target="drawer"
  id="cart-drawer"
  class="fixed inset-0 z-50 hidden">

  <!-- OVERLAY -->
  <div
    data-action="click->cart#close"
    class="absolute inset-0 bg-black/80 backdrop-blur-md transition-opacity duration-300">
  </div>

  <!-- DRAWER -->
  <div
    class="absolute right-0 top-0 h-full w-full md:w-[500px]
           bg-[#050505]/95 backdrop-blur-xl
           border-l border-white/10
           shadow-[0_0_60px_rgba(0,0,0,0.8)]
           flex flex-col">

    <!-- HEADER -->
    <div
      class="sticky top-0 z-20
             bg-[#050505]/95 backdrop-blur-xl
             border-b border-white/10
             px-8 py-7">

      <div class="flex items-start justify-between">

        <div>
          <h2 class="text-[15px] uppercase tracking-[0.45em] text-white">
            Cart
          </h2>

          <p class="text-sm text-gray-500 mt-3">
            Your selected pieces
          </p>
        </div>

        <button
          data-action="click->cart#close"
          class="w-11 h-11
                 border border-white/10
                 flex items-center justify-center
                 text-gray-400 hover:text-white
                 hover:border-white/30
                 transition duration-300
                 rounded-full">

          ✕

        </button>

      </div>

    </div>

    <!-- TURBO CONTENT -->
    <%= render "carts/cart_content" %>

  </div>

</div>