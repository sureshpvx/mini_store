<div
  data-cart-target="drawer"
  id="cart-drawer"
  class="fixed inset-0 z-50 hidden">

  <!-- OVERLAY -->
  <div
    data-action="click->cart#close"
    class="absolute inset-0 bg-white/60 backdrop-blur-sm transition-opacity duration-300">
  </div>

  <!-- DRAWER -->
  <div
    class="absolute right-0 top-0 h-full w-full sm:w-[400px] md:w-[500px]
           bg-white/95 backdrop-blur-xl
           border-l border-black/[0.06]
           shadow-[0_0_60px_rgba(0,0,0,0.05)]
           flex flex-col">

    <!-- HEADER -->
    <div
      class="sticky top-0 z-20
             bg-white/95 backdrop-blur-xl
             border-b border-black/[0.06]
             px-5 sm:px-8 py-5 sm:py-7">

      <div class="flex items-start justify-between">

        <div>
          <h2 class="text-[15px] uppercase tracking-[0.45em] text-black font-light">
            Cart
          </h2>

          <p class="text-sm text-gray-400 mt-3 font-light">
            Your selected pieces
          </p>
        </div>

        <button
          data-action="click->cart#close"
          class="w-11 h-11
                 border border-black/10
                 flex items-center justify-center
                 text-gray-400 hover:text-black
                 hover:border-black/30
                 transition duration-300">

          ✕

        </button>

      </div>

    </div>

    <!-- TURBO CONTENT -->
    <%= render "carts/cart_content" %>

  </div>

</div>