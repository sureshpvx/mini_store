<% content_for(:title, "Your Cart — HYPEE") %>

<section class="min-h-screen bg-white pt-24 pb-16">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-2xl uppercase tracking-[0.3em] font-light text-black">Your Cart</h1>
      <p class="text-sm text-gray-400 mt-2 font-light">
        <% if current_cart&.cart_items&.any? %>
          <%= current_cart.total_items %> item<%= 's' if current_cart.total_items != 1 %> in your cart
        <% else %>
          Your cart is empty
        <% end %>
      </p>
    </div>

    <!-- Cart Content -->
    <%= render "carts/cart_content" %>

    <!-- Continue Shopping -->
    <div class="mt-10 text-center">
      <%= link_to "← Continue Shopping", products_path,
            class: "text-sm text-gray-500 hover:text-black transition uppercase tracking-widest" %>
    </div>

  </div>
</section>
