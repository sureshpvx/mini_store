<!-- app/views/carts/_cart_content.html.erb -->
<turbo-frame
  id="cart_content"
  class="flex flex-col flex-1 min-h-0">
  <div
    class="flex-1 overflow-y-auto px-4 sm:px-6 md:px-8 py-6 sm:py-8 space-y-4 sm:space-y-6
           [&::-webkit-scrollbar]:w-1
           [&::-webkit-scrollbar-track]:bg-transparent
           [&::-webkit-scrollbar-thumb]:bg-black/10">

    <% if current_cart&.cart_items&.any? %>

      <% current_cart.cart_items.each do |item| %>

        <%# Skip orphaned items (product deleted from DB) %>
        <% unless item.product.present? %>
          <% Rails.logger.warn "[Cart] Skipping CartItem ##{item.id} — missing product (product_id: #{item.product_id})" %>
          <% next %>
        <% end %>

        <div
          class="group relative overflow-hidden
                 border border-black/[0.06]
                 bg-white
                 hover:border-black/20
                 transition-all duration-500
                 p-4 sm:p-5 flex gap-4 sm:gap-5">

          <!-- IMAGE -->
          <div
            class="relative w-[90px] h-[120px] sm:w-[115px] sm:h-[150px]
                   overflow-hidden
                   bg-gray-50 flex-shrink-0">

            <% if item.product.images.attached? && item.product.images.first.present? %>

              <%= image_tag item.product.images.first,
                            class: "w-full h-full object-cover
                                    group-hover:scale-105
                                    transition duration-700 ease-out" %>

            <% else %>

              <div
                class="w-full h-full flex items-center justify-center
                       text-gray-400 text-[10px] uppercase tracking-widest bg-gray-50">
                No Image
              </div>

            <% end %>

          </div>

          <!-- INFO -->
          <div class="relative flex-1 flex flex-col justify-between min-w-0">

            <div>

              <p
                class="text-[10px]
                       uppercase tracking-[0.3em]
                       text-gray-400 mb-3">

                <%= item.product.category&.name || "Uncategorized" %>

              </p>

              <h3
                class="text-[15px]
                       leading-relaxed
                       tracking-[0.08em]
                       text-black uppercase font-light">

                <%= item.product.name %>

              </h3>

            </div>

            <!-- BOTTOM -->
            <div class="mt-7">

              <!-- PRICE -->
              <div class="flex items-end justify-between">

                <p class="text-xl text-black font-light tracking-wide">
                  ₹ <%= item.total_price&.to_f&.round(2) || "0.00" %>
                </p>

                <%= button_to "Remove",
                              remove_item_cart_path(id: item.id),
                              method: :delete,
                              form: { data: { turbo: true } },
                              class: "text-[10px]
                                     uppercase tracking-[0.3em]
                                     text-gray-400 hover:text-black
                                     transition bg-transparent border-0 p-0" %>

              </div>

              <!-- QUANTITY -->
              <div
                class="mt-5 inline-flex items-center
                       border border-black/20
                       bg-white overflow-hidden">

                <%= button_to "−",
                              decrease_quantity_cart_path(id: item.id),
                              method: :patch,
                              form: { data: { turbo: true } },
                              class: "w-11 h-11 flex items-center justify-center
                                     text-gray-400 hover:text-black
                                     hover:bg-black/5 transition text-lg
                                     bg-transparent border-0" %>

                <div
                  class="w-12 h-11 flex items-center justify-center
                         text-sm text-black
                         border-x border-black/10">

                  <%= item.quantity %>

                </div>

                <%= button_to "+",
                              increase_quantity_cart_path(id: item.id),
                              method: :patch,
                              form: { data: { turbo: true } },
                              class: "w-11 h-11 flex items-center justify-center
                                     text-gray-400 hover:text-black
                                     hover:bg-black/5 transition text-lg
                                     bg-transparent border-0" %>

              </div>

            </div>

          </div>
        </div>

      <% end %>

    <% else %>

      <!-- EMPTY STATE -->
      <div
        class="h-full flex flex-col
               items-center justify-center
               text-center px-10 py-20">

        <div
          class="w-24 h-24
                 border border-black/10
                 flex items-center justify-center
                 mb-8">

          <svg xmlns="http://www.w3.org/2000/svg"
               class="w-10 h-10 text-gray-400"
               fill="none"
               viewBox="0 0 24 24"
               stroke="currentColor"
               stroke-width="1.5">

            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.5 6h11M10 21a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z" />

          </svg>

        </div>

        <h3
          class="text-lg uppercase
                 tracking-[0.3em]
                 text-black font-light">

          Your cart is empty

        </h3>

        <p
          class="text-sm text-gray-400
                 mt-4 leading-relaxed font-light">

          Curate your wardrobe with premium essentials.

        </p>

        <%= link_to "Explore Collection",
                    products_path,
                    data: { turbo: false },
                    class: "mt-8 border border-black/30
                            px-8 py-4
                            text-[11px] uppercase tracking-[0.2em]
                            text-black hover:bg-black hover:text-white
                            transition-all duration-300" %>

      </div>

    <% end %>

  </div>

  <!-- FOOTER -->
  <div
    class="border-t border-black/[0.06]
           bg-white/95 backdrop-blur-xl
           p-8 space-y-6">

    <!-- TOTALS -->
    <div class="space-y-4">

      <div class="flex items-center justify-between">

        <p
          class="text-[11px] uppercase
                 tracking-[0.2em]
                 text-gray-400">

          Subtotal

        </p>

        <p class="text-black text-2xl font-light tracking-wide">
          ₹ <%= current_cart&.total_price&.to_f&.round(2) || "0.00" %>
        </p>

      </div>

      <div class="flex items-center justify-between">

        <p
          class="text-[11px] uppercase
                 tracking-[0.2em]
                 text-gray-400">

          Shipping

        </p>

        <p class="text-gray-400 text-sm font-light">
          Calculated at next step
        </p>

      </div>

    </div>

    <!-- CHECKOUT -->
    <% if current_cart&.cart_items&.any? %>
      <%= link_to "Checkout",
                  checkout_path,
                  data: { turbo: false },
                  class: "w-full h-14
                     bg-black
                     flex items-center justify-center
                     uppercase tracking-[0.2em]
                     text-[11px] text-white
                     hover:bg-gray-800
                     transition-all duration-300" %>
    <% else %>
      <button disabled
              class="w-full h-14
                     border border-black/10
                     flex items-center justify-center
                     uppercase tracking-[0.2em]
                     text-[11px] text-gray-400
                     cursor-not-allowed">
        Cart Empty
      </button>
    <% end %>

    <!-- FOOT NOTE -->
    <p
      class="text-center text-[10px]
             uppercase tracking-[0.25em]
             text-gray-400 pt-1">

      Complimentary shipping on premium orders

    </p>

  </div>
</turbo-frame>