<% content_for :auth_page, true %>

<div class="min-h-screen bg-white flex items-center justify-center px-4 sm:px-6 py-10">
  <main class="w-full max-w-md">

    <!-- Header -->
    <div class="text-center mb-8 sm:mb-10">
      <h1 class="text-2xl font-bold tracking-tight uppercase text-black">
        Hypee
      </h1>

      <h2 class="text-xl sm:text-2xl mt-4 sm:mt-6 text-black font-light tracking-[0.1em]">
        Edit <%= resource_name.to_s.humanize %>
      </h2>

      <p class="text-gray-400 text-sm">
        Update your account details.
      </p>
    </div>

    <!-- Form -->
    <div class="border border-black/[0.06] p-4 sm:p-8 bg-white">

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="field">
          <%= f.label :email, class: "block text-xs uppercase text-gray-400 mb-2" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
                            class: "w-full bg-gray-50 border border-black/[0.06] px-4 py-4 text-black placeholder:text-gray-400 focus:outline-none focus:border-black transition" %>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <div class="text-sm text-gray-400">Currently waiting confirmation for: <%= resource.unconfirmed_email %></div>
        <% end %>

        <div class="field" data-controller="password-strength">
          <%= f.label :password, class: "block text-xs uppercase text-gray-400 mb-2" %>
          <p class="text-xs text-gray-400 mb-2"><i>(leave blank if you don't want to change it)</i></p>
          <%= f.password_field :password, autocomplete: "new-password",
                               data: {
                                 password_strength_target: "input",
                                 action: "focus->password-strength#show blur->password-strength#hide input->password-strength#validate"
                               },
                               class: "w-full bg-gray-50 border border-black/[0.06] px-4 py-4 text-black placeholder:text-gray-400 focus:outline-none focus:border-black transition" %>
          <%= render "devise/shared/password_strength_checklist" %>
          <% if @minimum_password_length %>
            <p class="text-xs text-gray-400 mt-1"><em><%= @minimum_password_length %> characters minimum</em></p>
          <% end %>
        </div>

        <div class="field">
          <%= f.label :password_confirmation, class: "block text-xs uppercase text-gray-400 mb-2" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
                               class: "w-full bg-gray-50 border border-black/[0.06] px-4 py-4 text-black placeholder:text-gray-400 focus:outline-none focus:border-black transition" %>
        </div>

        <div class="field">
          <%= f.label :current_password, class: "block text-xs uppercase text-gray-400 mb-2" %>
          <p class="text-xs text-gray-400 mb-2"><i>(we need your current password to confirm your changes)</i></p>
          <%= f.password_field :current_password, autocomplete: "current-password",
                               class: "w-full bg-gray-50 border border-black/[0.06] px-4 py-4 text-black placeholder:text-gray-400 focus:outline-none focus:border-black transition" %>
        </div>

        <div class="actions">
          <%= f.submit "Update",
                       class: "w-full bg-black text-white uppercase py-4 hover:bg-gray-800 transition" %>
        </div>
      <% end %>

      <!-- Cancel Account -->
      <div class="mt-8 pt-6 border-t border-black/[0.06]">
        <h3 class="text-lg font-light tracking-[0.1em] text-black mb-4">Cancel my account</h3>
        <div class="text-sm text-gray-400">
          Unhappy?
          <%= button_to "Cancel my account", registration_path(resource_name),
                        data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" },
                        method: :delete,
                        class: "underline text-black hover:opacity-80 bg-transparent border-none cursor-pointer p-0" %>
        </div>
      </div>

      <!-- Back -->
      <div class="text-center mt-6 text-xs text-gray-400 uppercase">
        <%= link_to "Back", :back, class: "underline hover:text-black transition" %>
      </div>

    </div>

  </main>
</div>