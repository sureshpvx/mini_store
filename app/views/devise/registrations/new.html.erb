<% content_for :auth_page, true %>

<div class="min-h-screen flex items-center justify-center px-4 sm:px-6 py-10">
  <main class="w-full max-w-md">

    <!-- Header -->
    <div class="text-center mb-8 sm:mb-10">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight uppercase">
        Hypee
      </h1>

      <h2 class="text-xl sm:text-2xl mt-4 sm:mt-6">
        Create Account
      </h2>

      <p class="text-gray-400 text-sm">
        Join Hypee today.
      </p>
    </div>

    <!-- Form -->
    <div class="border border-white/10 p-4 sm:p-8">

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>

        <%= render "devise/shared/error_messages", resource: resource %>

        <!-- Email -->
        <%= f.email_field :email,
                          autofocus: true,
                          autocomplete: "email",
                          placeholder: "Email Address",
                          class: "w-full bg-[#0A0A0A] border border-[#333333] px-4 py-4 text-white placeholder-gray-500 focus:outline-none focus:border-white transition" %>

        <!-- Password -->
        <%= f.password_field :password,
                             autocomplete: "new-password",
                             placeholder: "Password",
                             class: "w-full bg-[#0A0A0A] border border-[#333333] px-4 py-4 text-white placeholder-gray-500 focus:outline-none focus:border-white transition" %>

        <!-- Confirm Password -->
        <%= f.password_field :password_confirmation,
                             autocomplete: "new-password",
                             placeholder: "Confirm Password",
                             class: "w-full bg-[#0A0A0A] border border-[#333333] px-4 py-4 text-white placeholder-gray-500 focus:outline-none focus:border-white transition" %>

        <!-- Terms -->
        <div class="flex items-start gap-2 text-xs text-gray-400">
          <%= check_box_tag :terms, "1", false,
                            class: "mt-1 bg-[#0A0A0A] border-[#333333]" %>

          <span>
            I agree to the
            <a href="#" class="text-white underline hover:opacity-80">Terms</a>
            &
            <a href="#" class="text-white underline hover:opacity-80">Privacy Policy</a>
          </span>
        </div>

        <!-- Submit -->
        <%= f.submit "Create Account",
                     class: "w-full bg-white text-black uppercase py-4 mt-2 hover:bg-opacity-90 transition" %>

      <% end %>

      <!-- Footer -->
      <div class="text-center mt-6 pt-6 border-t border-[#1A1A1A] text-xs text-gray-400 uppercase">
        Already have an account?
        <%= link_to "Sign In", new_session_path(resource_name),
                    class: "underline ml-1 hover:text-white transition" %>
      </div>

    </div>

  </main>
</div>