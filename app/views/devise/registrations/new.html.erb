<% content_for :auth_page, true %>

<div class="min-h-screen bg-white flex items-center justify-center px-4 sm:px-6 py-10">
  <main class="w-full max-w-md">

    <!-- Header -->
    <div class="text-center mb-8 sm:mb-10">
      <h1 class="text-2xl font-bold tracking-tight uppercase text-black">Hypee</h1>
      <h2 class="text-xl sm:text-2xl mt-4 sm:mt-6 text-black font-light tracking-[0.1em]">Create Account</h2>
      <p class="text-gray-400 text-sm">Join Hypee today.</p>
    </div>

    <!-- Form -->
    <div class="border border-black/[0.06] p-4 sm:p-8 bg-white">

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
                   html: {
                     novalidate: true,
                     class: "space-y-6",
                     data: { controller: "form-validation", action: "submit->form-validation#validateAll" }
                   }) do |f| %>


        <!-- Email -->
        <div data-field-wrapper>
          <%= validated_field f, :email,
                              as: :email_field,
                              required: true,
                              autofocus: true,
                              autocomplete: "email",
                              placeholder: "Email Address",
                              data: { validate_type: "email" },
                              class: "w-full bg-gray-50 border border-black/[0.06] px-4 py-4 text-black placeholder:text-gray-400 focus:outline-none focus:border-black transition" %>
        </div>

        <!-- Password -->
        <div data-controller="password-strength" class="relative">
          <div data-field-wrapper>
            <div class="relative">
              <%= validated_field f, :password,
                                  as: :password_field,
                                  required: true,
                                  autocomplete: "new-password",
                                  placeholder: "Password",
                                  id: "user_password",
                                  data: {
                                    min_length: "8",
                                    "password-strength-target": "input",
                                    action: "focus->password-strength#show blur->password-strength#hide input->password-strength#validate"
                                  },
                                  class: "w-full bg-gray-50 border border-black/[0.06] px-4 py-4 pr-12 text-black placeholder:text-gray-400 focus:outline-none focus:border-black transition" %>
              <button type="button"
                      data-password-strength-target="toggle"
                      data-action="click->password-strength#toggleVisibility"
                      class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-black transition focus:outline-none z-10 cursor-pointer"
                      tabindex="-1"
                      aria-label="Toggle password visibility">
                <svg data-password-strength-target="eye-icon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </button>
            </div>
          </div>
          <%= render "devise/shared/password_strength_checklist" %>
        </div>

        <!-- Confirm Password -->
        <div data-field-wrapper>
          <div class="relative" data-controller="password-strength">
            <%= validated_field f, :password_confirmation,
                                as: :password_field,
                                required: true,
                                autocomplete: "new-password",
                                placeholder: "Confirm Password",
                                data: { validate_match: "user[password]", "password-strength-target": "input" },
                                class: "w-full bg-gray-50 border border-black/[0.06] px-4 py-4 pr-12 text-black placeholder:text-gray-400 focus:outline-none focus:border-black transition" %>
            <button type="button"
                    data-password-strength-target="toggle"
                    data-action="click->password-strength#toggleVisibility"
                    class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-black transition focus:outline-none z-10 cursor-pointer"
                    tabindex="-1"
                    aria-label="Toggle password visibility">
              <svg data-password-strength-target="eye-icon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- Terms -->
        <div data-field-wrapper class="flex flex-wrap items-start gap-2 text-xs text-gray-400">
          <%= check_box_tag :terms, "1", false,
                            required: true,
                            data: { form_validation_target: "field", action: "change->form-validation#validateField" },
                            class: "mt-1 bg-white border-black/[0.06]" %>
          <span>
            I agree to the
            <%= link_to "Terms", terms_path, class: "text-black underline hover:opacity-80" %>
            &
            <%= link_to "Privacy Policy", privacy_path, class: "text-black underline hover:opacity-80" %>
          </span>
        </div>

        <!-- Submit -->
        <%= f.submit "Create Account",
                     class: "w-full bg-black text-white uppercase py-4 mt-2 hover:bg-gray-800 transition" %>

      <% end %>

      <!-- Footer -->
      <div class="text-center mt-6 pt-6 border-t border-black/[0.06] text-xs text-gray-400 uppercase">
        Already have an account?
        <%= link_to "Sign In", new_session_path(resource_name), class: "underline ml-1 hover:text-black transition" %>
      </div>

    </div>

  </main>
</div>