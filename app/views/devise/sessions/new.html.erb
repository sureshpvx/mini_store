<% content_for :auth_page, true %>

<div class="min-h-screen flex items-center justify-center px-4 sm:px-6 py-10">
  <main class="w-full max-w-md">

    <!-- Header -->
    <div class="text-center mb-8 sm:mb-10">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight uppercase">
        Hypee
      </h1>

      <h2 class="text-xl sm:text-2xl mt-4 sm:mt-6">
        Sign In
      </h2>

      <p class="text-gray-400 text-sm">
        Welcome back to Hypee
      </p>
    </div>

    <!-- Form -->
    <div class="border border-white/10 p-4 sm:p-8">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>

        <!-- Email -->
        <%= f.email_field :email,
                          placeholder: "Email address",
                          class: "w-full bg-transparent border-0 border-b border-[#1A1A1A] py-4 px-0 text-white placeholder-gray-500 focus:outline-none focus:border-white transition" %>

        <!-- Password -->
        <%= f.password_field :password,
                             placeholder: "Password",
                             class: "w-full bg-transparent border-0 border-b border-[#1A1A1A] py-4 px-0 text-white placeholder-gray-500 focus:outline-none focus:border-white transition" %>

        <!-- Remember + Forgot -->
        <div class="flex justify-between items-center text-[10px] sm:text-xs uppercase text-gray-400">
          <label class="flex items-center gap-2">
            <%= f.check_box :remember_me, class: "bg-transparent border-white/20" %>
            Remember
          </label>

          <%= link_to "Forgot?", new_password_path(resource_name),
                      class: "underline hover:text-white transition" %>
        </div>

        <!-- Button -->
        <%= f.submit "Sign In",
                     class: "w-full bg-white text-black uppercase py-4 mt-4 sm:mt-6 active:scale-95 transition" %>

      <% end %>

      <!-- Divider -->
      <div class="my-6 sm:my-8 relative">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-[#1A1A1A]"></div>
        </div>
        <div class="relative text-center">
          <span class="bg-black px-4 text-[10px] sm:text-xs uppercase text-gray-500">
            Or continue with
          </span>
        </div>
      </div>

      <!-- Social -->
      <div class="grid grid-cols-2 gap-3">
        <button class="border border-white/20 py-3 text-xs sm:text-sm uppercase active:scale-95 transition">
          Google
        </button>
        <button class="border border-white/20 py-3 text-xs sm:text-sm uppercase active:scale-95 transition">
          Apple
        </button>
      </div>
    </div>

    <!-- Footer -->
    <div class="text-center mt-6 sm:mt-8 text-[10px] sm:text-xs uppercase text-gray-400">
      Don’t have an account?
      <%= link_to "Create Account", new_registration_path(resource_name),
                  class: "underline ml-1 hover:text-white transition" %>
    </div>

  </main>
</div>