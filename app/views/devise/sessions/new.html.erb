<% content_for :auth_page, true %>

<div class="min-h-screen bg-white flex items-center justify-center px-4 sm:px-6 py-10">
  <main class="w-full max-w-md">

    <!-- Header -->
    <div class="text-center mb-8 sm:mb-10">
      <h1 class="text-2xl font-bold tracking-tight uppercase text-black">Hypee</h1>
      <h2 class="text-xl sm:text-2xl mt-4 sm:mt-6 text-black font-light tracking-[0.1em]">Sign In</h2>
      <p class="text-gray-400 text-sm">Welcome back to Hypee</p>
    </div>

    <!-- Toggle -->
    <div class="flex border-b border-black/[0.06] mb-6">
      <button type="button" id="btn-email" onclick="showEmail()" class="flex-1 pb-3 text-[11px] uppercase tracking-[0.2em] text-black border-b-2 border-black transition">Email</button>
      <button type="button" id="btn-phone" onclick="showPhone()" class="flex-1 pb-3 text-[11px] uppercase tracking-[0.2em] text-gray-400 border-b-2 border-transparent transition">Phone</button>
    </div>

    <!-- EMAIL FORM -->
    <div id="form-email" class="border border-black/[0.06] p-4 sm:p-8 bg-white">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>

        <%= f.email_field :email, placeholder: "Email address",
                          class: "w-full bg-transparent border-0 border-b border-black/[0.06] py-4 px-0 text-black placeholder:text-gray-400 focus:outline-none focus:border-black transition" %>

        <%= f.password_field :password, placeholder: "Password",
                             class: "w-full bg-transparent border-0 border-b border-black/[0.06] py-4 px-0 text-black placeholder:text-gray-400 focus:outline-none focus:border-black transition" %>

        <div class="flex justify-between items-center text-[10px] sm:text-xs uppercase text-gray-400">
          <label class="flex items-center gap-2">
            <%= f.check_box :remember_me, class: "bg-transparent border-black/[0.06]" %>
            Remember
          </label>
          <%= link_to "Forgot?", new_password_path(resource_name), class: "underline hover:text-black transition" %>
        </div>

        <%= f.submit "Sign In", class: "w-full bg-black text-white uppercase py-4 mt-4 sm:mt-6 active:scale-95 transition" %>
      <% end %>

      <div class="my-6 sm:my-8 relative">
        <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-black/[0.04]"></div></div>
        <div class="relative text-center">
          <span class="bg-white px-4 text-[10px] sm:text-xs uppercase text-gray-400">Or continue with</span>
        </div>
      </div>

      <!-- Google OAuth Button -->
      <%= button_to '/auth/google_oauth2', method: :post, data: { turbo: false }, class: "w-full border border-black/[0.06] py-3 text-xs sm:text-sm uppercase text-black active:scale-95 transition" do %>
        Google
      <% end %>
    </div>

    <!-- PHONE FORM -->
    <div id="form-phone" class="border border-black/[0.06] p-4 sm:p-8 bg-white hidden">
      <div id="otp_modal_content">
        <%= form_with url: send_otp_path(context: "login"), data: { turbo_stream: true }, html: { class: "space-y-6" } do |f| %>
          <div class="flex gap-2">
            <%= f.select :country_code, ["+91", "+1", "+44"], { selected: "+91" },
                         class: "w-20 bg-transparent border-0 border-b border-black/[0.06] py-4 text-sm text-black focus:outline-none focus:border-black transition" %>
            <%= f.telephone_field :phone_number, placeholder: "Phone Number", required: true,
                                  class: "flex-1 bg-transparent border-0 border-b border-black/[0.06] py-4 px-0 text-black placeholder:text-gray-400 focus:outline-none focus:border-black transition" %>
          </div>
          <%= f.submit "Send OTP", class: "w-full bg-black text-white uppercase py-4 mt-4 active:scale-95 transition cursor-pointer" %>
        <% end %>
      </div>
    </div>

    <!-- Footer -->
    <div class="text-center mt-6 sm:mt-8 text-[10px] sm:text-xs uppercase text-gray-400">
      Don't have an account?
      <%= link_to "Create Account", new_registration_path(resource_name), class: "underline ml-1 hover:text-black transition" %>
    </div>

  </main>
</div>

<script>
    function showEmail() {
        document.getElementById('form-email').classList.remove('hidden')
        document.getElementById('form-phone').classList.add('hidden')
        document.getElementById('btn-email').className = 'flex-1 pb-3 text-[11px] uppercase tracking-[0.2em] text-black border-b-2 border-black transition'
        document.getElementById('btn-phone').className = 'flex-1 pb-3 text-[11px] uppercase tracking-[0.2em] text-gray-400 border-b-2 border-transparent transition'
    }
    function showPhone() {
        document.getElementById('form-email').classList.add('hidden')
        document.getElementById('form-phone').classList.remove('hidden')
        document.getElementById('btn-email').className = 'flex-1 pb-3 text-[11px] uppercase tracking-[0.2em] text-gray-400 border-b-2 border-transparent transition'
        document.getElementById('btn-phone').className = 'flex-1 pb-3 text-[11px] uppercase tracking-[0.2em] text-black border-b-2 border-black transition'
    }
</script>