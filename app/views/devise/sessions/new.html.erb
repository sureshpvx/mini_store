<% content_for :auth_page, true %>

<div class="min-h-screen bg-white flex items-center justify-center px-4 sm:px-6 py-10">
  <main class="w-full max-w-md">

    <!-- Header -->
    <div class="text-center mb-8 sm:mb-10">
      <h1 class="text-2xl font-bold tracking-tight uppercase text-black">Hypee</h1>
      <h2 class="text-xl sm:text-2xl mt-4 sm:mt-6 text-black font-light tracking-[0.1em]">Sign In</h2>
      <p class="text-gray-400 text-sm">Welcome back to Hypee</p>
    </div>

    <!-- TABS CONTAINER: wraps both tabs AND panels -->
    <div data-controller="tabs">

      <!-- Tabs -->
      <div class="flex border-b border-black/[0.06] mb-6">
        <button type="button"
                data-tabs-target="tab"
                data-index="0"
                data-action="click->tabs#switch"
                class="flex-1 pb-3 text-[11px] uppercase tracking-[0.2em] transition cursor-pointer">
          Email
        </button>
        <button type="button"
                data-tabs-target="tab"
                data-index="1"
                data-action="click->tabs#switch"
                class="flex-1 pb-3 text-[11px] uppercase tracking-[0.2em] transition cursor-pointer">
          Phone
        </button>
      </div>

      <!-- EMAIL PANEL -->
      <div data-tabs-target="panel"
           class="border border-black/[0.06] p-4 sm:p-8 bg-white">
        <%= form_for(resource, as: resource_name, url: session_path(resource_name),
                     html: {
                       novalidate: true,
                       class: "space-y-6",
                       data: { controller: "form-validation", action: "submit->form-validation#validateAll" }
                     }) do |f| %>

          <div data-field-wrapper>
            <%= validated_field f, :email,
                                as: :email_field,
                                required: true,
                                autocomplete: "email",
                                placeholder: "Email address",
                                data: { validate_type: "email" },
                                class: "w-full bg-transparent border-0 border-b border-black/[0.06] py-4 px-0 text-black placeholder:text-gray-400 focus:outline-none focus:border-black transition" %>
          </div>

          <div data-field-wrapper>
            <div class="relative" data-controller="password-strength">
              <%= validated_field f, :password,
                                  as: :password_field,
                                  required: true,
                                  autocomplete: "current-password",
                                  placeholder: "Password",
                                  data: { min_length: "8", "password-strength-target": "input" },
                                  class: "w-full bg-transparent border-0 border-b border-black/[0.06] py-4 px-0 pr-10 text-black placeholder:text-gray-400 focus:outline-none focus:border-black transition" %>
              <button type="button"
                      data-password-strength-target="toggle"
                      data-action="click->password-strength#toggleVisibility"
                      class="absolute right-0 top-1/2 -translate-y-1/2 text-gray-400 hover:text-black transition focus:outline-none"
                      tabindex="-1"
                      aria-label="Toggle password visibility">
                <svg data-password-strength-target="eye-icon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </button>
            </div>
          </div>

          <div class="flex justify-between items-center text-[10px] sm:text-xs uppercase text-gray-400">
            <label class="flex items-center gap-2">
              <%= f.check_box :remember_me, class: "bg-transparent border-black/[0.06]" %>
              Remember
            </label>
            <%= link_to "Forgot?", new_password_path(resource_name), class: "underline hover:text-black transition" %>
          </div>

          <%= f.submit "Sign In", class: "w-full bg-black text-white uppercase py-4 mt-4 sm:mt-6 active:scale-95 transition" %>
        <% end %>

        <div class="my-6 sm:my-8 relative">
          <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-black/[0.04]"></div></div>
          <div class="relative text-center">
            <span class="bg-white px-4 text-[10px] sm:text-xs uppercase text-gray-400">Or continue with</span>
          </div>
        </div>

        <%= button_to '/auth/google_oauth2', method: :post, data: { turbo: false },
                      class: "w-full border border-black/[0.06] py-3 text-xs sm:text-sm uppercase text-black active:scale-95 transition" do %>
          Google
        <% end %>
      </div>

      <!-- PHONE PANEL -->
      <div data-tabs-target="panel"
           class="border border-black/[0.06] p-4 sm:p-8 bg-white hidden">
        <div id="otp_modal_content">
          <%= form_with url: send_otp_path(context: "login"),
                        data: { turbo_stream: true },
                        html: {
                          novalidate: true,
                          class: "space-y-6",
                          data: { controller: "form-validation", action: "submit->form-validation#validateAll" }
                        } do |f| %>

            <div class="flex gap-2">
              <%= f.select :country_code, ["+91", "+1", "+44"], { selected: "+91" },
                           class: "w-20 bg-transparent border-0 border-b border-black/[0.06] py-4 text-sm text-black focus:outline-none focus:border-black transition" %>

              <div data-field-wrapper class="flex-1">
                <%= f.telephone_field :phone_number,
                                      required: true,
                                      placeholder: "Phone Number",
                                      data: {
                                        form_validation_target: "field",
                                        validate_type: "india-phone",
                                        required: "true",
                                        action: "blur->form-validation#validateField input->form-validation#clear input->form-validation#normalize"
                                      },
                                      class: "w-full bg-transparent border-0 border-b border-black/[0.06] py-4 px-0 text-black placeholder:text-gray-400 focus:outline-none focus:border-black transition" %>
              </div>
            </div>

            <%= f.submit "Send OTP", class: "w-full bg-black text-white uppercase py-4 mt-4 active:scale-95 transition cursor-pointer" %>
          <% end %>
        </div>
      </div>

    </div>

    <!-- Footer -->
    <div class="text-center mt-6 sm:mt-8 text-[10px] sm:text-xs uppercase text-gray-400">
      Don't have an account?
      <%= link_to "Create Account", new_registration_path(resource_name), class: "underline ml-1 hover:text-black transition" %>
    </div>

  </main>
</div>