<div data-password-strength-target="checklist"
     class="hidden mt-2 space-y-2 overflow-hidden transition-all duration-300 ease-in-out"
     style="max-height: 0; opacity: 0;">

  <!-- Rule 1: Length -->
  <div data-password-strength-target="rule-length" class="flex items-start gap-2">
    <div data-icon class="mt-[2px]">
      <svg class="w-4 h-4 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </div>
    <span data-text class="text-sm text-red-500">8 characters minimum</span>
  </div>

  <!-- Rule 2: Number -->
  <div data-password-strength-target="rule-number" class="flex items-start gap-2">
    <div data-icon class="mt-[2px]">
      <svg class="w-4 h-4 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </div>
    <span data-text class="text-sm text-red-500">One number</span>
  </div>

  <!-- Rule 3: Uppercase -->
  <div data-password-strength-target="rule-uppercase" class="flex items-start gap-2">
    <div data-icon class="mt-[2px]">
      <svg class="w-4 h-4 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </div>
    <span data-text class="text-sm text-red-500">One Uppercase letter</span>
  </div>

  <!-- Rule 4: Special -->
  <div data-password-strength-target="rule-special" class="flex items-start gap-2">
    <div data-icon class="mt-[2px]">
      <svg class="w-4 h-4 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </div>
    <span data-text class="text-sm text-red-500">One special character $!#%*&amp;()</span>
  </div>

</div>
