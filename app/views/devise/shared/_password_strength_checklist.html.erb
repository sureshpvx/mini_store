<%# Password strength checklist partial — render inside a password-strength controller wrapper %>
<div data-password-strength-target="checklist"
     class="hidden mt-2 bg-gray-50 border border-black/[0.06] rounded px-4 py-3 space-y-2 overflow-hidden"
     style="max-height: 0; opacity: 0; transition: max-height 0.3s ease, opacity 0.25s ease;">

  <p class="text-[10px] uppercase tracking-[0.15em] text-gray-400 mb-1">Password must contain</p>

  <div data-password-strength-target="ruleLength" class="flex items-center gap-2">
    <span data-icon>
      <svg class="w-4 h-4 text-gray-300 shrink-0" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="10" cy="10" r="8"/></svg>
    </span>
    <span data-text class="text-xs text-gray-400 transition-colors duration-200">At least 6 characters</span>
  </div>

  <div data-password-strength-target="ruleUppercase" class="flex items-center gap-2">
    <span data-icon>
      <svg class="w-4 h-4 text-gray-300 shrink-0" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="10" cy="10" r="8"/></svg>
    </span>
    <span data-text class="text-xs text-gray-400 transition-colors duration-200">An uppercase letter (A–Z)</span>
  </div>

  <div data-password-strength-target="ruleLowercase" class="flex items-center gap-2">
    <span data-icon>
      <svg class="w-4 h-4 text-gray-300 shrink-0" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="10" cy="10" r="8"/></svg>
    </span>
    <span data-text class="text-xs text-gray-400 transition-colors duration-200">A lowercase letter (a–z)</span>
  </div>

  <div data-password-strength-target="ruleNumber" class="flex items-center gap-2">
    <span data-icon>
      <svg class="w-4 h-4 text-gray-300 shrink-0" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="10" cy="10" r="8"/></svg>
    </span>
    <span data-text class="text-xs text-gray-400 transition-colors duration-200">A number (0–9)</span>
  </div>

  <div data-password-strength-target="ruleSpecial" class="flex items-center gap-2">
    <span data-icon>
      <svg class="w-4 h-4 text-gray-300 shrink-0" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="10" cy="10" r="8"/></svg>
    </span>
    <span data-text class="text-xs text-gray-400 transition-colors duration-200">A special character (!@#$%^&*)</span>
  </div>
</div>
