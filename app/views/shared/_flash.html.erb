<div class="fixed top-6 right-6 z-[100] space-y-3">

  <% flash.each do |type, message| %>

    <% bg =
         case type.to_sym
         when :notice
           "border-black/[0.06] bg-white/95"
         when :alert
           "border-red-200 bg-red-50"
         else
           "border-black/[0.06] bg-white/95"
         end
    %>

    <div
      data-controller="flash"
      class="
        w-[360px]
        border
        backdrop-blur-xl
        shadow-[0_0_40px_rgba(0,0,0,0.05)]
        px-5 py-4
        text-sm text-black
        flex items-start gap-4
        animate-in
        slide-in-from-right-5
        duration-300
        <%= bg %>
      ">

      <!-- ICON -->
      <div class="mt-0.5">

        <% if type.to_sym == :notice %>

          <div class="w-8 h-8 border border-black/[0.06] flex items-center justify-center">

            <svg xmlns="http://www.w3.org/2000/svg"
                 class="w-4 h-4 text-black"
                 fill="none"
                 viewBox="0 0 24 24"
                 stroke="currentColor"
                 stroke-width="1.5">

              <path stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M5 13l4 4L19 7" />

            </svg>

          </div>

        <% else %>

          <div class="w-8 h-8 border border-red-200 flex items-center justify-center">

            <svg xmlns="http://www.w3.org/2000/svg"
                 class="w-4 h-4 text-red-500"
                 fill="none"
                 viewBox="0 0 24 24"
                 stroke="currentColor"
                 stroke-width="1.5">

              <path stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M6 18L18 6M6 6l12 12" />

            </svg>

          </div>

        <% end %>

      </div>

      <!-- CONTENT -->
      <div class="flex-1">

        <p class="leading-relaxed text-sm text-black font-light">
          <%= message %>
        </p>

      </div>

      <!-- CLOSE -->
      <button
        data-action="click->flash#close"
        class="text-gray-400 hover:text-black transition">

        ✕

      </button>

    </div>

  <% end %>

</div>