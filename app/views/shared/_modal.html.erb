<div
  id="<%= modal_id %>"
  data-modal-target="overlay"
  class="
    hidden fixed inset-0 z-[100]
    bg-black/70 backdrop-blur-sm
    overflow-y-auto
    pt-24 pb-10 px-4 md:px-8
  "
  data-action="click->modal#close">

  <!-- PANEL -->
  <div
    data-modal-target="panel"
    data-action="click->modal#stop"
    class="
      relative
      w-full max-w-6xl
      mx-auto
      border border-white/10
      rounded-[28px]
      bg-[#050505]/95
      shadow-[0_0_80px_rgba(0,0,0,0.75)]
      overflow-hidden
    ">

    <!-- TOP BAR -->
    <div
      class="
        flex items-center justify-between
        border-b border-white/10
        px-8 md:px-10
        py-5
      ">

      <!-- TITLE -->
      <div>

        <p class="text-[10px] uppercase tracking-[0.35em] text-gray-600 mb-2">
          Admin Panel
        </p>

        <h2 class="text-xl uppercase tracking-[0.3em] text-white">
          <%= title %>
        </h2>

      </div>

      <!-- CLOSE -->
      <button
        data-action="click->modal#close"
        class="
          w-10 h-10
          flex items-center justify-center
          rounded-full
          border border-white/10
          text-gray-500
          hover:text-white
          hover:border-white/30
          transition-all duration-300
        ">

        ✕

      </button>

    </div>

    <!-- SCROLLABLE CONTENT -->
    <div
      class="
        overflow-y-auto
        max-h-[calc(90vh-110px)]
      ">


        <div class="p-8 md:p-10">

          <%= yield %>

        </div>


    </div>

  </div>

</div>