<div
  id="<%= modal_id %>"
  data-modal-target="overlay"
  class="
    hidden fixed inset-0 z-[100]
    bg-white/60 backdrop-blur-sm
    overflow-y-auto
    pt-24 pb-10 px-4 md:px-8
  "
  data-action="click->modal#close">

  <!-- PANEL -->
  <div
    data-modal-target="panel"
    data-action="click->modal#stop"
    class="
      relative
      w-full max-w-2xl
      mx-auto
      border border-black/[0.06]
      bg-white/95
      shadow-[0_0_60px_rgba(0,0,0,0.05)]
      overflow-hidden
    ">

    <!-- TOP BAR -->
    <div
      class="
        flex items-center justify-between
        border-b border-black/[0.06]
        px-8 md:px-10
        py-5
      ">

      <!-- TITLE -->
      <div>
        <h2 class="text-sm uppercase tracking-[0.2em] text-black font-light">
          <%= title %>
        </h2>
      </div>

      <!-- CLOSE -->
      <button
        data-action="click->modal#close"
        class="
          w-10 h-10
          flex items-center justify-center
          border border-black/10
          text-gray-400
          hover:text-black
          hover:border-black/30
          transition-all duration-300
        ">
        ✕
      </button>

    </div>

    <!-- SCROLLABLE CONTENT -->
    <div class="overflow-y-auto max-h-[calc(90vh-110px)]">
      <div class="p-8 md:p-10">
        <%= yield %>
      </div>
    </div>

  </div>

</div>