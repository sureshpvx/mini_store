<% unless current_user&.admin? %>

  <header class="fixed top-0 left-0 right-0 z-50 text-black bg-white" data-controller="mobile-menu">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-8 py-4 sm:py-5">
      <!-- ================= DESKTOP ================= -->
      <div class="hidden md:flex items-center justify-between">
        <!-- Logo -->
        <%= link_to root_path, class: "text-2xl font-bold uppercase tracking-tight text-black" do %>
          Hypee
        <% end %>
        <!-- Nav -->
        <nav class="flex items-center gap-6 text-xs uppercase tracking-widest">
          <% base = "text-black/70 hover:text-black transition" %>
          <% active = "text-black border-b border-black pb-1" %>

          <%= link_to "NEW ARRIVALS", products_path(filter: "new"),
                      data: { turbo: false },
                      class: "#{params[:filter] == 'new' ? active : base}" %>

          <%= link_to "MEN", products_path(filter: "men"),
                      class: "#{params[:filter] == 'men' ? active : base}" %>

          <%= link_to "WOMEN", products_path(filter: "women"),
                      class: "#{params[:filter] == 'women' ? active : base}" %>

          <%= link_to "ACCESSORIES", products_path(filter: "accessories"),
                      class: "#{params[:filter] == 'accessories' ? active : base}" %>
        </nav>
        <div data-controller="cart" class="flex items-center gap-5 text-black/70">
          <!-- Search -->
          <div data-controller="search-modal">
            <button data-action="click->search-modal#open" class="hover:text-black transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.35-5.15a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </button>
            <%= render "shared/search_modal" %>
          </div>
          <!-- Cart -->
          <button data-action="click->cart#open" class="relative hover:text-black transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.5 6h11M10 21a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z" />
            </svg>
          </button>
          <!-- CART DRAWER -->
          <%= render "carts/drawer" %>
          <!-- Auth Dropdown -->
          <div data-controller="dropdown" class="relative">
            <% if user_signed_in? %>
              <button data-action="click->dropdown#toggle" class="text-xs uppercase tracking-widest hover:text-black transition text-black/70">
                Account
              </button>
              <div data-dropdown-target="menu" class="hidden absolute right-0 mt-4 w-48 bg-white border border-black/10 shadow-lg">
                <div class="py-2 text-xs uppercase tracking-widest">
                  <div class="px-4 py-3 text-gray-500 text-[10px] break-all">
                    <%= current_user.email %>
                  </div>
                  <%= link_to "Orders", orders_path, class: "block px-4 py-3 text-gray-600 hover:text-black hover:bg-gray-50" %>
                  <div class="border-t border-black/10 my-1"></div>
                  <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "w-full text-left px-4 py-3 text-gray-600 hover:text-black hover:bg-gray-50 uppercase" %>
                </div>
              </div>
            <% else %>
              <%= link_to "Login", new_user_session_path, class: "text-xs uppercase tracking-widest hover:text-black transition text-black/70" %>
            <% end %>
          </div>
        </div>
      </div>

      <!-- ================= MOBILE ================= -->
      <div class="flex md:hidden items-center justify-between text-black/70">
        <!-- LEFT: Hamburger -->
        <button data-action="click->mobile-menu#toggle" class="hover:text-black transition p-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
        <!-- CENTER: Logo -->
        <%= link_to root_path, class: "text-lg font-bold uppercase tracking-tight text-black" do %>
          Hypee
        <% end %>
        <!-- RIGHT: Search + Cart -->
        <div class="flex items-center gap-4">
          <div data-controller="search-modal">
            <button data-action="click->search-modal#open" class="hover:text-black transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.35-5.15a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </button>
            <%= render "shared/search_modal" %>
          </div>
          <div data-controller="cart">
            <button data-action="click->cart#open" class="relative hover:text-black transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.5 6h11M10 21a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z" />
              </svg>
            </button>
            <%= render "carts/drawer" %>
          </div>
        </div>
      </div>
    </div>

    <!-- ================= MOBILE MENU ================= -->
    <div data-mobile-menu-target="panel" class="hidden fixed inset-0 bg-white z-50 flex flex-col h-screen overflow-hidden">
      <!-- Top bar -->
      <div class="flex items-center justify-between p-5 border-b border-black/[0.06]">
        <span class="text-lg font-bold uppercase text-black tracking-tight">Hypee</span>
        <button data-action="click->mobile-menu#toggle" class="w-10 h-10 flex items-center justify-center text-black">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <!-- Links -->
      <div class="flex-1 overflow-y-auto">
        <div class="p-6 space-y-1">
          <p class="text-[9px] uppercase tracking-[0.3em] text-gray-400 mb-5">Shop</p>
          <%= link_to "New Arrivals", products_path(filter: "new"),
                      data: { turbo: false, action: "click->mobile-menu#toggle" },
                      class: "block py-3 text-sm uppercase tracking-[0.2em] text-black/70 hover:text-black transition" %>
          <%= link_to "Men", products_path(filter: "men"),
                      data: { action: "click->mobile-menu#toggle" },
                      class: "block py-3 text-sm uppercase tracking-[0.2em] text-black/70 hover:text-black transition" %>
          <%= link_to "Women", products_path(filter: "women"),
                      data: { action: "click->mobile-menu#toggle" },
                      class: "block py-3 text-sm uppercase tracking-[0.2em] text-black/70 hover:text-black transition" %>
          <%= link_to "Accessories", products_path(filter: "accessories"),
                      data: { action: "click->mobile-menu#toggle" },
                      class: "block py-3 text-sm uppercase tracking-[0.2em] text-black/70 hover:text-black transition" %>
          <%= link_to "All Products", products_path,
                      data: { action: "click->mobile-menu#toggle" },
                      class: "block py-3 text-sm uppercase tracking-[0.2em] text-black/70 hover:text-black transition" %>
        </div>

        <div class="px-6 py-4 border-t border-black/[0.06]">
          <p class="text-[9px] uppercase tracking-[0.3em] text-gray-400 mb-5">Support</p>
          <%= link_to "Contact", contact_path,
                      data: { action: "click->mobile-menu#toggle" },
                      class: "block py-3 text-sm uppercase tracking-[0.2em] text-black/70 hover:text-black transition" %>
          <%= link_to "Shipping", shipping_path,
                      data: { action: "click->mobile-menu#toggle" },
                      class: "block py-3 text-sm uppercase tracking-[0.2em] text-black/70 hover:text-black transition" %>
          <%= link_to "FAQ", faq_path,
                      data: { action: "click->mobile-menu#toggle" },
                      class: "block py-3 text-sm uppercase tracking-[0.2em] text-black/70 hover:text-black transition" %>
        </div>

        <div class="px-6 py-4 border-t border-black/[0.06]">
          <p class="text-[9px] uppercase tracking-[0.3em] text-gray-400 mb-5">Account</p>
          <% if user_signed_in? %>
            <%= link_to "My Orders", orders_path,
                        data: { action: "click->mobile-menu#toggle" },
                        class: "block py-3 text-sm uppercase tracking-[0.2em] text-black/70 hover:text-black transition" %>
            <%= link_to "My Addresses", addresses_path,
                        data: { action: "click->mobile-menu#toggle" },
                        class: "block py-3 text-sm uppercase tracking-[0.2em] text-black/70 hover:text-black transition" %>
            <%= button_to "Logout", destroy_user_session_path, method: :delete,
                           form: { data: { turbo: false } },
                           class: "block w-full text-left py-3 text-sm uppercase tracking-[0.2em] text-red-500 hover:text-red-700 transition bg-transparent border-none cursor-pointer p-0" %>
          <% else %>
            <%= link_to "Sign In", new_user_session_path,
                        data: { action: "click->mobile-menu#toggle" },
                        class: "block py-3 text-sm uppercase tracking-[0.2em] text-black/70 hover:text-black transition" %>
            <%= link_to "Create Account", new_user_registration_path,
                        data: { action: "click->mobile-menu#toggle" },
                        class: "block py-3 text-sm uppercase tracking-[0.2em] text-black/70 hover:text-black transition" %>
          <% end %>
        </div>
      </div>

      <!-- Bottom -->
      <div class="p-6 border-t border-black/[0.06]">
        <p class="text-[9px] uppercase tracking-[0.3em] text-gray-400">
          &copy; <%= Time.current.year %> Hypee
        </p>
      </div>
    </div>
  </header>

  <!-- ================= MOBILE BOTTOM NAV ================= -->
  <div class="md:hidden fixed bottom-0 left-0 right-0 w-full bg-white border-t border-black/[0.06] z-40 pb-[env(safe-area-inset-bottom)]">
    <div class="flex items-center justify-around px-2 py-2">
      <!-- Home -->
      <%= link_to root_path, class: "flex flex-col items-center gap-0.5 text-black/40 hover:text-black transition py-1 px-3" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-6.046a.75.75 0 011.092.017l8.954 6.046M3.75 20.25h16.5"/>
        </svg>
        <span class="text-[8px] uppercase tracking-[0.15em]">Home</span>
      <% end %>
      <!-- Search -->
      <div data-controller="search-modal">
        <button data-action="click->search-modal#open" class="flex flex-col items-center gap-0.5 text-black/40 hover:text-black transition py-1 px-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
          </svg>
          <span class="text-[8px] uppercase tracking-[0.15em]">Search</span>
        </button>
        <%= render "shared/search_modal" %>
      </div>
      <!-- Cart -->
      <div data-controller="cart">
        <button data-action="click->cart#open" class="flex flex-col items-center gap-0.5 text-black/40 hover:text-black transition py-1 px-3 relative">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a2.25 2.25 0 00-2.25-2.25H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25h3M16.5 10.5H21m0 0l-3-3m3 3l-3 3"/>
          </svg>
          <span class="text-[8px] uppercase tracking-[0.15em]">Cart</span>
        </button>
        <%= render "carts/drawer" %>
      </div>
      <!-- Account -->
      <% if user_signed_in? %>
        <%= link_to orders_path, class: "flex flex-col items-center gap-0.5 text-black/40 hover:text-black transition py-1 px-3" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/>
          </svg>
          <span class="text-[8px] uppercase tracking-[0.15em]">Orders</span>
        <% end %>
      <% else %>
        <%= link_to new_user_session_path, class: "flex flex-col items-center gap-0.5 text-black/40 hover:text-black transition py-1 px-3" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/>
          </svg>
          <span class="text-[8px] uppercase tracking-[0.15em]">Login</span>
        <% end %>
      <% end %>
    </div>
  </div>

<% end %>