<% unless current_user&.admin? %>

  <header class="fixed top-0 left-0 right-0 z-50 text-black" data-controller="mobile-menu">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-8 py-5">
      <!-- ================= DESKTOP ================= -->
      <div class="hidden md:flex items-center justify-between">
        <!-- Logo -->
        <%= link_to root_path, class: "text-2xl font-bold uppercase tracking-tight text-black" do %>
          Hypee
        <% end %>
        <!-- Nav -->
        <nav class="flex items-center gap-6 text-xs uppercase tracking-widest">
          <% base = "text-black/70 hover:text-black transition" %>
          <% active = "text-black border-b border-black pb-1" %>

          <%= link_to "NEW ARRIVALS", products_path(filter: "new"),
                      data: { turbo: false },
                      class: "#{params[:filter] == 'new' ? active : base}" %>

          <%= link_to "MEN", products_path(filter: "men"),
                      class: "#{params[:filter] == 'men' ? active : base}" %>

          <%= link_to "WOMEN", products_path(filter: "women"),
                      class: "#{params[:filter] == 'women' ? active : base}" %>

          <%= link_to "ACCESSORIES", products_path(filter: "accessories"),
                      class: "#{params[:filter] == 'accessories' ? active : base}" %>
        </nav>
        <div data-controller="cart" class="flex items-center gap-5 text-black/70">
          <!-- Search -->
          <!-- Search Modal Trigger -->
          <div data-controller="search-modal">
            <button data-action="click->search-modal#open" class="hover:text-black transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.35-5.15a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </button>

            <!-- Overlay -->
            <div data-search-modal-target="overlay"
                 data-action="click->search-modal#close"
                 class="fixed inset-0 bg-black/20 backdrop-blur-sm z-[60] hidden opacity-0 transition-opacity duration-200"></div>

            <!-- Modal -->
            <div data-search-modal-target="modal"
                 class="fixed top-0 left-0 right-0 z-[70] hidden opacity-0 -translate-y-2 transition-all duration-200">
              <div class="bg-white border-b border-black/[0.06] shadow-lg">
                <div class="max-w-[1440px] mx-auto px-4 sm:px-8 py-5 flex items-center gap-4">
                  <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.35-5.15a7 7 0 11-14 0 7 7 0 0114 0z"/>
                  </svg>

                  <%= form_with url: search_path, method: :get, class: "flex-1", data: { turbo: false } do |f| %>
                    <%= f.text_field :q,
                                     value: params[:q],
                                     placeholder: "Search products...",
                                     autocomplete: "off",
                                     data: {
                                       search_modal_target: "input",
                                       action: "keydown->search-modal#submitOnEnter"
                                     },
                                     class: "w-full bg-transparent text-sm text-black placeholder-gray-300 focus:outline-none uppercase tracking-widest" %>
                  <% end %>

                  <button data-action="click->search-modal#close" class="text-[10px] uppercase tracking-[0.2em] text-gray-400 hover:text-black transition">
                    Close
                  </button>
                </div>
              </div>
            </div>
          </div>
          <!-- Cart -->
          <button data-action="click->cart#open" class="relative hover:text-black transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.5 6h11M10 21a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z" />
            </svg>
          </button>
          <!-- CART DRAWER -->
          <%= render "carts/drawer" %>
          <!-- Auth Dropdown -->
          <div data-controller="dropdown" class="relative">
            <% if user_signed_in? %>
              <button data-action="click->dropdown#toggle" class="text-xs uppercase tracking-widest hover:text-black transition text-black/70">
                Account
              </button>
              <div data-dropdown-target="menu" class="hidden absolute right-0 mt-4 w-48 bg-white border border-black/10 shadow-lg">
                <div class="py-2 text-xs uppercase tracking-widest">
                  <div class="px-4 py-3 text-gray-500 text-[10px] break-all">
                    <%= current_user.email %>
                  </div>
                  <%= link_to "Profile", "#", class: "block px-4 py-3 text-gray-600 hover:text-black hover:bg-gray-50" %>
                  <%= link_to "Orders", orders_path, class: "block px-4 py-3 text-gray-600 hover:text-black hover:bg-gray-50" %>
                  <div class="border-t border-black/10 my-1"></div>
                  <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "w-full text-left px-4 py-3 text-gray-600 hover:text-black hover:bg-gray-50 uppercase" %>
                </div>
              </div>
            <% else %>
              <%= link_to "Login", new_user_session_path, class: "text-xs uppercase tracking-widest hover:text-black transition text-black/70" %>
            <% end %>
          </div>
        </div>
      </div>
      <!-- ================= MOBILE ================= -->
      <div class="flex md:hidden items-center justify-between text-black/70">
        <!-- LEFT: Search -->
        <button class="hover:text-black transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1-5.15a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
        <!-- CENTER: Logo -->
        <%= link_to root_path, class: "text-lg font-bold uppercase tracking-tight text-black" do %>
          Hypee
        <% end %>
        <!-- RIGHT: Menu -->
        <button data-action="click->mobile-menu#toggle" class="hover:text-black transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
    <!-- ================= MOBILE MENU ================= -->
    <div data-mobile-menu-target="panel" class="hidden fixed inset-0 bg-white z-50 flex flex-col h-screen overflow-hidden">
      <!-- Top bar -->
      <div class="flex items-center justify-between p-6 border-b border-black/10">
        <span class="text-lg font-bold uppercase text-black">Menu</span>
        <button data-action="click->mobile-menu#toggle" class="text-xl text-black">
          ✕
        </button>
      </div>
      <!-- Links -->
      <div class="flex-1 overflow-y-auto p-6 flex flex-col gap-6 text-sm uppercase tracking-widest">
        <%= link_to "Shop", "#", class: "text-gray-500 hover:text-black" %>
        <%= link_to "New Arrivals", "#", class: "text-gray-500 hover:text-black" %>
        <%= link_to "Men", "#", class: "text-gray-500 hover:text-black" %>
        <%= link_to "Women", "#", class: "text-gray-500 hover:text-black" %>
        <%= link_to "Collections", "#", class: "text-gray-500 hover:text-black" %>
        <div class="border-t border-black/10 my-4"></div>
        <% if user_signed_in? %>
          <%= link_to "Profile", "#", class: "text-gray-500 hover:text-black" %>
          <%= link_to "Orders", "#", class: "text-gray-500 hover:text-black" %>
        <% else %>
          <%= link_to "Login", new_user_session_path, class: "text-gray-500 hover:text-black" %>
        <% end %>
      </div>
    </div>
  </header>

  <!-- ================= MOBILE BOTTOM NAV ================= -->
  <div class="md:hidden fixed bottom-0 left-0 w-full bg-white border-t border-black/10 z-40">
    <div class="flex items-center justify-between px-8 py-3 text-gray-400">
      <!-- Home -->
      <button class="flex flex-col items-center gap-1 text-black">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M3 10l9-7 9 7v10a1 1 0 01-1 1h-5v-6H9v6H4a1 1 0 01-1-1V10z"/>
        </svg>
      </button>
      <!-- Search -->
      <!-- Search -->
      <div data-controller="search-modal">
        <button data-action="click->search-modal#open" class="flex flex-col items-center gap-1 hover:text-black transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="16.65" y1="16.65" x2="21" y2="21"></line>
          </svg>
        </button>

        <!-- Overlay -->
        <div data-search-modal-target="overlay"
             data-action="click->search-modal#close"
             class="fixed inset-0 bg-black/20 backdrop-blur-sm z-[60] hidden opacity-0 transition-opacity duration-200"></div>

        <!-- Modal -->
        <div data-search-modal-target="modal"
             class="fixed top-0 left-0 right-0 z-[70] hidden opacity-0 -translate-y-2 transition-all duration-200">
          <div class="bg-white border-b border-black/[0.06] shadow-lg">
            <div class="max-w-[1440px] mx-auto px-4 sm:px-8 py-5 flex items-center gap-4">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.35-5.15a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>

              <%= form_with url: search_path, method: :get, class: "flex-1", data: { turbo: false } do |f| %>
                <%= f.text_field :q,
                                 value: params[:q],
                                 placeholder: "Search...",
                                 autocomplete: "off",
                                 data: {
                                   search_modal_target: "input",
                                   action: "keydown->search-modal#submitOnEnter"
                                 },
                                 class: "w-full bg-transparent text-sm text-black placeholder-gray-300 focus:outline-none uppercase tracking-widest" %>
              <% end %>

              <button data-action="click->search-modal#close" class="text-[10px] uppercase tracking-[0.2em] text-gray-400 hover:text-black transition">
                ✕
              </button>
            </div>
          </div>
        </div>
      </div>
      <!-- Wishlist -->
      <button class="flex flex-col items-center gap-1 hover:text-black transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
          <path d="M20.8 4.6c-1.5-1.4-3.8-1.4-5.3 0L12 8l-3.5-3.4c-1.5-1.4-3.8-1.4-5.3 0-1.6 1.5-1.6 4 0 5.5L12 21l8.8-10.9c1.6-1.5 1.6-4 0-5.5z"/>
        </svg>
      </button>
      <!-- Profile -->
      <button class="flex flex-col items-center gap-1 hover:text-black transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
          <circle cx="12" cy="8" r="4"></circle>
          <path d="M4 20c0-4 4-6 8-6s8 2 8 6"></path>
        </svg>
      </button>
    </div>
  </div>

<% end %>