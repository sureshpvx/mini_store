<footer class="bg-black text-white border-t border-white/5">

  <div class="max-w-7xl mx-auto px-4 sm:px-8 py-16 grid grid-cols-1 md:grid-cols-4 gap-10">

    <!-- Brand -->
    <div>
      <h3 class="text-xl font-bold tracking-tight mb-6 uppercase">
        Hypee
      </h3>

      <p class="text-gray-500 text-sm lowercase">
        define your edge.
      </p>
    </div>

    <!-- Links -->
    <div class="flex flex-col gap-3 text-sm">
      <%= link_to "Shop", "#", class: "text-gray-500 hover:text-white transition" %>
      <%= link_to "Collections", "#", class: "text-gray-500 hover:text-white transition" %>
      <%= link_to "Journal", "#", class: "text-gray-500 hover:text-white transition" %>
    </div>

    <div class="flex flex-col gap-3 text-sm">
      <%= link_to "Contact", "#", class: "text-gray-500 hover:text-white transition" %>
      <%= link_to "Shipping", "#", class: "text-gray-500 hover:text-white transition" %>
      <%= link_to "Returns", "#", class: "text-gray-500 hover:text-white transition" %>
    </div>

    <div class="flex flex-col gap-3 text-sm">
      <%= link_to "Privacy", "#", class: "text-gray-500 hover:text-white transition" %>
      <%= link_to "Terms", "#", class: "text-gray-500 hover:text-white transition" %>
    </div>

  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/5 py-6 px-4 sm:px-8 flex flex-col md:flex-row justify-between items-center text-gray-500 text-xs">

    <p>© <%= Time.current.year %> Hypee. All rights reserved.</p>

    <div class="flex gap-4 mt-3 md:mt-0">
      <a href="#" class="hover:text-white transition">IG</a>
      <a href="#" class="hover:text-white transition">TW</a>
      <a href="#" class="hover:text-white transition">PN</a>
    </div>

  </div>

</footer>