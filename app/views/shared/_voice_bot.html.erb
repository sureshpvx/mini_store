<!-- Voice Bot Widget — Available on all pages -->
<div data-controller="voice-bot">
  <!-- Floating button -->
  <button
    data-action="click->voice-bot#toggleWidget"
    class="fixed bottom-4 right-4 sm:bottom-6 sm:right-6 z-50 w-14 h-14 sm:w-16 sm:h-16 bg-white hover:bg-gray-100 text-black rounded-full shadow-[0_4px_24px_rgba(0,0,0,0.25)] hover:shadow-[0_6px_32px_rgba(0,0,0,0.35)] transition-all duration-300 flex items-center justify-center group ring-1 ring-black/10">

    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="black" class="w-7 h-7 sm:w-8 sm:h-8">
      <rect x="7" y="1" width="10" height="13" rx="5" ry="5"/>
      <path d="M3 12c0 5 4.5 9 9 9s9-4 9-9" stroke="black" stroke-width="2.5" stroke-linecap="round" fill="none"/>
      <line x1="12" y1="21" x2="12" y2="24" stroke="black" stroke-width="2.5" stroke-linecap="round"/>
      <line x1="7" y1="24" x2="17" y2="24" stroke="black" stroke-width="2.5" stroke-linecap="round"/>
    </svg>

    <span class="absolute -top-1 -right-1 w-4 h-4 bg-green-500 rounded-full border-2 border-white animate-pulse"></span>
  </button>

  <!-- Chat widget -->
  <div
    data-voice-bot-target="container"
    class="hidden fixed bottom-20 sm:bottom-24 right-2 sm:right-6 z-50
           w-[calc(100vw-1rem)] sm:w-96 max-w-md
           bg-white rounded-2xl shadow-2xl border border-gray-100
           flex-col overflow-hidden
           max-h-[70vh] sm:max-h-[80vh]">

    <!-- Header -->
    <div class="bg-black px-4 sm:px-5 py-3 sm:py-4 shrink-0">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 sm:w-10 sm:h-10 bg-white/20 rounded-full flex items-center justify-center text-lg sm:text-xl">🤖</div>
        <div class="flex-1 min-w-0">
          <h3 class="text-white font-semibold text-sm">HYPE Assistant</h3>
          <p class="text-white/70 text-xs truncate">I can add to cart, search, & more!</p>
        </div>
        <button
          data-action="click->voice-bot#toggleWidget"
          class="w-8 h-8 flex items-center justify-center text-white/60 hover:text-white transition-colors rounded-full hover:bg-white/10">
          ✕
        </button>
      </div>
    </div>

    <!-- Status -->
    <div class="px-3 sm:px-4 py-2 bg-gray-50 border-b border-gray-100 shrink-0">
      <div data-voice-bot-target="status" class="px-3 sm:px-4 py-2 rounded-xl text-xs sm:text-sm font-medium bg-gray-100 text-gray-600">
        Ready
      </div>
    </div>

    <!-- Conversation -->
    <div
      data-voice-bot-target="conversation"
      class="flex-1 overflow-y-auto p-3 sm:p-4 space-y-3 bg-gray-50 min-h-0"
      style="max-height: calc(70vh - 180px);">
      <div class="p-3 rounded-xl text-sm bg-gray-200 text-gray-900 mr-6 sm:mr-8 break-words">
        <span class="font-bold">Bot:</span> Hi! I'm your HYPE assistant. I can:
        <br>🛒 <strong>Add items to your cart</strong>
        <br>🔍 <strong>Search & list products</strong>
        <br>📦 <strong>Check your orders</strong>
        <br>💬 <strong>Answer any questions</strong>
        <br><br>Try: "Show me trending products" or "Add hoodie to cart"
      </div>
    </div>

    <!-- Input area -->
    <div class="p-3 sm:p-4 bg-white border-t border-gray-100 shrink-0">
      <form data-action="submit->voice-bot#sendMessage" class="flex gap-2">
        <button
          type="button"
          data-voice-bot-target="micBtn"
          data-action="click->voice-bot#toggleMic"
          class="w-9 h-9 sm:w-10 sm:h-10 bg-black hover:bg-black/80 text-white rounded-full flex items-center justify-center transition-colors shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-4 h-4 sm:w-5 sm:h-5">
            <rect x="8" y="2" width="8" height="10" rx="4" ry="4"/>
            <path d="M4 12c0 4.4 3.6 8 8 8s8-3.6 8-8" stroke="white" stroke-width="2" stroke-linecap="round" fill="none"/>
            <line x1="12" y1="20" x2="12" y2="23" stroke="white" stroke-width="2" stroke-linecap="round"/>
            <line x1="8" y1="23" x2="16" y2="23" stroke="white" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
        <input
          type="text"
          data-voice-bot-target="input"
          placeholder="Try: add hoodie to cart..."
          class="flex-1 min-w-0 px-3 sm:px-4 py-2 sm:py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent">
        <button
          type="submit"
          class="px-3 sm:px-4 py-2 sm:py-2.5 bg-black hover:bg-black/80 text-white rounded-xl text-sm font-medium transition-colors shrink-0">
          Send
        </button>
      </form>
    </div>
  </div>
</div>