<!-- Voice Bot Widget - Place on any page -->
<div data-controller="voice-bot">
  <!-- Floating button -->
  <button 
    data-action="click->voice-bot#toggleWidget"
    class="fixed bottom-6 right-6 z-40 w-14 h-14 bg-blue-600 hover:bg-blue-700 text-white rounded-full shadow-lg hover:shadow-xl transition-all duration-300 flex items-center justify-center text-2xl group">
    <span class="group-hover:scale-110 transition-transform">🎙️</span>
    <span class="absolute -top-1 -right-1 w-4 h-4 bg-green-400 rounded-full border-2 border-white"></span>
  </button>

  <!-- Chat widget -->
  <div 
    data-voice-bot-target="container"
    class="hidden fixed bottom-24 right-6 z-40 w-96 max-w-[calc(100vw-3rem)] bg-white rounded-2xl shadow-2xl border border-gray-100 flex-col overflow-hidden max-h-[80vh]">
    
    <!-- Header -->
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-5 py-4 shrink-0">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center text-xl">🤖</div>
        <div>
          <h3 class="text-white font-semibold text-sm">AI Assistant</h3>
          <p class="text-blue-100 text-xs">Ask me anything about HYPE</p>
        </div>
      </div>
    </div>

    <!-- Status -->
    <div class="px-4 py-2 bg-gray-50 border-b border-gray-100 shrink-0">
      <div data-voice-bot-target="status" class="px-4 py-2 rounded-xl text-sm font-medium bg-gray-100 text-gray-600">
        Ready
      </div>
    </div>

    <!-- Conversation -->
    <div 
      data-voice-bot-target="conversation"
      class="flex-1 overflow-y-auto p-4 space-y-3 bg-gray-50 min-h-0">
      <div class="p-3 rounded-xl text-sm bg-gray-200 text-gray-900 mr-8 break-words">
        <span class="font-bold">Bot:</span> Hi! I'm your HYPE assistant. Ask me about products, sizing, orders, or anything else!
      </div>
    </div>

    <!-- Input area -->
    <div class="p-4 bg-white border-t border-gray-100 shrink-0">
      <form data-action="submit->voice-bot#sendMessage" class="flex gap-2">
        <button 
          type="button"
          data-voice-bot-target="micBtn"
          data-action="click->voice-bot#toggleMic"
          class="w-10 h-10 bg-blue-500 hover:bg-blue-600 text-white rounded-full flex items-center justify-center transition-colors shrink-0">
          🎤
        </button>
        <input 
          type="text"
          data-voice-bot-target="input"
          placeholder="Type your message..."
          class="flex-1 px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
        <button 
          type="submit"
          class="px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-xl text-sm font-medium transition-colors">
          Send
        </button>
      </form>
    </div>
  </div>
</div>
