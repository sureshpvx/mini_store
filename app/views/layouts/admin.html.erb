<!DOCTYPE html>
<html>
<head>
  <title>Hypee Admin</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= favicon_link_tag 'favicon.ico' if Rails.root.join('app/assets/images/favicon.ico').exist? %>
  <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2">

  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>

<body class="bg-white text-black min-h-screen antialiased">

<!-- Flash container with ID for Turbo Streams -->
<div id="flash-container" class="fixed top-6 right-6 z-[9999] space-y-3">
  <% flash.each do |type, message| %>
    <%= render "shared/flash_message", type: type, message: message, timeout: 4000 %>
  <% end %>
</div>

<%= yield %>

</body>
</html>