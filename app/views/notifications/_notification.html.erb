<%# app/views/notifications/_notification.html.erb %>
<% url = local_assigns[:navigate_url] || notification.url %>

<div id="<%= dom_id(notification) %>"
     class="group flex items-start gap-4 px-4 py-4 <%= notification.unread? ? 'bg-gray-50/60' : 'bg-white' %> hover:bg-gray-50 transition cursor-pointer"
     data-notification-dropdown-target="<%= local_assigns[:in_dropdown] ? 'item' : '' %>">

  <!-- Icon -->
  <div class="flex-shrink-0 w-9 h-9 border border-black/[0.06] flex items-center justify-center mt-0.5
              <%= notification.unread? ? 'bg-black text-white border-black' : 'bg-white text-black/40' %>">
    <% case notification.kind %>
    <% when 'order_placed', 'payment_confirmed' %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
      </svg>
    <% when 'order_shipped' %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H21M3.375 14.25h3.375m0 0V11.25m0 3h7.5m-7.5 0V6.75L12 3l5.625 3.75v4.5"/>
      </svg>
    <% when 'order_delivered' %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"/>
      </svg>
    <% when 'order_cancelled' %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    <% when 'payment_failed' %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
      </svg>
    <% else %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/>
      </svg>
    <% end %>
  </div>

  <!-- Content -->
  <div class="flex-1 min-w-0">
    <div class="flex items-start justify-between gap-3">
      <p class="text-xs <%= notification.unread? ? 'font-medium text-black' : 'font-light text-black/70' %> uppercase tracking-[0.12em] leading-tight">
        <%= notification.title %>
      </p>
      <% if notification.unread? %>
        <span class="flex-shrink-0 w-2 h-2 bg-black rounded-full mt-1.5"></span>
      <% end %>
    </div>
    <p class="text-[11px] text-gray-500 leading-relaxed mt-1 font-light line-clamp-2">
      <%= notification.message %>
    </p>
    <p class="text-[9px] uppercase tracking-[0.15em] text-gray-400 mt-2">
      <%= time_ago_in_words(notification.created_at) %> ago
    </p>
  </div>
</div>
