<% unread = current_user.notifications.unread.count %>

<%# Replace the entire row (wrapper + inner notification) on the index page %>
<%= turbo_stream.replace "notification-row-#{@notification.id}" do %>
  <%= render "notifications/notification_row", notification: @notification %>
<% end %>

<%# Also replace the inner notification partial (for the desktop dropdown) %>
<%= turbo_stream.replace dom_id(@notification) do %>
  <%= render "notifications/notification", notification: @notification %>
<% end %>

<%# Update the notifications page header (unread count + Mark All button) %>
<%= turbo_stream.replace "notifications-header" do %>
  <div id="notifications-header" class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10 sm:mb-16">
    <div>
      <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-3">Account</p>
      <h1 class="text-2xl sm:text-3xl font-light uppercase tracking-[0.1em] text-black">
        Notifications
      </h1>
      <% if unread > 0 %>
        <p class="text-gray-400 text-sm font-light mt-2">
          <%= unread %> unread notification<%= unread == 1 ? '' : 's' %>
        </p>
      <% end %>
    </div>

    <% if unread > 0 %>
      <%= button_to "Mark All as Read",
                     mark_all_as_read_notifications_path,
                     method: :patch,
                     class: "border border-black/30 px-6 py-3 text-[11px] uppercase tracking-[0.2em] text-black hover:bg-black hover:text-white transition duration-300 bg-transparent cursor-pointer font-light" %>
    <% end %>
  </div>
<% end %>

<%# Desktop header badge %>
<%= turbo_stream.replace "notification-badge" do %>
  <span id="notification-badge" class="<%= unread > 0 ? '' : 'hidden' %> absolute -top-1 -right-1 w-4 h-4 bg-black text-white text-[8px] flex items-center justify-center rounded-full">
    <%= unread %>
  </span>
<% end %>

<%# Mobile header badge %>
<%= turbo_stream.replace "mobile-notification-badge" do %>
  <span id="mobile-notification-badge" class="<%= unread > 0 ? '' : 'hidden' %> absolute -top-1 -right-1 w-2 h-2 bg-black rounded-full"></span>
<% end %>

<%# Bottom nav badge %>
<%= turbo_stream.replace "bottomnav-notification-badge" do %>
  <span id="bottomnav-notification-badge" class="<%= unread > 0 ? '' : 'hidden' %> absolute top-0 right-2 w-2 h-2 bg-black rounded-full"></span>
<% end %>
