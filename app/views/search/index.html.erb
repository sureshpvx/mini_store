<section class="pt-32 pb-24 px-4 sm:px-8 bg-white min-h-screen">
  <div class="max-w-[1440px] mx-auto">

    <!-- Search Header -->
    <div class="mb-12 sm:mb-16">
      <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-3">Search</p>
      <h1 class="text-2xl sm:text-3xl font-light uppercase tracking-[0.2em] text-black">
        <% if @query.present? %>
          Results for "<%= @query %>"
        <% else %>
          Search Products
        <% end %>
      </h1>

      <!-- Search Input -->
      <%= form_with url: search_path, method: :get, class: "mt-8 flex w-full max-w-md gap-0", data: { turbo: false } do |f| %>
        <%= f.text_field :q, value: @query, placeholder: "Search products...",
                         class: "flex-1 bg-white border border-black/10 px-4 py-3 text-sm text-black placeholder-gray-300 focus:outline-none focus:border-black/30" %>
        <%= f.submit "Search",
                     class: "bg-black text-white px-6 py-3 text-xs uppercase tracking-widest hover:bg-gray-800 transition cursor-pointer" %>
      <% end %>

      <% if @query.present? %>
        <p class="text-gray-400 text-[10px] uppercase tracking-[0.2em] mt-4">
          <%= @products.count %> items found
        </p>
      <% end %>
    </div>

    <% if @products.any? %>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
        <% @products.each do |product| %>
          <%= link_to product_path(product), class: "group flex flex-col" do %>

            <div class="relative aspect-[3/4] bg-gray-50 overflow-hidden mb-4 flex items-center justify-center border border-black/[0.04]">
              <% if product.images.attached? %>
                <%= image_tag product.images.first, loading: "lazy",
                              class: "w-full h-full object-contain p-4 sm:p-8 group-hover:scale-105 transition-transform duration-700" %>
              <% else %>
                <div class="text-gray-300 uppercase text-[8px] tracking-widest">No Image</div>
              <% end %>
            </div>

            <div class="flex justify-between items-baseline gap-2">
              <h3 class="uppercase text-[10px] sm:text-[11px] tracking-[0.2em] font-light text-black group-hover:text-gray-500 transition truncate">
                <%= product.name %>
              </h3>
              <span class="text-[10px] text-gray-400 font-light whitespace-nowrap">
                <%= number_to_currency(product.price, unit: "₹", precision: 0) %>
              </span>
            </div>

          <% end %>
        <% end %>
      </div>

    <% elsif @query.present? %>

      <div class="flex flex-col items-center justify-center py-32 border border-dashed border-black/[0.06]">
        <p class="text-gray-400 text-xs uppercase tracking-[0.35em] mb-6 font-light">
          No products match "<%= @query %>"
        </p>
        <%= link_to "Explore Collection", products_path,
                    class: "text-[11px] text-black border border-black/30 px-8 py-3 uppercase tracking-[0.2em] hover:bg-black hover:text-white transition-all duration-300" %>
      </div>

    <% end %>

  </div>
</section>