<!DOCTYPE html>
<html>
<head>
  <title>AI Voice Assistant</title>
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <style>
    * { box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f5f5f7;
      margin: 0;
      padding: 20px;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }
    .voice-container {
      background: white;
      border-radius: 20px;
      padding: 40px;
      width: 100%;
      max-width: 500px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.1);
      text-align: center;
    }
    h1 { margin: 0 0 10px; font-size: 24px; color: #1d1d1f; }
    .subtitle { color: #86868b; margin-bottom: 30px; font-size: 14px; }
    #status {
      padding: 15px 20px;
      border-radius: 12px;
      margin: 20px 0;
      font-size: 14px;
      font-weight: 500;
      transition: all 0.3s;
    }
    .idle { background: #f5f5f7; color: #1d1d1f; }
    .listening { background: #ff3b30; color: white; }
    .thinking { background: #ff9500; color: white; }
    .speaking { background: #34c759; color: white; }
    .mic-btn {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      border: none;
      background: #007aff;
      color: white;
      font-size: 32px;
      cursor: pointer;
      transition: all 0.2s;
      margin: 20px 0;
    }
    .mic-btn:hover { transform: scale(1.05); }
    .mic-btn:active { transform: scale(0.95); }
    .mic-btn.recording { background: #ff3b30; animation: pulse 1.5s infinite; }
    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 rgba(255,59,48,0.4); }
      70% { box-shadow: 0 0 0 20px rgba(255,59,48,0); }
      100% { box-shadow: 0 0 0 0 rgba(255,59,48,0); }
    }
    .text-input-row {
      display: flex;
      gap: 10px;
      margin-top: 20px;
    }
    .text-input {
      flex: 1;
      padding: 12px 16px;
      border: 1px solid #d2d2d7;
      border-radius: 12px;
      font-size: 14px;
      outline: none;
    }
    .text-input:focus { border-color: #007aff; }
    .send-btn {
      padding: 12px 20px;
      background: #007aff;
      color: white;
      border: none;
      border-radius: 12px;
      font-size: 14px;
      cursor: pointer;
    }
    .send-btn:hover { background: #0051d5; }
    #conversation {
      text-align: left;
      max-height: 300px;
      overflow-y: auto;
      margin-top: 20px;
      padding: 15px;
      background: #f5f5f7;
      border-radius: 12px;
    }
    .msg { margin: 8px 0; padding: 10px 14px; border-radius: 12px; font-size: 14px; line-height: 1.4; }
    .user-msg { background: #007aff; color: white; margin-left: 40px; }
    .bot-msg { background: #e5e5ea; color: #1d1d1f; margin-right: 40px; }
    .error-msg { background: #ff3b30; color: white; text-align: center; }
    .divider {
      margin: 20px 0;
      border-top: 1px solid #d2d2d7;
      position: relative;
    }
    .divider span {
      position: absolute;
      top: -10px;
      left: 50%;
      transform: translateX(-50%);
      background: white;
      padding: 0 10px;
      color: #86868b;
      font-size: 12px;
    }
  </style>
</head>
<body>
  <div class="voice-container">
    <h1>🎙️ AI Voice Assistant</h1>
    <p class="subtitle">Type a message or tap the mic to talk</p>

    <div id="status" class="idle">Ready</div>

    <button id="micBtn" class="mic-btn">🎤</button>

    <div class="divider"><span>OR</span></div>

    <div class="text-input-row">
      <input type="text" id="textInput" class="text-input" placeholder="Type your message..." />
      <button id="sendBtn" class="send-btn">Send</button>
    </div>

    <div id="conversation"></div>
  </div>

  <script>
    const micBtn = document.getElementById('micBtn');
    const sendBtn = document.getElementById('sendBtn');
    const textInput = document.getElementById('textInput');
    const statusDiv = document.getElementById('status');
    const convDiv = document.getElementById('conversation');
    const csrfToken = document.querySelector('meta[name="csrf-token"]').content;

    let recognition;
    let synthesis = window.speechSynthesis;
    let isRecording = false;

    // Text input handler
    sendBtn.addEventListener('click', () => {
      const text = textInput.value.trim();
      if (!text) return;
      addMessage('You', text, 'user-msg');
      textInput.value = '';
      sendToAI(text);
    });

    textInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') sendBtn.click();
    });

    // Voice handler
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

    micBtn.addEventListener('click', toggleRecording);

    function toggleRecording() {
      if (!SpeechRecognition) {
        statusDiv.textContent = 'Voice not supported. Use text input below.';
        return;
      }
      if (isRecording) {
        stopRecording();
      } else {
        startRecording();
      }
    }

    function startRecording() {
      recognition = new SpeechRecognition();
      recognition.continuous = false;
      recognition.interimResults = false;
      recognition.lang = 'en-IN';

      recognition.onstart = () => {
        isRecording = true;
        micBtn.classList.add('recording');
        statusDiv.className = 'listening';
        statusDiv.textContent = '🎤 Listening... Speak now';
      };

      recognition.onresult = (event) => {
        const transcript = event.results[0][0].transcript;
        addMessage('You', transcript, 'user-msg');
        stopRecording();
        sendToAI(transcript);
      };

      recognition.onerror = (event) => {
        console.error('Speech error:', event.error);
        let msg = 'Voice error: ' + event.error;
        if (event.error === 'network') {
          msg = 'Voice requires internet. Use text input below.';
        } else if (event.error === 'not-allowed') {
          msg = 'Microphone permission denied.';
        }
        statusDiv.textContent = msg + ' Tap mic to retry.';
        statusDiv.className = 'idle';
        stopRecording();
      };

      recognition.onend = () => {
        if (isRecording) stopRecording();
      };

      recognition.start();
    }

    function stopRecording() {
      isRecording = false;
      micBtn.classList.remove('recording');
      if (recognition) recognition.stop();
    }

    function addMessage(speaker, text, className) {
      const div = document.createElement('div');
      div.className = 'msg ' + className;
      div.innerHTML = '<strong>' + speaker + ':</strong> ' + text;
      convDiv.appendChild(div);
      convDiv.scrollTop = convDiv.scrollHeight;
    }

    function sendToAI(text) {
      statusDiv.className = 'thinking';
      statusDiv.textContent = '🤖 AI is thinking...';

      fetch('/voice/message', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken
        },
        body: JSON.stringify({ message: text })
      })
      .then(response => {
        if (!response.ok) throw new Error('Server error: ' + response.status);
        return response.json();
      })
      .then(data => {
        if (data.error) throw new Error(data.error);
        const reply = data.reply;
        addMessage('Bot', reply, 'bot-msg');
        speakText(reply);
      })
      .catch(error => {
        console.error('Error:', error);
        addMessage('Error', error.message, 'error-msg');
        statusDiv.textContent = 'Error. Try again.';
        statusDiv.className = 'idle';
      });
    }

    function speakText(text) {
      synthesis.cancel();
      const utterance = new SpeechSynthesisUtterance(text);
      utterance.lang = 'en-IN';
      utterance.rate = 1.0;
      utterance.pitch = 1.0;

      const voices = synthesis.getVoices();
      const indianVoice = voices.find(v => v.lang === 'en-IN');
      if (indianVoice) utterance.voice = indianVoice;

      utterance.onstart = () => {
        statusDiv.className = 'speaking';
        statusDiv.textContent = '🔊 Speaking...';
      };

      utterance.onend = () => {
        statusDiv.className = 'idle';
        statusDiv.textContent = 'Ready';
      };

      synthesis.speak(utterance);
    }

    window.speechSynthesis.onvoiceschanged = () => {};
  </script>
</body>
</html>
