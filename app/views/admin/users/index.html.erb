<%# app/views/admin/users/index.html.erb %>

<div class="min-h-screen bg-white text-black flex">
  <%= render "admin/shared/sidebar", active: :customers %>

  <main class="flex-1 px-10 py-10 bg-white">
    <!-- TOPBAR -->
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6 border-b border-black/[0.06] pb-8">
      <div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-3">Directory</p>
        <h1 class="text-3xl font-light uppercase tracking-[0.1em] text-black">Customers</h1>
      </div>
    </div>

    <!-- STATS -->
    <div class="flex flex-wrap gap-4 mt-8 mb-8">
      <div class="border border-black/[0.06] bg-white px-5 py-3">
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-1">Total Users</p>
        <p class="text-xl font-light text-black"><%= User.count %></p>
      </div>
      <div class="border border-black/[0.06] bg-white px-5 py-3">
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-1">Customers</p>
        <p class="text-xl font-light text-black"><%= User.where(role: 0).count %></p>
      </div>
      <div class="border border-black/[0.06] bg-white px-5 py-3">
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-1">Admins</p>
        <p class="text-xl font-light text-black"><%= User.where(role: 1).count %></p>
      </div>
      <div class="border border-black/[0.06] bg-white px-5 py-3">
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-1">New This Month</p>
        <p class="text-xl font-light text-emerald-600"><%= User.where("created_at > ?", Time.current.beginning_of_month).count %></p>
      </div>
    </div>

    <!-- TABLE -->
    <div class="relative overflow-hidden border border-black/[0.06] bg-white">
      <table class="w-full text-left border-collapse">
        <thead>
        <tr class="bg-gray-50/50 border-b border-black/[0.06] text-[10px] uppercase tracking-[0.3em] text-gray-400">
          <th class="p-6 font-medium">ID</th>
          <th class="p-6 font-medium">Email</th>
          <th class="p-6 font-medium">Phone</th>
          <th class="p-6 font-medium">Role</th>
          <th class="p-6 font-medium text-right">Orders</th>
          <th class="p-6 font-medium text-right">Joined</th>
        </tr>
        </thead>
        <tbody class="divide-y divide-black/[0.04]">
        <% @users.each do |user| %>
          <tr class="group hover:bg-gray-50/50 transition-all duration-300">
            <td class="p-6">
              <p class="text-xs font-mono text-black">#<%= user.id %></p>
            </td>
            <td class="p-6">
              <p class="text-xs text-black"><%= user.email %></p>
            </td>
            <td class="p-6">
              <p class="text-xs text-black"><%= user.phone_number.presence || "—" %></p>
            </td>
            <td class="p-6">
                <span class="text-[10px] uppercase tracking-[0.15em] px-2 py-0.5 border <%= user.admin? ? 'text-black border-black/20' : 'text-gray-400 border-gray-400/20' %>">
                  <%= user.role.to_s.humanize %>
                </span>
            </td>
            <td class="p-6 text-right">
              <p class="text-xs text-black"><%= user.orders.count %></p>
            </td>
            <td class="p-6 text-right">
              <p class="text-xs text-black"><%= user.created_at.strftime("%b %d, %Y") %></p>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>

    <!-- PAGINATION -->
    <% if @pagy&.pages.to_i > 1 %>
      <div class="mt-12 flex items-center justify-center gap-2">
        <% if @pagy.prev %>
          <%= link_to pagy_url_for(@pagy, @pagy.prev), class: "w-11 h-11 flex items-center justify-center border border-black/[0.06] text-gray-400 hover:text-black hover:border-black/20 transition-all duration-300" do %>←<% end %>
        <% end %>
        <% @pagy.series.each do |item| %>
          <% if item.is_a?(Integer) %>
            <%= link_to item, pagy_url_for(@pagy, item), class: "w-11 h-11 flex items-center justify-center border border-black/[0.06] text-gray-400 hover:text-black hover:border-black/20 text-[11px] tracking-[0.2em] transition-all duration-300" %>
          <% elsif item.is_a?(String) %>
            <div class="w-11 h-11 flex items-center justify-center bg-black text-white text-[11px] tracking-[0.2em] font-medium"><%= item %></div>
          <% elsif item == :gap %>
            <div class="w-11 text-center text-gray-400">...</div>
          <% end %>
        <% end %>
        <% if @pagy.next %>
          <%= link_to pagy_url_for(@pagy, @pagy.next), class: "w-11 h-11 flex items-center justify-center border border-black/[0.06] text-gray-400 hover:text-black hover:border-black/20 transition-all duration-300" do %>→<% end %>
        <% end %>
      </div>
    <% end %>
  </main>
</div>