<%# app/views/admin/categories/index.html.erb %>

<div class="min-h-screen bg-white text-black flex">
  <%= render "admin/shared/sidebar", active: :categories %>

  <main class="flex-1 px-10 py-10 bg-white">
    <!-- TOPBAR -->
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6 border-b border-black/[0.06] pb-8">
      <div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-3">Catalog Structure</p>
        <h1 class="text-3xl font-light uppercase tracking-[0.1em] text-black">Categories</h1>
      </div>
      <div class="text-right">
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-1">Total</p>
        <p class="text-3xl font-light text-black"><%= @categories.count %></p>
      </div>
    </div>

    <!-- CREATE FORM -->
    <div class="border border-black/[0.06] bg-gray-50 p-8 mt-10 mb-10">
      <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-6">Create New Category</p>
      <%= form_with model: [:admin, @category], local: true, class: "flex flex-col md:flex-row items-end gap-5" do |f| %>
        <div class="flex-1 w-full">
          <%= f.label :name, class: "block text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-3" %>
          <%= f.text_field :name, placeholder: "e.g. Men, Women...",
                           class: "w-full h-12 bg-white border border-black/[0.06] px-4 text-sm text-black placeholder-gray-400 outline-none focus:border-black/20 transition-colors" %>
        </div>
        <div class="flex-1 w-full">
          <%= f.label :parent_id, "Parent", class: "block text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-3" %>
          <%= f.collection_select :parent_id, Category.where(parent_id: nil), :id, :name,
                                  { include_blank: "Main Category" },
                                  class: "w-full h-12 bg-white border border-black/[0.06] px-4 text-sm text-black outline-none focus:border-black/20 transition-colors appearance-none" %>
        </div>
        <%= f.submit "Create", class: "h-12 px-8 bg-black text-white uppercase tracking-[0.2em] text-[11px] font-medium hover:bg-gray-800 transition cursor-pointer" %>
      <% end %>
    </div>

    <!-- LIST -->
    <div class="space-y-4">
      <% @categories.each do |category| %>
        <div class="border border-black/[0.06] bg-white overflow-hidden">
          <div class="p-6 flex items-center justify-between">
            <div>
              <input type="text" value="<%= category.name %>"
                     data-id="<%= category.id %>"
                     data-endpoint="<%= admin_category_path(category) %>"
                     class="category-name-input bg-transparent text-lg font-medium text-black outline-none border-b border-transparent focus:border-black/20 pb-1"
                     onblur="autoSave(this)" onkeydown="handleEnter(event, this)">
              <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mt-2"><%= category.subcategories.count %> subcategories</p>
            </div>
            <div class="flex items-center gap-2">
              <%= button_to admin_category_path(category), method: :delete,
                            class: "h-8 w-8 flex items-center justify-center text-gray-400 hover:text-red-500 hover:bg-red-50 transition",
                            data: { turbo_confirm: "Delete?" } do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-width="2"/></svg>
              <% end %>
            </div>
          </div>
          <% if category.subcategories.any? %>
            <div class="border-t border-black/[0.04] bg-gray-50/50 px-6 py-4">
              <div class="flex flex-wrap gap-2">
                <% category.subcategories.each do |sub| %>
                  <div class="flex items-center gap-2 bg-white border border-black/[0.06] px-3 py-2">
                    <input type="text" value="<%= sub.name %>"
                           data-id="<%= sub.id %>"
                           data-endpoint="<%= admin_category_path(sub) %>"
                           class="sub-name-input bg-transparent text-xs text-black outline-none border-b border-transparent focus:border-black/20"
                           onblur="autoSave(this)" onkeydown="handleEnter(event, this)">
                    <%= button_to admin_category_path(sub), method: :delete,
                                  class: "text-gray-400 hover:text-red-500 transition",
                                  data: { turbo_confirm: "Delete?" } do %>
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-width="2"/></svg>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </main>
</div>

<script>
    function handleEnter(e, input) { if (e.key === 'Enter') { e.preventDefault(); input.blur(); } }
    function autoSave(input) {
        const original = input.defaultValue, val = input.value.trim(), ep = input.dataset.endpoint;
        if (val === original || val === '') { if (val === '') input.value = original; return; }
        input.style.opacity = '0.5';
        fetch(ep, { method: 'POST', headers: { 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content }, body: new URLSearchParams({ 'category[name]': val, _method: 'patch' }) })
            .then(r => { input.style.opacity = '1'; if (r.ok) input.defaultValue = val; else input.value = original; })
            .catch(() => { input.style.opacity = '1'; input.value = original; });
    }
</script>