<%# app/views/admin/categories/index.html.erb %>

<div class="max-w-6xl mx-auto px-6 py-16 text-white min-h-screen bg-black">

  <!-- HEADER -->
  <div class="flex items-end justify-between mb-16">
    <div>
      <p class="text-[11px] font-medium uppercase tracking-[0.4em] text-gray-500 mb-3">
        Catalog Structure
      </p>
      <h1 class="text-5xl font-black tracking-tight uppercase text-white">
        Categories
      </h1>
    </div>
    <div class="text-right">
      <p class="text-[11px] font-medium uppercase tracking-[0.35em] text-gray-500 mb-2">
        Total
      </p>
      <p class="text-4xl font-light text-white">
        <%= @categories.count %>
      </p>
    </div>
  </div>

  <!-- CREATE CATEGORY -->
  <div class="border border-white/[0.06] bg-[#0a0a0a] rounded-[32px] p-10 mb-14">
    <div class="mb-8">
      <p class="text-[11px] font-medium uppercase tracking-[0.35em] text-gray-500 mb-2">Create</p>
      <h2 class="text-2xl font-semibold text-white">New Category</h2>
    </div>

    <%= form_with model: [:admin, @category], local: true, class: "flex flex-col md:flex-row items-end gap-5" do |f| %>
      <div class="flex-1 w-full">
        <%= f.label :name, class: "block text-[10px] uppercase tracking-[0.3em] text-gray-500 mb-3" %>
        <%= f.text_field :name, placeholder: "e.g. Men, Women, Accessories...",
                         class: "w-full h-14 bg-black border border-white/10 rounded-2xl px-5 text-sm text-white placeholder-gray-700 outline-none focus:border-white/25 transition-colors" %>
      </div>

      <div class="flex-1 w-full">
        <%= f.label :parent_id, "Parent Category", class: "block text-[10px] uppercase tracking-[0.3em] text-gray-500 mb-3" %>
        <%= f.collection_select :parent_id, Category.where(parent_id: nil), :id, :name,
                                { include_blank: "Main Category" },
                                class: "w-full h-14 bg-black border border-white/10 rounded-2xl px-5 text-sm text-white outline-none focus:border-white/25 transition-colors appearance-none" %>
      </div>

      <%= f.submit "Create Category",
                   class: "h-14 px-10 rounded-full bg-white text-black uppercase tracking-[0.3em] text-[11px] font-bold hover:bg-gray-200 active:scale-95 transition-all duration-200 cursor-pointer" %>
    <% end %>
  </div>

  <!-- CATEGORIES LIST -->
  <div class="space-y-8">
    <% if @categories.any? %>
      <% @categories.each do |category| %>

        <div class="group border border-white/[0.06] bg-[#0a0a0a] rounded-[28px] overflow-hidden hover:border-white/[0.10] transition-colors duration-500">

          <!-- MAIN CATEGORY ROW -->
          <div class="p-8 md:p-10">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">

              <!-- LEFT: Name & Meta -->
              <div class="flex-1 min-w-0">
                <div class="relative group/input flex items-center gap-3 max-w-lg">
                  <input type="text"
                         value="<%= category.name %>"
                         data-id="<%= category.id %>"
                         data-endpoint="<%= admin_category_path(category) %>"
                         class="category-name-input w-full bg-transparent text-2xl md:text-3xl font-semibold text-white outline-none border-b border-transparent focus:border-white/20 pb-1 transition-colors placeholder-gray-700"
                         title="Click to edit"
                         onblur="autoSave(this)"
                         onkeydown="handleEnter(event, this)">

                  <!-- Subtle pencil hint on hover -->
                  <svg class="w-5 h-5 text-white/0 group-hover/input:text-white/20 transition-colors duration-300 flex-shrink-0 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125"/>
                  </svg>
                </div>

                <div class="flex items-center gap-3 mt-4">
                  <span class="h-1.5 w-1.5 rounded-full bg-white/20"></span>
                  <p class="text-[10px] uppercase tracking-[0.35em] text-gray-600 font-medium">
                    <%= category.subcategories.count %> subcategories
                  </p>
                </div>
              </div>

              <!-- RIGHT: Actions (hover reveal) -->
              <div class="flex items-center gap-3 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0">

                <!-- Focus input -->
                <button type="button" onclick="document.querySelector('input.category-name-input[data-id=\'<%= category.id %>\']')?.focus()"
                        class="h-11 w-11 rounded-full border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:border-white/30 hover:bg-white/5 transition-all duration-200"
                        title="Edit name">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125"/>
                  </svg>
                </button>

                <!-- Delete -->
                <%= button_to admin_category_path(category), method: :delete,
                              class: "h-11 w-11 rounded-full border border-red-500/15 flex items-center justify-center text-red-400/40 hover:text-red-400 hover:bg-red-500/10 hover:border-red-500/30 transition-all duration-200",
                              data: { turbo_confirm: "Delete '#{category.name}' and all subcategories?" } do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/>
                  </svg>
                <% end %>
              </div>
            </div>
          </div>

          <!-- SUBCATEGORIES -->
          <% if category.subcategories.any? %>
            <div class="border-t border-white/[0.04] bg-black/20 px-8 md:px-10 py-6 md:py-8">
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                <% category.subcategories.each do |sub| %>

                  <div class="group/sub relative bg-black border border-white/[0.05] rounded-2xl px-5 py-4 hover:border-white/[0.10] transition-all duration-300">
                    <div class="flex items-center justify-between gap-3">
                      <div class="flex-1 min-w-0">
                        <input type="text"
                               value="<%= sub.name %>"
                               data-id="<%= sub.id %>"
                               data-endpoint="<%= admin_category_path(sub) %>"
                               class="sub-name-input w-full bg-transparent text-sm font-medium text-white outline-none border-b border-transparent focus:border-white/20 pb-0.5 transition-colors placeholder-gray-700"
                               title="Click to edit"
                               onblur="autoSave(this)"
                               onkeydown="handleEnter(event, this)">
                        <p class="text-[9px] uppercase tracking-[0.3em] text-gray-700 mt-2 font-medium">Subcategory</p>
                      </div>

                      <!-- Delete on hover (X icon for subtlety) -->
                      <div class="opacity-0 group-hover/sub:opacity-100 transition-opacity duration-200 flex-shrink-0">
                        <%= button_to admin_category_path(sub), method: :delete,
                                      class: "h-8 w-8 rounded-full flex items-center justify-center text-red-400/30 hover:text-red-400 hover:bg-red-500/10 transition-all duration-200",
                                      data: { turbo_confirm: "Delete '#{sub.name}'?" } do %>
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                          </svg>
                        <% end %>
                      </div>
                    </div>

                    <!-- Bottom flash indicator -->
                    <div class="save-indicator absolute bottom-0 left-5 right-5 h-[1px] bg-transparent transition-colors duration-300 rounded-full"></div>
                  </div>

                <% end %>
              </div>
            </div>
          <% end %>

        </div>

      <% end %>
    <% else %>
      <!-- Empty State -->
      <div class="border border-white/[0.06] bg-[#0a0a0a] rounded-[28px] p-16 text-center">
        <p class="text-gray-600 text-sm uppercase tracking-widest">No categories yet</p>
        <p class="text-gray-700 text-xs mt-2">Create your first category above</p>
      </div>
    <% end %>
  </div>

</div>

<!-- AUTO-SAVE SCRIPT -->
<script>
    function handleEnter(e, input) {
        if (e.key === 'Enter') {
            e.preventDefault();
            input.blur();
        }
    }

    function autoSave(input) {
        const originalValue = input.defaultValue;
        const newValue = input.value.trim();
        const endpoint = input.dataset.endpoint;

        if (newValue === originalValue) return;
        if (newValue === '') {
            input.value = originalValue;
            return;
        }

        // Dim while saving
        input.style.opacity = '0.5';

        const token = document.querySelector('meta[name="csrf-token"]')?.content;
        const formData = new FormData();
        formData.append('category[name]', newValue);
        formData.append('_method', 'patch');

        fetch(endpoint, {
            method: 'POST',
            headers: { 'X-CSRF-Token': token },
            body: formData
        })
            .then(response => {
                input.style.opacity = '1';
                if (response.ok) {
                    input.defaultValue = newValue;
                    flashSave(input, 'success');
                } else {
                    input.value = originalValue;
                    flashSave(input, 'error');
                }
            })
            .catch(() => {
                input.style.opacity = '1';
                input.value = originalValue;
                flashSave(input, 'error');
            });
    }

    function flashSave(input, type) {
        const card = input.closest('.group, .group\\/sub');
        const indicator = card?.querySelector('.save-indicator');
        if (!indicator) return;

        if (type === 'success') {
            indicator.style.backgroundColor = 'rgba(255,255,255,0.25)';
        } else {
            indicator.style.backgroundColor = 'rgba(239,68,68,0.6)';
        }

        setTimeout(() => {
            indicator.style.backgroundColor = 'transparent';
        }, 700);
    }
</script>