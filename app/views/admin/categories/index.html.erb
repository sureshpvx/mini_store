<!-- app/views/admin/categories/index.html.erb -->

<div class="p-6 max-w-5xl mx-auto">

  <h1 class="text-2xl font-bold uppercase mb-6">Categories</h1>

  <!-- CREATE CATEGORY -->
  <div class="mb-10 bg-[#0A0A0A] p-6 border border-white/10">

    <%= form_with model: [:admin, @category], local: true do |f| %>

      <div class="grid grid-cols-2 gap-4">

        <div>
          <%= f.label :name, class: "text-xs text-gray-400 uppercase" %>
          <%= f.text_field :name, class: "w-full mt-2 bg-black border border-white/10 px-4 py-3" %>
        </div>

        <div>
          <%= f.label :parent_id, "Parent Category", class: "text-xs text-gray-400 uppercase" %>

          <%= f.collection_select :parent_id,
                                  Category.where(parent_id: nil),
                                  :id,
                                  :name,
                                  { include_blank: "Main Category" },
                                  class: "w-full mt-2 bg-black border border-white/10 px-4 py-3" %>
        </div>

      </div>

      <%= f.submit "Create Category",
                   class: "mt-4 px-6 py-2 border border-white hover:bg-white hover:text-black" %>

    <% end %>

  </div>

  <!-- CATEGORY LIST -->
  <% @categories.each do |category| %>
    <div class="mb-6 border border-white/10 p-4">

      <h2 class="font-bold"><%= category.name %></h2>

      <div class="ml-4 mt-2 text-sm text-gray-400">
        <% category.subcategories.each do |sub| %>
          <div>- <%= sub.name %></div>
        <% end %>
      </div>

    </div>
  <% end %>

</div>