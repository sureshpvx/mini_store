<%# app/views/admin/orders/show.html.erb %>

<div class="min-h-screen bg-white text-black flex">
  <%= render "admin/shared/sidebar", active: :orders %>

  <main class="flex-1 px-10 py-10 bg-white max-w-[1600px]">
    <!-- HEADER -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 border-b border-black/[0.06] pb-8 mb-10">
      <div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-3">Order Details</p>
        <h1 class="text-3xl font-light uppercase tracking-[0.1em] text-black">
          #HYPEE-<%= @order.id.to_s.rjust(4, "0") %>
        </h1>
        <p class="text-[10px] text-gray-400 uppercase tracking-[0.2em] mt-2">
          Placed on <%= @order.created_at.strftime("%b %d, %Y at %H:%M") %>
        </p>
      </div>
      <div class="flex items-center gap-4">
        <%= link_to admin_orders_path, class: "inline-flex items-center gap-2 border border-black/[0.06] px-5 py-2.5 text-[10px] uppercase tracking-[0.2em] text-gray-500 hover:text-black hover:border-black/20 transition-all duration-300" do %>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          Back to Orders
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
      <!-- LEFT COLUMN -->
      <div class="xl:col-span-2 space-y-6">

        <!-- ORDER ITEMS -->
        <div class="border border-black/[0.06] bg-white">
          <div class="px-6 py-5 border-b border-black/[0.06] flex justify-between items-center">
            <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400">Items</p>
            <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400"><%= @order.order_items.sum(:quantity) %> total</p>
          </div>
          <table class="w-full text-left border-collapse">
            <thead>
            <tr class="bg-gray-50/50 border-b border-black/[0.06] text-[10px] uppercase tracking-[0.3em] text-gray-400">
              <th class="p-5 font-medium">Product</th>
              <th class="p-5 font-medium text-right">Qty</th>
              <th class="p-5 font-medium text-right">Unit Price</th>
              <th class="p-5 font-medium text-right">Total</th>
            </tr>
            </thead>
            <tbody class="divide-y divide-black/[0.04]">
            <% @order.order_items.each do |item| %>
              <tr class="group">
                <td class="p-5">
                  <p class="text-sm font-medium text-black"><%= item.product&.name || "Deleted Product" %></p>
                  <p class="text-[10px] text-gray-400 mt-0.5 uppercase tracking-widest">ID: <%= item.product_id %></p>
                </td>
                <td class="p-5 text-right text-xs text-black"><%= item.quantity %></td>
                <td class="p-5 text-right text-xs text-black"><%= number_to_currency(item.price, unit: "₹", precision: 0) %></td>
                <td class="p-5 text-right text-xs font-medium text-black"><%= number_to_currency(item.price * item.quantity, unit: "₹", precision: 0) %></td>
              </tr>
            <% end %>
            </tbody>
          </table>
        </div>

        <!-- TIMELINE -->
        <div class="border border-black/[0.06] bg-white p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-6">Timeline</p>
          <div class="space-y-6 relative pl-4 border-l border-black/[0.06]">
            <div class="relative pl-6">
              <span class="absolute -left-[5px] top-1.5 w-2.5 h-2.5 bg-black rounded-full"></span>
              <p class="text-xs text-black">Order placed</p>
              <p class="text-[10px] text-gray-400 mt-0.5"><%= @order.created_at.strftime("%b %d, %Y — %H:%M") %></p>
            </div>
            <% if @order.status != "pending" %>
              <div class="relative pl-6">
                <span class="absolute -left-[5px] top-1.5 w-2.5 h-2.5 bg-gray-300 rounded-full"></span>
                <p class="text-xs text-black">Status updated to <%= @order.status.to_s.humanize %></p>
                <p class="text-[10px] text-gray-400 mt-0.5"><%= @order.updated_at.strftime("%b %d, %Y — %H:%M") %></p>
              </div>
            <% end %>
            <div class="relative pl-6">
              <span class="absolute -left-[5px] top-1.5 w-2.5 h-2.5 <%= @order.payment_status.to_s == "paid" ? "bg-emerald-600" : "bg-gray-300" %> rounded-full"></span>
              <p class="text-xs text-black">Payment <%= @order.payment_status.to_s.humanize.downcase %></p>
              <p class="text-[10px] text-gray-400 mt-0.5"><%= @order.updated_at.strftime("%b %d, %Y — %H:%M") %></p>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT COLUMN -->
      <div class="space-y-6">

        <!-- STATUS MANAGEMENT -->
        <div class="border border-black/[0.06] bg-white p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-6">Status Control</p>

          <%= form_with model: [:admin, @order], class: "space-y-5" do |f| %>

            <div>
              <%= f.label :status, class: "block text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-2" %>
              <%= f.select :status,
                           options_for_select(Order.statuses.keys.map { |s| [s.humanize, s] }, @order.status),
                           {},
                           class: "w-full bg-white border border-black/10 px-3 py-2.5 text-xs text-black focus:outline-none focus:border-black/30 transition appearance-none" %>
            </div>

            <div>
              <%= f.label :payment_status, class: "block text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-2" %>
              <%= f.select :payment_status,
                           options_for_select(Order.payment_statuses.keys.map { |s| [s.humanize, s] }, @order.payment_status),
                           {},
                           class: "w-full bg-white border border-black/10 px-3 py-2.5 text-xs text-black focus:outline-none focus:border-black/30 transition appearance-none" %>
            </div>

            <%= f.submit "Update Order",
                         class: "w-full bg-black text-white px-6 py-3 text-[10px] uppercase tracking-[0.2em] hover:bg-gray-800 transition cursor-pointer" %>

          <% end %>
        </div>

        <!-- CUSTOMER -->
        <div class="border border-black/[0.06] bg-white p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-6">Customer</p>
          <div class="space-y-4 text-sm">
            <div>
              <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-1">Name</p>
              <p class="text-black"><%= @order.shipping_full_name.presence || "N/A" %></p>
            </div>
            <div>
              <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-1">Email</p>
              <p class="text-black"><%= @order.user&.email || "Guest" %></p>
            </div>
            <div>
              <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-1">Phone</p>
              <p class="text-black"><%= @order.shipping_phone_number.presence || "N/A" %></p>
            </div>
          </div>
        </div>

        <!-- SHIPPING ADDRESS -->
        <div class="border border-black/[0.06] bg-white p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-6">Shipping Address</p>
          <div class="text-sm text-black leading-relaxed">
            <p><%= @order.shipping_full_name %></p>
            <p class="text-gray-500 mt-1"><%= @order.shipping_address_line_1 %></p>
            <% if @order.shipping_address_line_2.present? %>
              <p class="text-gray-500"><%= @order.shipping_address_line_2 %></p>
            <% end %>
            <p class="text-gray-500 mt-1">
              <%= @order.shipping_city %>, <%= @order.shipping_state %> <%= @order.shipping_postal_code %>
            </p>
            <p class="text-gray-500"><%= @order.shipping_country %></p>
          </div>
        </div>

        <!-- ORDER SUMMARY -->
        <div class="border border-black/[0.06] bg-white p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-6">Summary</p>
          <div class="space-y-3 text-xs">
            <div class="flex justify-between text-gray-500">
              <span>Subtotal</span>
              <span><%= number_to_currency(@order.total_price, unit: "₹", precision: 0) %></span>
            </div>
            <div class="flex justify-between text-gray-500">
              <span>Shipping</span>
              <span class="uppercase tracking-widest text-[10px]">Free</span>
            </div>
            <div class="border-t border-black/[0.06] pt-3 flex justify-between text-sm font-medium text-black">
              <span>Total</span>
              <span><%= number_to_currency(@order.total_price, unit: "₹", precision: 0) %></span>
            </div>
          </div>
        </div>

        <!-- RAZORPAY REFERENCE -->
        <% if @order.razorpay_order_id.present? %>
          <div class="border border-black/[0.06] bg-white p-6">
            <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-4">Payment Reference</p>
            <div class="space-y-2 text-[10px] uppercase tracking-widest text-gray-500 font-mono">
              <p><span class="text-gray-400">Order ID:</span> <%= @order.razorpay_order_id %></p>
              <% if @order.razorpay_payment_id.present? %>
                <p><span class="text-gray-400">Payment ID:</span> <%= @order.razorpay_payment_id %></p>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- CURRENT BADGES -->
        <div class="border border-black/[0.06] bg-white p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-4">Current State</p>
          <div class="flex flex-wrap gap-2">
            <% status_styles = {
              "pending"    => "text-orange-500 border-orange-500/20",
              "processing" => "text-blue-500 border-blue-500/20",
              "shipped"    => "text-purple-500 border-purple-500/20",
              "delivered"  => "text-emerald-600 border-emerald-600/20",
              "cancelled"  => "text-red-500 border-red-500/20"
            } %>
            <span class="text-[10px] uppercase tracking-[0.15em] px-2 py-0.5 border <%= status_styles[@order.status.to_s] || 'text-gray-400 border-gray-400/20' %>">
              <%= @order.status.to_s.humanize %>
            </span>

            <% pay_styles = {
              "pending"  => "text-orange-500 border-orange-500/20",
              "paid"     => "text-emerald-600 border-emerald-600/20",
              "failed"   => "text-red-500 border-red-500/20",
              "refunded" => "text-gray-500 border-gray-500/20"
            } %>
            <span class="text-[10px] uppercase tracking-[0.15em] px-2 py-0.5 border <%= pay_styles[@order.payment_status.to_s] || 'text-gray-400 border-gray-400/20' %>">
              <%= @order.payment_status.to_s.humanize %>
            </span>
          </div>
        </div>

      </div>
    </div>
  </main>
</div>