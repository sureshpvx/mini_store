<div class="min-h-screen bg-white text-black flex">
  <%= render "admin/shared/sidebar", active: :search %>

  <main class="flex-1 px-10 py-10 bg-white">
    <!-- Header -->
    <div class="border-b border-black/[0.06] pb-8 mb-10">
      <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-3">Global Search</p>
      <h1 class="text-3xl font-light uppercase tracking-[0.1em] text-black">Search Results</h1>
    </div>

    <!-- Search Input -->
    <%= form_with url: admin_search_path, method: :get, class: "mb-10 flex gap-0", data: { turbo: false } do |f| %>
      <%= f.text_field :q, value: @query, placeholder: "Search orders, products, users...",
                       class: "flex-1 bg-white border border-black/10 px-4 py-3 text-sm text-black placeholder-gray-300 focus:outline-none focus:border-black/30" %>
      <%= f.submit "Search", class: "bg-black text-white px-6 py-3 text-xs uppercase tracking-widest hover:bg-gray-800 transition cursor-pointer" %>
    <% end %>

    <% if @query.blank? %>
      <p class="text-gray-400 text-xs uppercase tracking-widest">Enter a search term above</p>
    <% elsif @total == 0 %>
      <p class="text-gray-400 text-xs uppercase tracking-widest">No results found for "<%= @query %>"</p>
    <% else %>

      <!-- PRODUCTS -->
      <% if @products.any? %>
        <div class="mb-10">
          <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-4">Products (<%= @products.count %>)</p>
          <div class="border border-black/[0.06] overflow-hidden">
            <table class="w-full text-left text-sm">
              <tbody class="divide-y divide-black/[0.04]">
              <% @products.each do |p| %>
                <tr class="hover:bg-gray-50/50 transition">
                  <td class="p-4"><%= p.name %></td>
                  <td class="p-4 text-gray-500"><%= number_to_currency(p.price, unit: "₹", precision: 0) %></td>
                  <td class="p-4 text-right"><%= link_to "View", admin_product_path(p), class: "text-[10px] uppercase tracking-widest underline text-gray-400 hover:text-black" %></td>
                </tr>
              <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>

      <!-- ORDERS -->
      <% if @orders.any? %>
        <div class="mb-10">
          <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-4">Orders (<%= @orders.count %>)</p>
          <div class="border border-black/[0.06] overflow-hidden">
            <table class="w-full text-left text-sm">
              <tbody class="divide-y divide-black/[0.04]">
              <% @orders.each do |o| %>
                <tr class="hover:bg-gray-50/50 transition">
                  <td class="p-4">#HYPEE-<%= o.id.to_s.rjust(4,"0") %></td>
                  <td class="p-4 text-gray-500"><%= o.shipping_full_name || o.user&.email %></td>
                  <td class="p-4 text-right"><%= link_to "View", admin_order_path(o), class: "text-[10px] uppercase tracking-widest underline text-gray-400 hover:text-black" %></td>
                </tr>
              <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>

      <!-- USERS -->
      <% if @users.any? %>
        <div class="mb-10">
          <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-4">Users (<%= @users.count %>)</p>
          <div class="border border-black/[0.06] overflow-hidden">
            <table class="w-full text-left text-sm">
              <tbody class="divide-y divide-black/[0.04]">
              <% @users.each do |u| %>
                <tr class="hover:bg-gray-50/50 transition">
                  <td class="p-4"><%= u.email %></td>
                  <td class="p-4 text-gray-500"><%= u.phone_number || "—" %></td>
                </tr>
              <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>

      <!-- CATEGORIES -->
      <% if @categories.any? %>
        <div class="mb-10">
          <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-4">Categories (<%= @categories.count %>)</p>
          <div class="border border-black/[0.06] overflow-hidden">
            <table class="w-full text-left text-sm">
              <tbody class="divide-y divide-black/[0.04]">
              <% @categories.each do |c| %>
                <tr class="hover:bg-gray-50/50 transition">
                  <td class="p-4"><%= c.name %></td>
                </tr>
              <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>

      <!-- CONTACTS -->
      <% if @contacts.any? %>
        <div class="mb-10">
          <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-4">Contact Messages (<%= @contacts.count %>)</p>
          <div class="border border-black/[0.06] overflow-hidden">
            <table class="w-full text-left text-sm">
              <tbody class="divide-y divide-black/[0.04]">
              <% @contacts.each do |c| %>
                <tr class="hover:bg-gray-50/50 transition">
                  <td class="p-4"><%= c.name %></td>
                  <td class="p-4 text-gray-500"><%= c.email %></td>
                  <td class="p-4 text-gray-400 text-[10px]"><%= c.message.truncate(40) %></td>
                </tr>
              <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>

      <!-- NEWSLETTERS -->
      <% if @newsletters.any? %>
        <div class="mb-10">
          <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-4">Newsletter (<%= @newsletters.count %>)</p>
          <div class="border border-black/[0.06] overflow-hidden">
            <table class="w-full text-left text-sm">
              <tbody class="divide-y divide-black/[0.04]">
              <% @newsletters.each do |n| %>
                <tr class="hover:bg-gray-50/50 transition">
                  <td class="p-4"><%= n.email %></td>
                  <td class="p-4 text-gray-500 text-[10px] uppercase"><%= n.subscribed ? "Active" : "Unsubscribed" %></td>
                </tr>
              <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>

    <% end %>
  </main>
</div>