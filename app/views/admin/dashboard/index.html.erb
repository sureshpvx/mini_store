<%# app/views/admin/dashboard/index.html.erb %>

<div class="min-h-screen bg-white text-black flex">
  <%= render "admin/shared/sidebar", active: :dashboard %>

  <main class="flex-1 px-10 py-10 bg-white">
    <!-- TOPBAR -->
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6 border-b border-black/[0.06] pb-8">
      <div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-3">Commerce Analytics</p>
        <h1 class="text-3xl font-light uppercase tracking-[0.1em] text-black">Dashboard</h1>
      </div>
    </div>

    <!-- KPI GRID -->
    <section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4 mt-10">
      <div class="border border-black/[0.06] bg-white p-6">
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400">Revenue</p>
        <h2 class="text-3xl font-light mt-4 text-black">
          <%= number_to_currency(Order.where(payment_status: 1).sum(:total_price), unit: "₹", precision: 0) %>
        </h2>
        <p class="text-emerald-600 text-xs mt-3 font-light">Paid commerce volume</p>
      </div>

      <div class="border border-black/[0.06] bg-white p-6">
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400">Orders</p>
        <h2 class="text-3xl font-light mt-4 text-black"><%= Order.count %></h2>
        <p class="text-gray-400 text-xs mt-3 font-light"><%= Order.where(status: 1).count %> processing orders</p>
      </div>

      <div class="border border-black/[0.06] bg-white p-6">
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400">Products</p>
        <h2 class="text-3xl font-light mt-4 text-black"><%= Product.count %></h2>
        <p class="text-gray-400 text-xs mt-3 font-light"><%= Product.where("stock < ?", 10).count %> low stock alerts</p>
      </div>

      <div class="border border-black/[0.06] bg-white p-6">
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400">Customers</p>
        <h2 class="text-3xl font-light mt-4 text-black"><%= User.count %></h2>
        <p class="text-gray-400 text-xs mt-3 font-light">Registered users</p>
      </div>
    </section>

    <!-- LOWER GRID -->
    <section class="grid grid-cols-1 xl:grid-cols-3 gap-6 mt-10">
      <!-- RECENT ORDERS -->
      <div class="xl:col-span-2 border border-black/[0.06] bg-white">
        <div class="flex items-center justify-between px-6 py-5 border-b border-black/[0.06]">
          <div>
            <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-2">Fulfillment Queue</p>
            <h2 class="text-lg font-light uppercase tracking-[0.1em] text-black">Recent Orders</h2>
          </div>
        </div>
        <div class="divide-y divide-black/[0.04]">
          <% Order.order(created_at: :desc).limit(5).each do |order| %>
            <div class="flex items-center justify-between px-6 py-5 hover:bg-gray-50/50 transition">
              <div>
                <p class="text-sm font-medium text-black">#HYPEE-<%= order.id.to_s.rjust(4, "0") %></p>
                <p class="text-[10px] uppercase tracking-[0.25em] text-gray-400 mt-1"><%= order.shipping_full_name %></p>
              </div>
              <div class="text-right">
                <p class="text-sm text-black"><%= number_to_currency(order.total_price, unit: "₹", precision: 0) %></p>
                <p class="text-[10px] uppercase tracking-[0.25em] mt-1 <%= order.payment_status.to_s == 'paid' ? 'text-emerald-600' : 'text-orange-500' %>"><%= order.payment_status %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- INVENTORY STATUS -->
      <div class="border border-black/[0.06] bg-white p-6">
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-2">Inventory Watch</p>
        <h2 class="text-lg font-light uppercase tracking-[0.1em] text-black mb-6">Low Stock</h2>
        <div class="space-y-4">
          <% Product.where("stock < ?", 10).limit(6).each do |product| %>
            <div>
              <div class="flex items-center justify-between mb-2">
                <p class="text-sm text-black truncate"><%= product.name %></p>
                <p class="text-xs text-orange-500 font-light"><%= product.stock %></p>
              </div>
              <div class="h-[1px] bg-black/[0.06] relative overflow-hidden">
                <div class="absolute left-0 top-0 h-full bg-orange-500" style="width: <%= [product.stock * 10, 100].min %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </section>
  </main>
</div>