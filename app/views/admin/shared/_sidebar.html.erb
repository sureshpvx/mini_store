<%# app/views/admin/shared/_sidebar.html.erb %>

<%# Usage: render "admin/shared/sidebar", active: :dashboard %>

<aside class="w-72 border-r border-black/[0.06] bg-white px-8 py-10 flex flex-col justify-between">

  <div>

    <div>
      <h1 class="text-2xl font-bold uppercase tracking-tight">Hypee</h1>
      <p class="text-[10px] uppercase tracking-[0.35em] text-gray-400 mt-2">Commerce Control Node</p>
    </div>

    <nav class="mt-14 space-y-1">

      <%# Dashboard %>
      <a href="<%= admin_root_path %>"
         class="flex items-center justify-between px-5 py-4 text-[11px] uppercase tracking-[0.2em] transition <%= active == :dashboard ? 'bg-black text-white' : 'text-gray-400 hover:text-black' %>">
        <span>Dashboard</span>
        <span class="text-[10px] <%= active == :dashboard ? 'opacity-60' : '' %>">01</span>
      </a>
<%# search %>
      <a href="<%= admin_search_path %>"
         class="flex items-center justify-between px-5 py-4 text-[11px] uppercase tracking-[0.2em] transition <%= active == :search ? 'bg-black text-white' : 'text-gray-400 hover:text-black' %>">
        <span>Search</span>
        <span class="text-[10px] <%= active == :search ? 'opacity-60' : '' %>">⌘</span>
      </a>


      <%# Catalog %>
      <a href="<%= admin_products_path %>"
         class="flex items-center justify-between px-5 py-4 text-[11px] uppercase tracking-[0.2em] transition <%= active == :products ? 'bg-black text-white' : 'text-gray-400 hover:text-black' %>">
        <span>Catalog</span>
        <span class="text-[10px] <%= active == :products ? 'opacity-60' : '' %>"><%= Product.count %></span>
      </a>

      <%# Orders %>
      <a href="<%= admin_orders_path %>"
         class="flex items-center justify-between px-5 py-4 text-[11px] uppercase tracking-[0.2em] transition <%= active == :orders ? 'bg-black text-white' : 'text-gray-400 hover:text-black' %>">
        <span>Orders</span>
        <span class="text-[10px] <%= active == :orders ? 'opacity-60' : '' %>"><%= Order.count %></span>
      </a>

      <%# Customers %>
      <a href="<%= admin_users_path %>"
         class="flex items-center justify-between px-5 py-4 text-[11px] uppercase tracking-[0.2em] transition <%= active == :customers ? 'bg-black text-white' : 'text-gray-400 hover:text-black' %>">
        <span>Customers</span>
        <span class="text-[10px] <%= active == :customers ? 'opacity-60' : '' %>"><%= User.count %></span>
      </a>

      <%# Categories %>
      <a href="<%= admin_categories_path %>"
         class="flex items-center justify-between px-5 py-4 text-[11px] uppercase tracking-[0.2em] transition <%= active == :categories ? 'bg-black text-white' : 'text-gray-400 hover:text-black' %>">
        <span>Categories</span>
        <span class="text-[10px] <%= active == :categories ? 'opacity-60' : '' %>"><%= Category.count %></span>
      </a>

    </nav>

  </div>

  <%# LOGOUT %>
  <div class="border-t border-black/[0.06] pt-6">
    <%= button_to destroy_user_session_path,
                  method: :delete,
                  class: "w-full flex items-center gap-3 px-5 py-4 text-gray-400 hover:text-red-500 transition group" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9"/>
      </svg>
      <span class="text-[11px] uppercase tracking-[0.2em]">Logout</span>
    <% end %>

    <div class="mt-4 px-5">
      <p class="text-[10px] text-gray-400 tracking-widest"><%= current_user&.email %></p>
    </div>
  </div>

</aside>