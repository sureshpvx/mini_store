<%= form_with model: [:admin, Product.new],
              url: admin_products_path,
              local: true,
              html: {
                multipart: true,
                data: { turbo: false }
              } do |f| %>

  <%= f.text_field :name, value: "Test Product" %>

  <%= f.number_field :price, value: 100 %>

  <%= f.collection_select :category_id,
                          Category.all,
                          :id,
                          :name %>

  <%= f.file_field :images,
                   multiple: true,
                   direct_upload: false %>

  <%= f.submit "Create Product" %>

<% end %>