<%# app/views/admin/products/show.html.erb - inside the top bar, before the buttons %>

<% if @product.cart_items.any? || @product.order_items.where.not(order_id: Order.delivered.pluck(:id)).any? %>
  <div class="mb-4 border border-orange-200 bg-orange-50 p-3">
    <p class="text-[10px] uppercase tracking-[0.2em] text-orange-600 mb-1">Cannot Delete Safely</p>
    <div class="text-xs text-orange-700 space-y-1">
      <% if @product.cart_items.any? %>
        <p>• <%= @product.cart_items.count %> user(s) have this in cart:
          <%= @product.active_cart_users.map(&:email).join(", ") %></p>
      <% end %>
      <% active_count = @product.order_items.where.not(order_id: Order.delivered.pluck(:id)).count %>
      <% if active_count > 0 %>
        <p>• <%= active_count %> active order(s) contain this product</p>
      <% end %>
    </div>
  </div>
<% end %>
<div class="min-h-screen bg-white text-black">
  <div class="max-w-7xl mx-auto px-6 py-10">

    <%# ========== TOP BAR ========== %>
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8 pb-6 border-b border-black/[0.06]">
      <div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-1">
          <%= link_to "Admin", admin_root_path, class: "text-gray-400 hover:text-black" %> / Products
        </p>
        <h1 class="text-3xl font-light tracking-[0.1em] text-black"><%= @product.name %></h1>
      </div>

      <div class="flex items-center gap-3">
        <div data-controller="modal" data-modal-id="edit-product-<%= @product.id %>">
          <button data-modal-id="edit-product-<%= @product.id %>" data-action="click->modal#open"
                  class="inline-flex items-center gap-2 px-5 h-10 bg-black text-white text-[11px] uppercase tracking-[0.2em] font-medium hover:bg-gray-800 transition active:scale-95">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Edit
          </button>
          <%= render "shared/modal", title: "Edit Product", modal_id: "edit-product-#{@product.id}" do %>
            <%= render "admin/products/form", product: @product %>
          <% end %>
        </div>

        <%= button_to admin_product_path(@product),
                      method: :delete,
                      data: { turbo_confirm: "Delete this product permanently?" },
                      class: "inline-flex items-center gap-2 px-5 h-10 border border-red-500 text-red-500 text-[11px] uppercase tracking-[0.2em] font-medium hover:bg-red-500 hover:text-white transition active:scale-95" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          Delete
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <%# ========== LEFT: Compact Media Gallery ========== %>
      <div class="lg:col-span-2 space-y-3" data-controller="product-gallery">

        <% all_media = [] %>
        <% @product.images.each { |img| all_media << { type: :image, src: url_for(img), alt: @product.name } } %>
        <% if @product.video.attached? %>
          <% all_media << { type: :video, src: url_for(@product.video), content_type: @product.video.content_type, alt: "#{@product.name} video" } %>
        <% end %>

        <% if all_media.any? %>

          <%# Compact Main Viewport %>
          <div class="relative aspect-[4/3] sm:aspect-[16/10] overflow-hidden bg-gray-50 group select-none border border-black/[0.06]" data-product-gallery-target="viewport">

            <div class="flex h-full transition-transform duration-500 ease-out will-change-transform" data-product-gallery-target="track">
              <% all_media.each_with_index do |media, i| %>
                <div class="w-full h-full flex-shrink-0 relative" data-slide-index="<%= i %>">

                  <% if media[:type] == :image %>
                    <%= image_tag media[:src],
                                  class: "w-full h-full object-cover",
                                  alt: media[:alt],
                                  loading: i == 0 ? "eager" : "lazy",
                                  draggable: "false" %>
                  <% else %>
                    <video class="w-full h-full object-cover cursor-pointer"
                           muted loop playsinline preload="metadata"
                           data-product-gallery-target="video"
                           onclick="this.paused ? this.play() : this.pause(); this.muted = !this.muted;">
                      <source src="<%= media[:src] %>" type="<%= media[:content_type] %>">
                    </video>

                    <div class="absolute inset-0 flex items-center justify-center pointer-events-none transition-opacity duration-300" data-video-overlay>
                      <div class="w-10 h-10 border border-black/20 flex items-center justify-center backdrop-blur-sm bg-white/50">
                        <svg class="w-3.5 h-3.5 text-black ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                      </div>
                    </div>
                  <% end %>

                </div>
              <% end %>
            </div>

            <%# Arrows %>
            <% if all_media.size > 1 %>
              <button type="button"
                      class="absolute left-0 top-0 bottom-0 w-12 sm:w-16 flex items-center justify-start pl-3 sm:pl-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 focus:opacity-100 outline-none z-10"
                      aria-label="Previous"
                      data-action="click->product-gallery#prev">
                <svg class="w-5 h-5 text-black/40 hover:text-black transition" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
              </button>

              <button type="button"
                      class="absolute right-0 top-0 bottom-0 w-12 sm:w-16 flex items-center justify-end pr-3 sm:pr-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 focus:opacity-100 outline-none z-10"
                      aria-label="Next"
                      data-action="click->product-gallery#next">
                <svg class="w-5 h-5 text-black/40 hover:text-black transition" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
              </button>
            <% end %>

            <%# Counter %>
            <% if all_media.size > 1 %>
              <div class="absolute top-3 right-3 text-[10px] uppercase tracking-[0.2em] text-black/50 bg-white/80 backdrop-blur-sm border border-black/10 px-2 py-0.5 z-10">
                <span data-product-gallery-target="current">1</span> / <%= all_media.size %>
              </div>
            <% end %>

            <%# Video badge %>
            <% if all_media.any? { |m| m[:type] == :video } %>
              <div class="absolute top-3 left-3 text-[9px] uppercase tracking-[0.2em] text-black/60 bg-white/80 backdrop-blur-sm border border-black/10 px-2 py-0.5 z-10 hidden" data-product-gallery-target="videoBadge">
                Video
              </div>
            <% end %>

          </div>

          <%# Compact Thumbnails %>
          <% if all_media.size > 1 %>
            <div class="flex gap-2 overflow-x-auto pb-1 scrollbar-hide select-none" data-product-gallery-target="thumbs">
              <% all_media.each_with_index do |media, i| %>
                <button type="button"
                        class="flex-shrink-0 w-12 h-12 sm:w-14 sm:h-14 border transition-colors relative outline-none <%= i == 0 ? 'border-black/40' : 'border-black/10 hover:border-black/30' %>"
                        data-action="click->product-gallery#goTo"
                        data-index="<%= i %>"
                        aria-label="View <%= media[:type] %> <%= i + 1 %>">

                  <% if media[:type] == :image %>
                    <%= image_tag media[:src], class: "w-full h-full object-cover", alt: "", draggable: "false" %>
                  <% else %>
                    <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                      <svg class="w-4 h-4 text-black/40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                    </div>
                  <% end %>

                  <div class="absolute bottom-0 left-0 right-0 h-[2px] bg-black transition-opacity <%= i == 0 ? 'opacity-100' : 'opacity-0' %>" data-thumb-indicator></div>
                </button>
              <% end %>
            </div>
          <% end %>

        <% else %>
          <div class="aspect-[4/3] bg-gray-50 flex items-center justify-center border border-black/[0.04]">
            <span class="text-[10px] uppercase tracking-[0.3em] text-gray-400">No Image</span>
          </div>
        <% end %>

        <%# Description - compact %>
        <% if @product.description.present? %>
          <div class="border border-black/[0.06] p-4 sm:p-5 bg-white mt-2">
            <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-2">Description</p>
            <p class="text-sm text-gray-500 leading-relaxed font-light whitespace-pre-line"><%= @product.description %></p>
          </div>
        <% end %>

      </div>

      <%# ========== RIGHT: Info Panel ========== %>
      <div class="lg:col-span-1 space-y-6">

        <%# Status Card %>
        <div class="border border-black/[0.06] p-5 bg-white">
          <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-4">Status</p>
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-400">Stock</span>
              <span class="text-sm font-light text-black"><%= @product.stock.to_i %> units</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-400">Availability</span>
              <% if @product.stock.to_i > 0 %>
                <span class="text-[10px] uppercase tracking-[0.15em] text-emerald-600 border border-emerald-600/20 px-2 py-0.5">In Stock</span>
              <% else %>
                <span class="text-[10px] uppercase tracking-[0.15em] text-red-500 border border-red-500/20 px-2 py-0.5">Out of Stock</span>
              <% end %>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-400">Price</span>
              <span class="text-lg font-light text-black">₹<%= number_with_precision(@product.price, precision: 2) %></span>
            </div>
          </div>
        </div>

        <%# Details Card %>
        <div class="border border-black/[0.06] p-5 bg-white">
          <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-4">Details</p>
          <div class="space-y-3">
            <div class="flex items-center justify-between border-b border-black/[0.04] pb-2">
              <span class="text-xs text-gray-400">Category</span>
              <span class="text-xs text-black text-right">
                <% if @product.category %>
                  <%= @product.category.parent&.name %> → <%= @product.category.name %>
                <% else %>
                  —
                <% end %>
              </span>
            </div>
            <div class="flex items-center justify-between border-b border-black/[0.04] pb-2">
              <span class="text-xs text-gray-400">Images</span>
              <span class="text-xs text-black"><%= @product.images.attached? ? @product.images.count : 0 %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-400">Video</span>
              <span class="text-xs text-black"><%= @product.video.attached? ? "Yes" : "No" %></span>
            </div>
          </div>
        </div>

        <%# History Card %>
        <div class="border border-black/[0.06] p-5 bg-white">
          <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-4">History</p>
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-400">Created</span>
              <span class="text-xs text-black"><%= @product.created_at.strftime("%b %d, %Y %H:%M") %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-400">Updated</span>
              <span class="text-xs text-black"><%= @product.updated_at.strftime("%b %d, %Y %H:%M") %></span>
            </div>
          </div>
        </div>

        <%= link_to "Back to Products", admin_products_path,
                    class: "w-full h-10 flex items-center justify-center border border-black/[0.06] text-[11px] uppercase tracking-[0.2em] text-gray-400 hover:text-black hover:border-black/20 transition" %>

      </div>
    </div>

  </div>
</div>