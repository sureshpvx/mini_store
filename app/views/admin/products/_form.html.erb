<%= form_with scope: :product,
              url: admin_products_path,
              method: :post,
              local: true,
              html: { multipart: true },
              class: "w-full" do |f| %>

  <div class="px-8 py-10">

      <!-- BODY -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
        <!-- LEFT SIDE -->
        <div class="space-y-10">

          <!-- Name -->
          <div>
            <%= f.label :name, class: "text-xs uppercase tracking-widest text-gray-400 mb-3 block" %>
            <%= f.text_field :name,
                             class: "w-full bg-transparent border-b border-white/20 py-3 text-sm focus:border-white focus:outline-none" %>
          </div>

          <!-- Description -->
          <div>
            <%= f.label :description, class: "text-xs uppercase tracking-widest text-gray-400 mb-3 block" %>
            <%= f.text_area :description,
                            rows: 4,
                            class: "w-full bg-transparent border-b border-white/20 py-3 text-sm focus:border-white focus:outline-none resize-none" %>
          </div>

          <!-- Price + Stock -->
          <div class="grid grid-cols-2 gap-10">
            <div>
              <%= f.label :price, class: "text-xs uppercase tracking-widest text-gray-400 mb-3 block" %>
              <%= f.number_field :price,
                                 class: "w-full bg-transparent border-b border-white/20 py-3 text-sm focus:border-white focus:outline-none" %>
            </div>

            <div>
              <%= f.label :stock, class: "text-xs uppercase tracking-widest text-gray-400 mb-3 block" %>
              <%= f.number_field :stock,
                                 class: "w-full bg-transparent border-b border-white/20 py-3 text-sm focus:border-white focus:outline-none" %>
            </div>
          </div>

          <!-- Category -->
          <div>
            <%= f.label :category_id, class: "text-xs uppercase tracking-widest text-gray-400 mb-3 block" %>

            <%= f.grouped_collection_select :category_id,
                                            Category.where(parent_id: nil),
                                            :subcategories,
                                            :name,
                                            :id,
                                            :full_name,
                                            { prompt: "Select Category" },
                                            class: "w-full bg-transparent border-b border-white/20 py-3 text-sm focus:border-white focus:outline-none appearance-none" %>
          </div>

        </div>

        <!-- RIGHT SIDE -->
        <div class="space-y-10">

          <!-- IMAGES -->
          <div data-controller="upload">

            <input type="file"
                   name="product[images][]"
                   multiple
                   accept="image/*"
                   data-upload-target="input"
                   class="hidden" />

            <div data-upload-target="dropzone"
                 data-action="click->upload#open"
                 class="upload-box w-full h-52 border border-dashed border-white/20 bg-[#0D0D0D] flex items-center justify-center cursor-pointer hover:border-white/50 transition relative overflow-hidden">

              <!-- Placeholder -->
              <div data-upload-target="placeholder" class="text-center">
                <p class="text-sm text-gray-400">
                  Drag & drop or <span class="underline">browse</span>
                </p>
                <p class="text-xs text-gray-600 mt-1">Images only</p>
              </div>

              <!-- Preview container INSIDE -->
              <div data-upload-target="preview"
                   class="absolute inset-0 hidden p-2 flex flex-wrap gap-2">
              </div>

            </div>
          </div>

          <!-- VIDEO -->
          <div data-controller="upload">
            <label class="text-xs uppercase tracking-widest text-gray-400 mb-4 block">
              Product Video
            </label>

            <input type="file"
                   name="product[video]"
                   accept="video/*"
                   data-upload-target="input"
                   class="hidden" />

            <div data-upload-target="dropzone"
                 data-action="click->upload#open"
                 class="w-full h-44 border border-dashed border-white/20 bg-[#0D0D0D] flex items-center justify-center cursor-pointer hover:border-white/50 transition relative overflow-hidden">

              <!-- Placeholder -->
              <div data-upload-target="placeholder" class="text-center">
                <p class="text-sm text-gray-400">
                  Upload video
                </p>
                <p class="text-xs text-gray-600 mt-1">
                  MP4 recommended
                </p>
              </div>

              <!-- Preview INSIDE dropzone -->
              <div data-upload-target="preview"
                   class="absolute inset-0 hidden">
              </div>

            </div>
          </div>

        </div>

      </div>

      <!-- FOOTER -->
    <div class="flex justify-between items-center pt-8 border-t border-white/10 mt-10">
      <button type="button"
                data-action="click->modal#close"
                class="text-sm uppercase tracking-widest text-gray-400 hover:text-white">
          Cancel
        </button>

        <%= f.submit "Create",
                     class: "px-10 py-3 border border-white text-sm uppercase tracking-widest hover:bg-white hover:text-black transition" %>
      </div>

    </div>
<% end %>