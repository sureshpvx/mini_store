<%= form_with model: [:admin, product],
              local: true,
              html: {
                multipart: true,
                class: "w-full"
              } do |f| %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">

    <!-- ===================================================== -->
    <!-- LEFT SIDE -->
    <!-- ===================================================== -->

    <div class="space-y-7 text-left">

      <!-- NAME -->
      <div>

        <label class="block w-full text-left text-[11px] uppercase tracking-[0.35em] text-gray-500 mb-4">
          Name
        </label>

        <%= f.text_field :name,
                         class: "
                           w-full
                           text-left
                           bg-transparent
                           border-0 border-b border-white/10
                           pb-4
                           text-white
                           text-lg
                           outline-none
                           focus:border-white/40
                           transition-all
                         " %>

      </div>

      <!-- DESCRIPTION -->
      <div>

        <label class="block w-full text-left text-[11px] uppercase tracking-[0.35em] text-gray-500 mb-4">
          Description
        </label>

        <%= f.text_area :description,
                        rows: 5,
                        class: "
                          w-full
                          text-left
                          bg-transparent
                          border-0 border-b border-white/10
                          pb-4
                          text-white
                          leading-relaxed
                          outline-none
                          resize-none
                          focus:border-white/40
                          transition-all
                        " %>

      </div>

      <!-- PRICE + STOCK -->
      <div class="grid grid-cols-2 gap-6">

        <!-- PRICE -->
        <div class="text-left">

          <label class="block w-full text-left text-[11px] uppercase tracking-[0.35em] text-gray-500 mb-4">
            Price
          </label>

          <%= f.number_field :price,
                             step: 0.01,
                             class: "
                               w-full
                               text-left
                               bg-transparent
                               border-0 border-b border-white/10
                               pb-4
                               text-white
                               text-lg
                               outline-none
                               focus:border-white/40
                               transition-all
                             " %>

        </div>

        <!-- STOCK -->
        <div class="text-left">

          <label class="block w-full text-left text-[11px] uppercase tracking-[0.35em] text-gray-500 mb-4">
            Stock
          </label>

          <%= f.number_field :stock,
                             class: "
                               w-full
                               text-left
                               bg-transparent
                               border-0 border-b border-white/10
                               pb-4
                               text-white
                               text-lg
                               outline-none
                               focus:border-white/40
                               transition-all
                             " %>

        </div>

      </div>

      <!-- CATEGORY -->
      <div class="text-left">

        <label class="block w-full text-left text-[11px] uppercase tracking-[0.35em] text-gray-500 mb-4">
          Category
        </label>

        <div class="relative">

          <%= f.select :category_id,

                       Category.where(parent_id: nil).map { |parent|
                         [
                           parent.name,

                           parent.subcategories.map { |sub|
                             [sub.name, sub.id]
                           }
                         ]
                       },

                       { prompt: "Select Category" },

                       {
                         class: "
                     w-full
                     text-left
                     bg-transparent
                     border-0
                     border-b
                     border-white/10
                     pb-4
                     pr-10
                     text-white
                     outline-none
                     focus:border-white/40
                     transition-all
                   "
                       } %>

          <!-- ARROW -->
          <div class="pointer-events-none absolute right-0 top-1/2 -translate-y-1/2 text-white/70">

            <svg xmlns="http://www.w3.org/2000/svg"
                 class="w-5 h-5"
                 fill="none"
                 viewBox="0 0 24 24"
                 stroke="currentColor">

              <path stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7" />

            </svg>

          </div>

        </div>

      </div>

    </div>

    <!-- ===================================================== -->
    <!-- RIGHT SIDE -->
    <!-- ===================================================== -->

    <div class="space-y-7 text-left">

      <!-- ===================================================== -->
      <!-- IMAGES -->
      <!-- ===================================================== -->

      <div data-controller="upload">

        <label class="block w-full text-left text-[11px] uppercase tracking-[0.35em] text-gray-500 mb-4">
          Product Images
        </label>

        <input
          type="file"
          name="product[images][]"
          multiple
          accept="image/*"
          data-upload-target="input"
          class="hidden" />

        <!-- DROPZONE -->
        <div
          data-upload-target="dropzone"
          data-action="click->upload#open"
          class="
            relative
            h-[220px]
            border border-dashed border-white/10
            bg-[#0A0A0A]
            overflow-y-auto
            cursor-pointer
            hover:border-white/30
            transition-all duration-300
          ">

          <!-- PLACEHOLDER -->
          <div
            data-upload-target="placeholder"
            class="
              absolute inset-0
              flex flex-col items-center justify-center
              text-center
            ">

            <p class="text-sm text-gray-400">
              Drag & drop or
              <span class="underline">browse</span>
            </p>

            <p class="text-xs text-gray-600 mt-2">
              Images only
            </p>

          </div>

          <!-- PREVIEW -->
          <div
            data-upload-target="preview"
            data-has-existing="<%= product.images.attached? %>"
            class="
              absolute inset-0
              p-4
              flex flex-wrap gap-3 content-start
            ">

            <% if product.persisted? && product.images.attached? %>

              <% product.images.each_with_index do |image, index| %>

                <div
                  data-existing="true"
                  class="
                    relative
                    w-[90px]
                    h-[90px]
                    bg-black
                    overflow-hidden
                    border border-white/10
                  ">

                  <%= image_tag image,
                                class: "w-full h-full object-cover" %>

                  <% if index == 0 %>

                    <div
                      class="
                        absolute bottom-1 left-1
                        text-[9px]
                        bg-white text-black
                        px-2 py-0.5
                        uppercase tracking-widest
                      ">

                      Primary

                    </div>

                  <% end %>

                </div>

              <% end %>

            <% end %>

          </div>

        </div>

      </div>

      <!-- ===================================================== -->
      <!-- VIDEO -->
      <!-- ===================================================== -->

      <div data-controller="upload">

        <label class="block w-full text-left text-[11px] uppercase tracking-[0.35em] text-gray-500 mb-4">
          Product Video
        </label>

        <input
          type="file"
          name="product[video]"
          accept="video/*"
          data-upload-target="input"
          class="hidden" />

        <!-- DROPZONE -->
        <div
          data-upload-target="dropzone"
          data-action="click->upload#open"
          class="
            relative
            h-[220px]
            border border-dashed border-white/10
            bg-[#0A0A0A]
            overflow-hidden
            cursor-pointer
            hover:border-white/30
            transition-all duration-300
          ">

          <!-- PLACEHOLDER -->
          <div
            data-upload-target="placeholder"
            class="
              absolute inset-0
              flex flex-col items-center justify-center
              text-center
            ">

            <p class="text-sm text-gray-400">
              Upload video
            </p>

            <p class="text-xs text-gray-600 mt-2">
              MP4 recommended
            </p>

          </div>

          <!-- PREVIEW -->
          <div
            data-upload-target="preview"
            data-has-existing="<%= product.video.attached? %>"
            class="absolute inset-0 p-4">

            <% if product.persisted? && product.video.attached? %>

              <div
                data-existing="true"
                class="
                  w-full
                  h-full
                  overflow-hidden
                  border border-white/10
                ">

                <%= video_tag url_for(product.video),
                              controls: true,
                              class: "w-full h-full object-cover" %>

              </div>

            <% end %>

          </div>

        </div>

      </div>

    </div>

  </div>

  <!-- ===================================================== -->
  <!-- FOOTER -->
  <!-- ===================================================== -->

  <div
    class="
      mt-8
      pt-6
      border-t border-white/10
      flex items-center justify-between
    ">

    <!-- CANCEL -->
    <button
      type="button"
      data-action="click->modal#close"
      class="
        text-[11px]
        uppercase
        tracking-[0.35em]
        text-gray-500
        hover:text-white
        transition-all
      ">

      Cancel

    </button>

    <!-- SUBMIT -->
    <%= f.submit product.persisted? ? "Update Product" : "Create Product",
                 class: "
                   px-10 py-4
                   border border-white
                   text-[11px]
                   uppercase
                   tracking-[0.35em]
                   text-white
                   hover:bg-white
                   hover:text-black
                   transition-all duration-300
                   cursor-pointer
                 " %>

  </div>

<% end %>