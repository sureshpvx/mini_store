<%= form_with model: [:admin, @product],
              local: true,
              multipart: true do |f| %>

  <%= f.text_field :name %>

  <%= f.text_field :description %>

  <%= f.number_field :price %>

  <%= f.number_field :stock %>

  <%= f.collection_select :category_id, Category.all, :id, :name %>

  <%= f.file_field :images, multiple: true %>

  <%= f.submit %>

<% end %>