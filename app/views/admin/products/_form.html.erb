<!-- app/views/admin/products/_form.html.erb -->
<% product = local_assigns[:product] || @product || Product.new %>

<%= form_with model: [:admin, product],
              local: true,
              multipart: true,
              html: {
                novalidate: true,
                class: "flex flex-col gap-5",
                data: { controller: "form-validation", action: "submit->form-validation#validateAll" }
              } do |f| %>

  <%# NAME %>
  <div data-field-wrapper class="flex flex-col gap-1">
    <%= f.label :name, class: "text-gray-400 text-[10px] tracking-[0.2em] uppercase text-left" %>
    <%= validated_field f, :name,
                        class: "bg-gray-50 border border-black/[0.06] text-black px-3 py-2.5 text-sm focus:border-black focus:outline-none transition-colors" %>
  </div>

  <%# DESCRIPTION %>
  <div data-field-wrapper class="flex flex-col gap-1">
    <%= f.label :description, class: "text-gray-400 text-[10px] tracking-[0.2em] uppercase text-left" %>
    <%= validated_field f, :description, as: :text_area, rows: 3,
                        class: "bg-gray-50 border border-black/[0.06] text-black px-3 py-2.5 text-sm focus:border-black focus:outline-none transition-colors resize-none" %>
  </div>

  <%# PRICE + STOCK %>
  <div class="grid grid-cols-2 gap-4">
    <div data-field-wrapper class="flex flex-col gap-1">
      <%= f.label :price, class: "text-gray-400 text-[10px] tracking-[0.2em] uppercase text-left" %>
      <%= validated_field f, :price, as: :number_field, step: "0.01",
                          class: "bg-gray-50 border border-black/[0.06] text-black px-3 py-2.5 text-sm focus:border-black focus:outline-none transition-colors" %>
    </div>
    <div data-field-wrapper class="flex flex-col gap-1">
      <%= f.label :stock, class: "text-gray-400 text-[10px] tracking-[0.2em] uppercase text-left" %>
      <%= validated_field f, :stock, as: :number_field,
                          class: "bg-gray-50 border border-black/[0.06] text-black px-3 py-2.5 text-sm focus:border-black focus:outline-none transition-colors" %>
    </div>
  </div>

  <%# CATEGORY %>
  <div data-field-wrapper class="flex flex-col gap-1">
    <%= f.label :category_id, "Category", class: "text-gray-400 text-[10px] tracking-[0.2em] uppercase text-left" %>
    <%= f.select :category_id,
                 options_for_select(
                   Category.includes(:parent).where.not(parent_id: nil).map { |c|
                     ["#{c.parent.name} — #{c.name}", c.id]
                   }.sort,
                   product.category_id
                 ),
                 { include_blank: "Select Category" },
                 {
                   required: true,
                   data: { form_validation_target: "field", action: "blur->form-validation#validateField change->form-validation#clear" },
                   class: "bg-white border border-black/[0.06] text-black px-3 py-2.5 text-sm focus:border-black focus:outline-none transition-colors cursor-pointer"
                 } %>
  </div>

  <%# EXISTING IMAGES (edit mode) %>
  <% if product.persisted? && product.images.attached? %>
    <div class="flex flex-col gap-2">
      <p class="text-gray-400 text-[10px] tracking-[0.2em] uppercase text-left">Current Images</p>
      <div class="flex gap-2 flex-wrap">
        <% product.images.each do |image| %>
          <div class="relative group">
            <%= image_tag image.variant(resize_to_limit: [80, 80]), class: "border border-black/[0.06] w-20 h-20 object-cover" %>
            <label class="absolute inset-0 flex items-center justify-center bg-white/70 opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer">
              <input type="checkbox" name="remove_image_ids[]" value="<%= image.id %>" class="accent-black">
              <span class="text-black text-[10px] ml-1">Remove</span>
            </label>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# IMAGE UPLOAD %>
  <div data-field-wrapper class="flex flex-col gap-2">
    <%= f.label :images, product.new_record? ? "Images" : "Add More Images", class: "text-gray-400 text-[10px] tracking-[0.2em] uppercase text-left" %>
    <div class="border border-dashed border-black/[0.06] p-6 text-center">
      <%= f.file_field :images,
                       multiple: true,
                       accept: "image/jpeg,image/png,image/webp",
                       required: product.new_record?,
                       data: {
                         form_validation_target: "field",
                         required: product.new_record? ? "true" : "false",
                         action: "change->form-validation#validateField change->form-validation#clear"
                       },
                       class: "text-gray-400 text-xs file:mr-4 file:py-2 file:px-4 file:border file:border-black/[0.06] file:bg-white file:text-black file:text-xs file:tracking-widest file:uppercase file:cursor-pointer hover:file:border-black transition-colors" %>
    </div>
  </div>

  <%# EXISTING VIDEO (edit mode) %>
  <% if product.persisted? && product.video.attached? %>
    <div class="flex flex-col gap-2">
      <p class="text-gray-400 text-[10px] tracking-[0.2em] uppercase text-left">Current Video</p>
      <div class="border border-black/[0.06] p-3 flex items-center justify-between">
        <span class="text-black text-xs"><%= product.video.filename %></span>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="remove_video" value="1" class="accent-black">
          <span class="text-gray-400 text-[10px] tracking-widest uppercase">Remove</span>
        </label>
      </div>
    </div>
  <% end %>

  <%# VIDEO UPLOAD %>
  <div class="flex flex-col gap-2">
    <%= f.label :video, product.new_record? ? "Video" : "Replace Video", class: "text-gray-400 text-[10px] tracking-[0.2em] uppercase text-left" %>
    <div class="border border-dashed border-black/[0.06] p-6 text-center">
      <%= f.file_field :video, accept: "video/mp4,video/webm",
                       class: "text-gray-400 text-xs file:mr-4 file:py-2 file:px-4 file:border file:border-black/[0.06] file:bg-white file:text-black file:text-xs file:tracking-widest file:uppercase file:cursor-pointer hover:file:border-black transition-colors" %>
    </div>
  </div>

  <%= f.submit product.new_record? ? "Create Product" : "Update Product",
               class: "mt-2 bg-black text-white h-12 uppercase tracking-[0.2em] text-[11px] font-medium hover:bg-gray-800 transition-colors cursor-pointer" %>

<% end %>