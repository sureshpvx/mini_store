<%# app/views/admin/products/index.html.erb %>

<div class="min-h-screen bg-white text-black flex">
  <%= render "admin/shared/sidebar", active: :products %>

  <main class="flex-1 px-10 py-10 bg-white">
    <!-- TOPBAR -->
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6 border-b border-black/[0.06] pb-8">
      <div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-3">Inventory Management</p>
        <h1 class="text-3xl font-light uppercase tracking-[0.1em] text-black">Catalog</h1>
      </div>

      <div class="flex items-center gap-4">
        <div class="hidden lg:flex items-center border border-black/[0.06] bg-gray-50 px-5 h-12 w-[320px]">
          <input type="text" placeholder="Search products..." class="bg-transparent w-full outline-none text-sm placeholder:text-gray-400">
        </div>

        <div data-controller="modal">
          <button data-modal-id="add-product-modal" data-action="click->modal#open" class="bg-black text-white px-8 h-12 uppercase tracking-[0.2em] text-[11px] font-medium hover:bg-gray-800 transition">
            + Add Product
          </button>
          <%= render "shared/modal", title: "Add Product", modal_id: "add-product-modal" do %>
            <%= render "admin/products/form", product: Product.new %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- STATS BAR -->
    <div class="flex flex-wrap gap-4 mt-8 mb-8">
      <div class="border border-black/[0.06] bg-white px-5 py-3">
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-1">Total Products</p>
        <p class="text-xl font-light text-black"><%= Product.count %></p>
      </div>
      <div class="border border-black/[0.06] bg-white px-5 py-3">
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-1">Inventory Value</p>
        <p class="text-xl font-light text-black">
          <%= number_to_currency(Product.sum("price * stock"), unit: "₹", precision: 0) %>
        </p>
      </div>
      <div class="border border-black/[0.06] bg-white px-5 py-3">
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-1">Units In Stock</p>
        <p class="text-xl font-light text-black"><%= Product.sum(:stock) %></p>
      </div>
      <div class="border border-black/[0.06] bg-white px-5 py-3">
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-1">Low Stock</p>
        <p class="text-xl font-light text-orange-500"><%= Product.where("stock < ?", 10).count %></p>
      </div>
    </div>

    <!-- PRODUCT TABLE -->
    <div class="relative overflow-hidden border border-black/[0.06] bg-white">
      <table class="w-full text-left border-collapse">
        <thead>
        <tr class="bg-gray-50/50 border-b border-black/[0.06] text-[10px] uppercase tracking-[0.3em] text-gray-400">
          <th class="p-6 font-medium">Product</th>
          <th class="p-6 font-medium">Category</th>
          <th class="p-6 font-medium">Stock</th>
          <th class="p-6 font-medium text-right">Price</th>
          <th class="p-6 font-medium text-right">Actions</th>
        </tr>
        </thead>
        <tbody class="divide-y divide-black/[0.04]">
        <% @products.each do |product| %>
          <tr class="group hover:bg-gray-50/50 transition-all duration-300">
            <td class="p-6">
              <div class="flex items-center gap-5">
                <div class="relative w-14 h-16 bg-gray-50 border border-black/[0.04] overflow-hidden">
                  <% if product.images.attached? %>
                    <%= image_tag product.images.first, class: "w-full h-full object-cover group-hover:scale-105 transition duration-700" %>
                  <% end %>
                </div>
                <div>
                  <p class="text-xs font-medium uppercase tracking-widest text-black mb-1"><%= product.name %></p>
                  <% if product.deleted? %>
                    <span class="text-[9px] uppercase tracking-widest text-red-500 border border-red-500/20 px-1.5 py-0.5">Archived</span>
                  <% end %>
                  <p class="text-[9px] text-gray-400 font-mono tracking-tighter">REF: #<%= product.id %></p>
                </div>
              </div>
            </td>
            <td class="p-6">
              <div class="flex items-center gap-2">
                <div class="h-1 w-1 bg-black/20"></div>
                <span class="text-[10px] text-gray-400 uppercase tracking-widest font-light">
                  <%= product.category&.name || "Default" %>
                </span>
              </div>
            </td>
            <td class="p-6">
              <div class="flex flex-col gap-2 w-32">
                <div class="flex justify-between items-end">
                  <span class="text-[10px] uppercase tracking-widest text-gray-400">Stock</span>
                  <span class="text-xs font-light <%= product.stock.to_i <= 10 ? 'text-orange-500' : 'text-black' %>">
                    <%= product.stock.to_i.to_s.rjust(2, '0') %>
                  </span>
                </div>
                <div class="w-full h-[1px] bg-black/[0.06] relative">
                  <div class="absolute top-0 left-0 h-full transition-all duration-1000 <%= product.stock.to_i < 10 ? 'bg-orange-500' : 'bg-black/30' %>" style="width: <%= [product.stock.to_i * 2, 100].min %>%;"></div>
                </div>
              </div>
            </td>
            <td class="p-6 text-right">
                <span class="text-xs font-light tracking-wide text-black">
                  <%= number_to_currency(product.price, unit: "₹", precision: 0) %>
                </span>
            </td>
            <td class="p-6 text-right">
              <div class="flex justify-end items-center gap-6">
                <div data-controller="modal" data-modal-id="edit-product-<%= product.id %>">
                  <button data-modal-id="edit-product-<%= product.id %>" data-action="click->modal#open" class="relative group/link">
                    <span class="text-[10px] uppercase tracking-widest text-gray-400 group-hover/link:text-black transition-colors">Edit</span>
                    <div class="absolute -bottom-1 left-0 w-0 h-px bg-black transition-all group-hover/link:w-full"></div>
                  </button>
                  <%= render "shared/modal", title: "Edit Product", modal_id: "edit-product-#{product.id}" do %>
                    <%= render "admin/products/form", product: product %>
                  <% end %>
                </div>

                <%# Inside the Actions td, before the delete button %>
                <% if product.cart_items.any? || product.order_items.where.not(order_id: @delivered_order_ids).any? %>
                  <span class="text-[9px] uppercase tracking-widest text-orange-500 border border-orange-500/20 px-1.5 py-0.5 mr-2" title="In <%= product.cart_items.count %> carts, <%= product.order_items.where.not(order_id: Order.delivered.pluck(:id)).count %> active orders">
                    Active
                  </span>
                <% end %>
                <%# In the Actions column, replace the simple delete button with this %>
                <% if product.deleted? %>
                  <%# RESTORE %>
                  <%= button_to restore_admin_product_path(product), method: :patch, class: "p-2 hover:bg-emerald-50 transition-colors text-gray-400 hover:text-emerald-600", title: "Restore product" do %>
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                  <% end %>
                <% else %>
                  <%# ARCHIVE (soft delete) %>
                  <%= button_to admin_product_path(product), method: :delete, data: { turbo_confirm: "Archive this product? It will be hidden from the store." }, class: "p-2 hover:bg-red-50 transition-colors text-gray-400 hover:text-red-500", title: "Archive product" do %>
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path d="M6 18L18 6M6 6l12 12" stroke-width="2"/>
                    </svg>
                  <% end %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>

    <!-- PAGINATION -->
    <% if @pagy&.pages.to_i > 1 %>
      <div class="mt-12 flex items-center justify-center gap-2">
        <% if @pagy.prev %>
          <%= link_to pagy_url_for(@pagy, @pagy.prev), class: "w-11 h-11 flex items-center justify-center border border-black/[0.06] text-gray-400 hover:text-black hover:border-black/20 transition-all duration-300" do %>←<% end %>
        <% end %>
        <% @pagy.series.each do |item| %>
          <% if item.is_a?(Integer) %>
            <%= link_to item, pagy_url_for(@pagy, item), class: "w-11 h-11 flex items-center justify-center border border-black/[0.06] text-gray-400 hover:text-black hover:border-black/20 text-[11px] tracking-[0.2em] transition-all duration-300" %>
          <% elsif item.is_a?(String) %>
            <div class="w-11 h-11 flex items-center justify-center bg-black text-white text-[11px] tracking-[0.2em] font-medium"><%= item %></div>
          <% elsif item == :gap %>
            <div class="w-11 text-center text-gray-400">...</div>
          <% end %>
        <% end %>
        <% if @pagy.next %>
          <%= link_to pagy_url_for(@pagy, @pagy.next), class: "w-11 h-11 flex items-center justify-center border border-black/[0.06] text-gray-400 hover:text-black hover:border-black/20 transition-all duration-300" do %>→<% end %>
        <% end %>
      </div>
    <% end %>
  </main>
</div>