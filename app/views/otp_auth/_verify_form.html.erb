<turbo-frame id="otp_modal_content">

  <div class="max-w-md mx-auto">

    <p class="text-xs uppercase tracking-[0.4em] text-gray-500 mb-3">
      Verify OTP
    </p>

    <h2 class="text-3xl text-white font-light mb-8">
      Enter Verification Code
    </h2>

    <%= form_with url: verify_otp_path,
                  method: :post,
                  data: {
                    turbo: false
                  },
                  local: true do |f| %>

      <div class="space-y-6">

        <%= f.hidden_field :phone_number,
                           value: session[:otp_phone_number] %>

        <%= f.text_field :otp,
                         placeholder: "6 Digit OTP",
                         class: "
                           w-full h-14
                           rounded-2xl
                           bg-black
                           border border-white/10
                           px-5
                           text-white
                         " %>

        <%= f.submit "Verify OTP",
                     class: "
                       w-full h-14
                       rounded-full
                       bg-white
                       text-black
                       uppercase
                       tracking-[0.3em]
                       text-sm
                     " %>

      </div>

    <% end %>

  </div>

</turbo-frame>