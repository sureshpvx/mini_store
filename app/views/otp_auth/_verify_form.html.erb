<turbo-frame id="otp_modal_content">

  <div class="max-w-md mx-auto">

    <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-3">
      Verify OTP
    </p>

    <h2 class="text-xl sm:text-2xl font-light uppercase tracking-[0.1em] text-black mb-8">
      Enter Verification Code
    </h2>

    <%= form_with url: verify_otp_path,
                  method: :post,
                  data: {
                    turbo: false
                  },
                  local: true do |f| %>

      <div class="space-y-4">

        <%= f.hidden_field :phone_number,
                           value: session[:otp_phone_number] %>

        <%= f.text_field :otp,
                         placeholder: "6 Digit OTP",
                         class: "
                           w-full h-12
                           bg-white
                           border border-black/[0.06]
                           px-4
                           text-black text-sm
                           placeholder:text-gray-400
                           focus:border-black/20
                           focus:outline-none
                           transition
                         " %>

        <%= f.submit "Verify OTP",
                     class: "
                       w-full h-14
                       bg-black
                       text-white
                       uppercase
                       tracking-[0.2em]
                       text-[11px]
                       hover:bg-gray-800
                       transition-all
                       duration-300
                       cursor-pointer
                     " %>

      </div>

    <% end %>

  </div>

</turbo-frame>